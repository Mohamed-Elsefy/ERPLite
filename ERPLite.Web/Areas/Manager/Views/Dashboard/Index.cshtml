@model ManagerDashboardViewModel

@{
    ViewData["Title"] = "Manager Dashboard";
}

<div class="row g-4 mb-4">
    <div class="col-12 col-md-4">
        <div class="card stat-card shadow-sm h-100 bg-white border-0 p-4 rounded-4">
            <div class="d-flex align-items-center">
                <div class="bg-primary-subtle text-primary p-3 rounded-3 me-3">
                    <i class="bi bi-people-fill fs-3"></i>
                </div>
                <div>
                    <h6 class="text-muted mb-1 fw-medium small">Department Personnel</h6>
                    <h3 class="fw-bold mb-0 text-dark">@Model.Statistics.TotalEmployees</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-4">
        <div class="card stat-card shadow-sm h-100 bg-white border-0 p-4 rounded-4">
            <div class="d-flex align-items-center">
                <div class="bg-success-subtle text-success p-3 rounded-3 me-3">
                    <i class="bi bi-cart-check-fill fs-3"></i>
                </div>
                <div>
                    <h6 class="text-muted mb-1 fw-medium small">Monitored Sales Pools</h6>
                    <h3 class="fw-bold mb-0 text-dark">@Model.Statistics.TotalOrders</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-4">
        <div class="card stat-card shadow-sm h-100 bg-white border-0 p-4 rounded-4">
            <div class="d-flex align-items-center">
                <div class="bg-info-subtle text-info p-3 rounded-3 me-3">
                    <i class="bi bi-building-gear fs-3"></i>
                </div>
                <div>
                    <h6 class="text-muted mb-1 fw-medium small">Active Departments</h6>
                    <h3 class="fw-bold mb-0 text-dark">@Model.Statistics.TotalDepartments</h3>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-12 col-lg-8">
        <div class="row g-4">
            <div class="col-12 col-sm-6">
                <div class="card shadow-sm border-0 bg-white p-4 rounded-4 border-start border-primary border-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted small mb-1 fw-bold text-uppercase">Month Revenue Stream</h6>
                            <h3 class="fw-bold mb-0 text-primary">@Model.Statistics.MonthlyRevenue.ToString("C2")</h3>
                        </div>
                        <i class="bi bi-lightning-charge text-primary fs-2 opacity-50"></i>
                    </div>
                </div>
            </div>

            <div class="col-12 col-sm-6">
                <div class="card shadow-sm border-0 bg-white p-4 rounded-4 border-start border-success border-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted small mb-1 fw-bold text-uppercase">Month Fresh Orders</h6>
                            <h3 class="fw-bold mb-0 text-success">@Model.Statistics.NewOrdersThisMonth</h3>
                        </div>
                        <i class="bi bi-calendar2-check text-success fs-2 opacity-50"></i>
                    </div>
                </div>
            </div>

            <div class="col-12">
                <div class="card shadow-sm border-0 bg-dark text-white p-4 rounded-4">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <h5 class="fw-bold text-white mb-1"><i class="bi bi-graph-up me-2 text-warning"></i>Operational Notice</h5>
                            <p class="text-white-50 mb-0 small">This month registered <span class="text-info fw-bold">@Model.Statistics.NewCustomersThisMonth new active customers</span> in the centralized system directories.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-4">
        <div class="card border-0 shadow-sm rounded-4 bg-white h-100 p-4">
            <h5 class="fw-bold text-dark mb-3"><i class="bi bi-shield-alert text-danger me-2"></i>Inventory Baseline</h5>
            <div class="row w-100 text-center mb-3 g-0">
                <div class="col-6 border-end">
                    <h2 class="fw-bold text-warning mb-0">@Model.Statistics.LowStockProducts</h2>
                    <span class="text-muted small">Low Baseline</span>
                </div>
                <div class="col-6">
                    <h2 class="fw-bold text-danger mb-0">@Model.Statistics.OutOfStockProducts</h2>
                    <span class="text-muted small">Out of Stock</span>
                </div>
            </div>
            <p class="text-muted small text-center px-1 mb-4">Stocks require review to maintain procurement cycles.</p>
            <a asp-area="Manager" asp-controller="Products" asp-action="Index" class="btn btn-outline-dark btn-sm rounded-pill w-100 mt-auto py-2 fw-semibold">
                <i class="bi bi-boxes me-1"></i> Manage Stock Inventory
            </a>
        </div>
    </div>
</div>