@{
    ViewData["Title"] = "Manager Dashboard";
}

<div class="row g-4">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center bg-white p-4 rounded shadow-sm border-start border-success border-4">
            <div>
                <h2 class="fw-bold mb-1 text-dark">Operations Management Portal</h2>
                <p class="text-muted mb-0">Welcome back, Manager. Monitor department performance and action pending requests.</p>
            </div>

            <form asp-area="" asp-controller="Auth" asp-action="Logout" method="post" id="logoutForm">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-danger d-flex align-items-center gap-2 px-3 py-2 fw-semibold shadow-sm">
                    <i class="bi bi-box-arrow-right"></i>
                    <span>Sign Out</span>
                </button>
            </form>
        </div>
    </div>

    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100 bg-white">
            <div class="card-body d-flex align-items-center p-4">
                <div class="bg-danger-subtle text-danger p-3 rounded-3 me-3">
                    <i class="bi bi-exclamation-circle-fill fs-3"></i>
                </div>
                <div>
                    <h6 class="text-muted mb-1 fw-medium">Pending Leaves</h6>
                    <h4 class="fw-bold mb-0 text-dark">5 Requests</h4>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100 bg-white">
            <div class="card-body d-flex align-items-center p-4">
                <div class="bg-success-subtle text-success p-3 rounded-3 me-3">
                    <i class="bi bi-graph-up-arrow fs-3"></i>
                </div>
                <div>
                    <h6 class="text-muted mb-1 fw-medium">Department Velocity</h6>
                    <h4 class="fw-bold mb-0 text-dark">92%</h4>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100 bg-white">
            <div class="card-body d-flex align-items-center p-4">
                <div class="bg-primary-subtle text-primary p-3 rounded-3 me-3">
                    <i class="bi bi-file-earmark-spreadsheet-fill fs-3"></i>
                </div>
                <div>
                    <h6 class="text-muted mb-1 fw-medium">Reports for Review</h6>
                    <h4 class="fw-bold mb-0 text-dark">3 Files</h4>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100 bg-white">
            <div class="card-body d-flex align-items-center p-4">
                <div class="bg-info-subtle text-info p-3 rounded-3 me-3">
                    <i class="bi bi-person-check-fill fs-3"></i>
                </div>
                <div>
                    <h6 class="text-muted mb-1 fw-medium">Active Staff Today</h6>
                    <h4 class="fw-bold mb-0 text-dark">14 / 16 Present</h4>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 mb-5">
        <div class="card border-0 shadow-sm p-4 bg-white">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="fw-bold text-dark mb-0">
                    <i class="bi bi-check2-square text-success me-1"></i> Pending Team Approvals
                </h5>
                <span class="badge bg-warning text-dark"><i class="bi bi-arrow-clockwise me-1"></i>Live Sync Enabled</span>
            </div>

            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Employee Reference</th>
                            <th>Request Type</th>
                            <th>Target Period</th>
                            <th>Justification / Notes</th>
                            <th class="text-end">Action Control</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>
                                <div class="fw-semibold">Ahmed Raafat</div>
                                <small class="text-muted">Software Developer</small>
                            </td>
                            <td><span class="badge bg-primary-subtle text-primary">Annual Leave</span></td>
                            <td>June 01 - June 04, 2026</td>
                            <td class="text-muted">Family urgent circumstances</td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-success px-3 me-1 fw-semibold">Approve</button>
                                <button class="btn btn-sm btn-outline-danger px-3 fw-semibold">Reject</button>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <div class="fw-semibold">Sarah Karim</div>
                                <small class="text-muted">Data Analyst</small>
                            </td>
                            <td><span class="badge bg-warning-subtle text-warning text-dark">Early Departure</span></td>
                            <td>Today (2 Hours)</td>
                            <td class="text-muted">Scheduled medical checkup</td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-success px-3 me-1 fw-semibold">Approve</button>
                                <button class="btn btn-sm btn-outline-danger px-3 fw-semibold">Reject</button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>