@model AttendanceIndexViewModel

@{
    ViewData["Title"] = "My Attendance Sheets";
}

<div class="card border-0 shadow-sm rounded-4 bg-white p-4 mb-4">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h4 class="fw-bold text-dark mb-1"><i class="bi bi-clock-history text-primary me-2"></i>Shift Attendance Hub</h4>
            <p class="text-muted small mb-0">Manage daily punch synchronization, monitor biometric registry logs, and review monthly shift integrity stats.</p>
        </div>
    </div>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 shadow-sm mb-4" role="alert">
        <i class="bi bi-exclamation-octagon-fill me-2"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show border-0 rounded-3 shadow-sm mb-4" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row g-4 mb-4">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm rounded-4 bg-white p-4 text-center h-100 d-flex flex-column justify-content-between">
            <div>
                <div class="avatar-circle @(Model.HasCheckedInToday ? "bg-light text-muted" : "bg-success-subtle text-success") rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 65px; height: 65px;">
                    <i class="bi bi-fingerprint fs-2"></i>
                </div>
                <h5 class="fw-bold text-dark mb-1">Shift Entrance</h5>
                <p class="text-muted small mb-3">Record your starting punch for today's active shift footprint.</p>
            </div>

            <div>
                @if (Model.HasCheckedInToday)
                {
                    <div class="alert alert-success-subtle border border-success-subtle rounded-pill py-2 small fw-semibold text-success mb-0">
                        <i class="bi bi-check-all me-1"></i> Checked In Today at @Model.TodayCheckInTime
                    </div>
                }
                else
                {
                    <form asp-action="CheckIn" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-success rounded-pill px-5 fw-bold w-100 py-2 shadow-sm">
                            <i class="bi bi-box-arrow-in-right me-1"></i> Execute Check-In
                        </button>
                    </form>
                }
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card border-0 shadow-sm rounded-4 bg-white p-4 text-center h-100 d-flex flex-column justify-content-between">
            <div>
                <div class="avatar-circle @(!Model.HasCheckedInToday || Model.HasCheckedOutToday ? "bg-light text-muted" : "bg-danger-subtle text-danger") rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 65px; height: 65px;">
                    <i class="bi bi-stopwatch fs-2"></i>
                </div>
                <h5 class="fw-bold text-dark mb-1">Shift Exit</h5>
                <p class="text-muted small mb-3">Record your closing punch and conclude your administrative duty hours.</p>
            </div>

            <div>
                @if (Model.HasCheckedOutToday)
                {
                    <div class="alert alert-danger-subtle border border-danger-subtle rounded-pill py-2 small fw-semibold text-danger mb-0">
                        <i class="bi bi-moon-stars-fill me-1"></i> Checked Out Today at @Model.TodayCheckOutTime
                    </div>
                }
                else if (!Model.HasCheckedInToday)
                {
                    <button type="button" class="btn btn-light border rounded-pill px-5 text-muted w-100 py-2 small fw-semibold" disabled>
                        <i class="bi bi-lock-fill me-1"></i> Awaiting Check-In Punch
                    </button>
                }
                else
                {
                    <form asp-action="CheckOut" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger rounded-pill px-5 fw-bold w-100 py-2 shadow-sm">
                            <i class="bi bi-box-arrow-left me-1"></i> Execute Check-Out
                        </button>
                    </form>
                }
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4 bg-white p-4">
    <div class="d-flex align-items-center mb-4 pb-3 border-bottom">
        <div class="avatar-circle bg-light text-primary fw-bold me-3 rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
            <i class="bi bi-calendar-check text-primary"></i>
        </div>
        <div>
            <h5 class="fw-bold text-dark mb-0">Historical Attendance Registry</h5>
            <small class="text-muted">A verified timeline of your past working shifts and status audit classifications.</small>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light text-secondary small fw-bold">
                <tr>
                    <th scope="col" class="ps-3">Shift Date</th>
                    <th scope="col">Punch In Time</th>
                    <th scope="col">Punch Out Time</th>
                    <th scope="col" class="text-end pe-3">Status Badge</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.HistoryLog != null && Model.HistoryLog.Any())
                {
                    foreach (var item in Model.HistoryLog)
                    {
                        <tr>
                            <td class="ps-3">
                                <div class="d-flex align-items-center">
                                    <div class="avatar-circle bg-light text-secondary rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 32px; height: 32px;">
                                        <i class="bi bi-calendar3 small"></i>
                                    </div>
                                    <span class="fw-bold text-dark small">@item.Date.ToString("yyyy-MM-dd")</span>
                                </div>
                            </td>
                            <td class="text-success fw-bold small">
                                <i class="bi bi-box-arrow-in-right me-1"></i>@item.CheckInTime.ToString("hh:mm tt")
                            </td>
                            <td>
                                @if (item.CheckOutTime.HasValue)
                                {
                                    <span class="text-danger fw-bold small">
                                        <i class="bi bi-box-arrow-left me-1"></i>@item.CheckOutTime.Value.ToString("hh:mm tt")
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-warning-subtle text-warning border border-warning-subtle rounded-pill px-3 py-1.5 fw-bold small">
                                        <i class="bi bi-activity me-1"></i>Active On Duty
                                    </span>
                                }
                            </td>
                            <td class="text-end pe-3">
                                @{
                                    var currentStatus = item.Status?.ToString();
                                    var isCompliant = currentStatus == "OnTime" || currentStatus == "Present";
                                }
                                <span class="badge @(isCompliant ? "bg-success-subtle text-success border border-success-subtle" : "bg-danger-subtle text-danger border border-danger-subtle") rounded-pill px-3 py-1.5 fw-bold small">
                                    <i class="bi @(isCompliant ? "bi-shield-check" : "bi-exclamation-triangle") me-1"></i>@currentStatus
                                </span>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted py-5 small">
                            <i class="bi bi-building-dash fs-2 d-block mb-2 text-secondary"></i>No system punch records found for your account ecosystem.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>