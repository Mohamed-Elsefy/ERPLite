@model EmployeeDashboardViewModel

@{
    ViewData["Title"] = "Employee Portal";
}

<div class="card border-0 shadow-sm rounded-3 bg-white p-4 mb-4">
    <div class="d-flex align-items-center justify-content-between">
        <div>
            <h5 class="fw-bold text-dark mb-1">Welcome back, @User.Identity?.Name!</h5>
            <p class="text-muted mb-0 small">Workspace Timeline: @DateTime.Today.ToString("D")</p>
        </div>
        <div>
            @if (Model.TodayAttendance == null)
            {
                <span class="badge rounded-pill px-3 py-1.5 fw-medium font-monospace" style="background-color: #fffbeb; color: #b45309; border: 1px solid #fde68a; font-size: 0.75rem;">
                    <i class="bi bi-clock-history me-1"></i> Awaiting Check-In
                </span>
            }
            else
            {
                <span class="badge rounded-pill px-3 py-1.5 fw-medium font-monospace" style="background-color: #f0fdf4; color: #16a34a; border: 1px solid #bbf7d0; font-size: 0.75rem;">
                    <i class="bi bi-check-circle me-1"></i> Active On Duty
                </span>
            }
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-3 bg-white">
    <div class="card-header bg-transparent border-0 pt-4 px-4 pb-0">
        <h6 class="fw-bold text-dark mb-0">
            <i class="bi bi-calendar2-check text-secondary me-2"></i>Recent Attendance Records (Top 10)
        </h6>
    </div>
    <div class="card-body p-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-muted small fw-semibold" style="background-color: #f8fafc;">
                    <tr>
                        <th class="ps-3 border-0 py-3">Shift Date</th>
                        <th class="border-0 py-3">Check-In</th>
                        <th class="border-0 py-3">Check-Out</th>
                        <th class="text-end pe-3 border-0 py-3">Duty Status</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.RecentAttendances != null && Model.RecentAttendances.Any())
                    {
                        foreach (var item in Model.RecentAttendances)
                        {
                            <tr style="border-color: #f8fafc;">
                                <td class="fw-medium text-dark small ps-3">@item.Date.ToString("yyyy-MM-dd")</td>
                                <td>
                                    <span class="text-secondary font-monospace small" style="font-size: 0.8rem;">
                                        <i class="bi bi-box-arrow-in-right me-1 text-muted"></i>
                                        @item.CheckInTime.ToString("hh:mm tt")
                                    </span>
                                </td>
                                <td>
                                    @if (!item.CheckOutTime.HasValue)
                                    {
                                        <span class="badge bg-light text-secondary font-monospace border-0 rounded-pill px-2 py-0.5 small" style="font-size: 0.7rem;">
                                            Active Session
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-secondary font-monospace small" style="font-size: 0.8rem;">
                                            <i class="bi bi-box-arrow-left me-1 text-muted"></i>
                                            @item.CheckOutTime.Value.ToString("hh:mm tt")
                                        </span>
                                    }
                                </td>
                                <td class="text-end pe-3">
                                    @{
                                        var status = item.Status?.ToLower();
                                        var isOnTime = status == "present" || status == "ontime";
                                    }
                                    <span class="badge rounded-pill px-2.5 py-1 font-monospace fw-medium"
                                          style="font-size: 0.7rem;
                                        background-color: @(isOnTime ? "#f0fdf4" : "#fef2f2");
                                        color: @(isOnTime ? "#16a34a" : "#dc2626");
                                        border: 1px solid @(isOnTime ? "#bbf7d0" : "#fecaca");">
                                        @(isOnTime ? "On-Time" : item.Status)
                                    </span>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted py-5" style="background-color: #ffffff;">
                                <i class="bi bi-calendar-x d-block fs-3 mb-2 text-muted opacity-40"></i>
                                No recent attendance ledger records found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>