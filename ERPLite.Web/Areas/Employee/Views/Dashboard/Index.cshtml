@model EmployeeDashboardViewModel

@{
    ViewData["Title"] = "Employee Portal";
}

<div class="row mb-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm rounded-4 p-4 bg-white">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <h5 class="fw-bold text-dark mb-1">Welcome back, @User.Identity?.Name!</h5>
                    <p class="text-muted mb-0 small">Today is @DateTime.Today.ToString("D")</p>
                </div>
                <div>
                    @if (Model.TodayAttendance == null)
                    {
                        <span class="badge bg-warning-subtle text-warning border border-warning-subtle p-2 px-3 rounded-pill fs-6 fw-bold">
                            <i class="bi bi-exclamation-triangle me-1"></i> Not Checked-In Yet
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-success-subtle text-success border border-success-subtle p-2 px-3 rounded-pill fs-6 fw-bold">
                            <i class="bi bi-check-circle me-1"></i> Active On Duty
                        </span>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4 bg-white">
    <div class="card-header bg-transparent border-0 pt-4 px-4">
        <h5 class="fw-bold text-dark mb-0">
            <i class="bi bi-clock-history text-info me-2"></i>My Recent Attendance Records (Top 10)
        </h5>
    </div>
    <div class="card-body p-4">
        <div class="table-responsive">
            <table class="table table-hover @(Model.RecentAttendances != null && Model.RecentAttendances.Any() ? "datatable" : "") align-middle mb-0">
                <thead class="table-light text-secondary small fw-bold">
                    <tr>
                        <th class="ps-3">Shift Date</th>
                        <th>Check-In Time</th>
                        <th>Check-Out Time</th>
                        <th class="text-end pe-3">Duty Status</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.RecentAttendances != null && Model.RecentAttendances.Any())
                    {
                        foreach (var item in Model.RecentAttendances)
                        {
                            <tr>
                                <td class="fw-medium text-dark ps-3">@item.Date.ToString("yyyy-MM-dd")</td>
                                <td>
                                    <span class="text-success fw-semibold small">
                                        <i class="bi bi-box-arrow-in-right me-1"></i>
                                        @item.CheckInTime.ToString("hh:mm tt")
                                    </span>
                                </td>
                                <td>
                                    @if (!item.CheckOutTime.HasValue)
                                    {
                                        <span class="badge bg-light text-muted border rounded-pill px-2 py-1 small italic"><i class="bi bi-activity text-primary me-1"></i> Active</span>
                                    }
                                    else
                                    {
                                        <span class="text-danger fw-semibold small">
                                            <i class="bi bi-box-arrow-left me-1"></i>
                                            @item.CheckOutTime.Value.ToString("hh:mm tt")
                                        </span>
                                    }
                                </td>
                                <td class="text-end pe-3">
                                    @if (item.Status == "Present" || item.Status == "OnTime")
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill px-3 py-1.5 fw-bold small">On-Time</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger border border-danger-subtle rounded-pill px-3 py-1.5 fw-bold small">@item.Status</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted py-5">
                                <i class="bi bi-calendar-x d-block fs-3 mb-2 text-secondary"></i>
                                No recent attendance records found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>