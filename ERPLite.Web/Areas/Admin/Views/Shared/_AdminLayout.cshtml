<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ERPLite Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark border-bottom border-primary border-3">
        <div class="container-fluid px-4">
            <a class="navbar-brand fw-bold text-primary" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                <i class="bi bi-cpu-fill me-2"></i>ERPLite <span class="badge bg-danger fs-7 ms-1">Admin</span>
            </a>
            <div class="collapse navbar-collapse">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link active" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                            <i class="bi bi-speedometer2 me-1"></i> Control Panel
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white-50" href="#"><i class="bi bi-shield-lock me-1"></i> Security Roles</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white-50" href="#"><i class="bi bi-gear me-1"></i> Global Settings</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="Admin" asp-controller="Users" asp-action="Index">
                            Users
                        </a>
                    </li>
                </ul>

                <span class="text-light me-3 border-end pe-3 border-secondary">
                    <i class="bi bi-person-circle text-primary me-1"></i> Root: <strong>@User.Identity?.Name</strong>
                </span>

                <form asp-area="" asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-danger px-3 fw-semibold">
                        <i class="bi bi-box-arrow-right me-1"></i> Logout
                    </button>
                </form>
            </div>
        </div>
    </nav>

    <div class="container-fluid px-4 mt-4">
        @RenderBody()
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>