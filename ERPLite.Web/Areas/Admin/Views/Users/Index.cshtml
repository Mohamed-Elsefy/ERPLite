@model UserIndexViewModel

@{
    ViewData["Title"] = "System Access Control";
}

<div class="card border-0 shadow-sm rounded-4 bg-white p-4">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
        <div>
            <h4 class="fw-bold text-dark mb-1"><i class="bi bi-shield-lock-fill text-primary me-2"></i>User Access Management</h4>
            <p class="text-muted small mb-0">Monitor digital identities, modify system security roles, and enforce account lockouts.</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Promote" class="btn btn-outline-primary rounded-pill px-4 fw-semibold shadow-sm">
                <i class="bi bi-arrow-up-circle-fill me-1"></i> Promote Employee
            </a>
            <a asp-action="Create" class="btn btn-primary rounded-pill px-4 fw-semibold shadow-sm">
                <i class="bi bi-person-plus-fill me-1"></i> Provision New User
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 rounded-3" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form asp-action="Index" method="get" class="row g-2 mb-4">
        <div class="col-12 col-md-5 col-lg-4">
            <div class="input-group">
                <span class="input-group-text bg-white border-end-0 text-muted"><i class="bi bi-search"></i></span>
                <input type="text" name="search" value="@Model.SearchTerm" class="form-control border-start-0 rounded-end-3" placeholder="Filter by name or email address..." />
            </div>
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-light border fw-semibold rounded-3 px-3">Filter</button>
            @if (!string.IsNullOrWhiteSpace(Model.SearchTerm))
            {
                <a asp-action="Index" class="btn btn-link text-decoration-none text-muted small">Clear Criteria</a>
            }
        </div>
    </form>

    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light text-secondary small fw-bold">
                <tr>
                    <th scope="col" class="ps-3">Identity User</th>
                    <th scope="col">Security Role</th>
                    <th scope="col">Account Integrity</th>
                    <th scope="col" class="text-end pe-3">Authorization Control</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Users == null || !Model.Users.Any())
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted py-5">
                            <i class="bi bi-person-x fs-1 d-block mb-2"></i>No user credentials match your criteria.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var user in Model.Users)
                    {
                        <tr>
                            <td class="ps-3">
                                <div class="d-flex align-items-center">
                                    <div class="avatar-circle bg-light text-primary fw-bold me-3 rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                        @user.FullName.Substring(0, Math.Min(2, user.FullName.Length)).ToUpper()
                                    </div>
                                    <div>
                                        <h6 class="fw-bold mb-0 text-dark">@user.FullName</h6>
                                        <small class="text-muted">@user.Email</small>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="badge bg-primary-subtle text-primary border border-primary-subtle rounded-pill px-3 py-2 fw-bold small">
                                    <i class="bi bi-tag-fill me-1"></i>@user.Role
                                </span>
                            </td>
                            <td>
                                @if (user.IsLocked)
                                {
                                    <span class="badge bg-danger-subtle text-danger border border-danger-subtle rounded-pill px-3 py-2">
                                        <i class="bi bi-lock-fill me-1"></i>Administrative Block Active
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill px-3 py-2">
                                        <i class="bi bi-shield-check me-1"></i>Operational / Clear
                                    </span>
                                }
                            </td>
                            <td class="text-end pe-3">
                                <div class="d-inline-flex gap-2 align-items-center">
                                    <a asp-action="Details" asp-route-id="@user.Id" class="btn btn-sm btn-light border rounded-circle d-flex align-items-center justify-content-center" style="width:32px; height:32px; padding:0;" title="View Integrated Profile">
                                        <i class="bi bi-eye-fill text-muted fs-6"></i>
                                    </a>

                                    <a asp-action="EditRole" asp-route-id="@user.Id" class="btn btn-sm btn-outline-secondary rounded-pill px-3 fw-semibold" title="Modify Application Privileges">
                                        <i class="bi bi-shield-shaded me-1"></i>Edit Role
                                    </a>

                                    @if (user.IsLocked)
                                    {
                                        <form asp-action="Unlock" asp-route-id="@user.Id" method="post" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-success rounded-pill px-3 fw-semibold">
                                                <i class="bi bi-unlock-fill me-1"></i>Restore Access
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-action="Lock" asp-route-id="@user.Id" method="post" onsubmit="return confirm('Are you sure you want to suspend this user account access temporarily?');" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3 fw-semibold">
                                                <i class="bi bi-lock-fill me-1"></i>Block User
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>