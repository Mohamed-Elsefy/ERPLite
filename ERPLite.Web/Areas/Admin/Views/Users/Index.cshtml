@using ERPLite.Web.Areas.Admin.Models.Users
@model UserIndexViewModel

<div class="card border-0 shadow-sm rounded-3">
    <div class="card-header bg-white border-0 pt-4 pb-3">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h3 class="fw-bold text-dark mb-1">
                    <i class="bi bi-people-fill text-primary me-2"></i>Users Management
                </h3>
                <p class="text-muted small mb-0">Manage system users, assigned roles, and account security states.</p>
            </div>
            <a asp-action="Create" class="btn btn-primary px-4 py-2 fw-semibold shadow-sm d-flex align-items-center gap-2">
                <i class="bi bi-person-plus-fill"></i>
                <span>Create New User</span>
            </a>
        </div>

        <form method="get" asp-action="Index">
            <div class="row g-2">
                <div class="col-md-5">
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0 text-muted">
                            <i class="bi bi-search"></i>
                        </span>
                        <input type="text" asp-for="SearchTerm" name="search" class="form-control border-start-0 bg-light"
                               placeholder="Search by name or email address..." value="@Model.SearchTerm" />
                    </div>
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-dark px-4 fw-semibold shadow-sm">
                        Search
                    </button>

                    @if (!string.IsNullOrWhiteSpace(Model.SearchTerm))
                    {
                        <a asp-action="Index" class="btn btn-outline-secondary px-3 d-flex align-items-center shadow-sm" title="Clear Search">
                            <i class="bi bi-x-lg"></i>
                        </a>
                    }
                </div>
            </div>
        </form>
    </div>

    <div class="card-body p-4 pt-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle border-0">
                <thead class="table-light text-secondary border-bottom border-2">
                    <tr>
                        <th class="ps-3 py-3 fw-bold">Full Name</th>
                        <th class="py-3 fw-bold">Email Address</th>
                        <th class="py-3 fw-bold">System Role</th>
                        <th class="py-3 fw-bold">Account Status</th>
                        <th class="text-end pe-3 py-3 fw-bold">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Users.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-5">
                                <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                                No users found matching your request.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var user in Model.Users)
                        {
                            <tr class="border-bottom">
                                <td class="ps-3 fw-semibold text-dark">@user.FullName</td>
                                <td class="text-muted">@user.Email</td>
                                <td>
                                    @if (user.Role == "Admin")
                                    {
                                        <span class="badge bg-danger-subtle text-danger px-3 py-2 rounded-pill fw-semibold">
                                            <i class="bi bi-shield-fill-check me-1"></i> @user.Role
                                        </span>
                                    }
                                    else if (user.Role == "Manager")
                                    {
                                        <span class="badge bg-success-subtle text-success px-3 py-2 rounded-pill fw-semibold">
                                            <i class="bi bi-briefcase-fill me-1"></i> @user.Role
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-primary-subtle text-primary px-3 py-2 rounded-pill fw-semibold">
                                            <i class="bi bi-person-fill me-1"></i> @user.Role
                                        </span>
                                    }
                                </td>
                                <td>
                                    @if (user.IsLocked)
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary px-2.5 py-1.5 rounded d-inline-flex align-items-center gap-1">
                                            <i class="bi bi-lock-fill text-danger"></i> Locked
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success-subtle text-success px-2.5 py-1.5 rounded d-inline-flex align-items-center gap-1">
                                            <i class="bi bi-check-circle-fill text-success"></i> Active
                                        </span>
                                    }
                                </td>
                                <td class="text-end pe-3">
                                    <div class="d-inline-flex gap-2">
                                        <a asp-area="Admin" asp-action="EditRole" asp-route-id="@user.Id"
                                           class="btn btn-warning btn-sm fw-semibold d-flex align-items-center gap-1 shadow-sm px-2.5"
                                           title="Edit User Role">
                                            <i class="bi bi-pencil-square"></i>
                                            <span>Edit Role</span>
                                        </a>

                                        @if (!user.IsLocked)
                                        {
                                            <form asp-action="Lock" method="post" class="m-0">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@user.Id" />
                                                <button type="submit" class="btn btn-outline-danger btn-sm fw-semibold d-flex align-items-center gap-1 shadow-sm px-2.5" title="Lock Account">
                                                    <i class="bi bi-lock-fill"></i>
                                                    <span>Lock</span>
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <form asp-action="Unlock" method="post" class="m-0">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@user.Id" />
                                                <button type="submit" class="btn btn-outline-success btn-sm fw-semibold d-flex align-items-center gap-1 shadow-sm px-2.5" title="Unlock Account">
                                                    <i class="bi bi-unlock-fill"></i>
                                                    <span>Unlock</span>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>