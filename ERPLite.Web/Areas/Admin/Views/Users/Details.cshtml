@model UserDetailsViewModel

@{

    ViewData["Title"] = "Identity Profile Details";
    var culture = System.Globalization.CultureInfo.GetCultureInfo("en-US");
    var avatarText = !string.IsNullOrEmpty(Model.FullName) && Model.FullName.Length >= 2
        ? Model.FullName.Substring(0, 2).ToUpper()
        : (!string.IsNullOrEmpty(Model.FullName) ? Model.FullName.ToUpper() : "US");
}

<div class="row justify-content-center">
    <div class="col-12 col-xl-10">

        <div class="d-flex justify-content-between align-items-center mb-4 pb-2">
            <div>
                <h4 class="fw-bold text-dark mb-1"><i class="bi bi-person-badge-fill text-primary me-2"></i>Integrated Identity File</h4>
                <p class="text-muted small mb-0">Cross-referencing system authentication tokens with corporate HR records.</p>
            </div>
            <a asp-action="Index" class="btn btn-light border rounded-pill px-4 fw-semibold small shadow-sm">
                <i class="bi bi-arrow-left me-1"></i> Back to Fleet
            </a>
        </div>

        <div class="row g-4">
            <div class="col-12 col-md-7">
                <div class="card border-0 shadow-sm rounded-4 bg-white p-4 h-100 d-flex flex-column">
                    <div class="d-flex align-items-center pb-3 border-bottom mb-4">
                        <div class="avatar-circle bg-primary-subtle text-primary fw-bold rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 60px; height: 60px; font-size: 1.3rem;">
                            @avatarText
                        </div>
                        <div>
                            <h5 class="fw-bold text-dark mb-1">@Model.FullName</h5>
                            <span class="badge bg-light text-primary border border-primary-subtle rounded-pill px-3 py-1.5 fw-semibold small">
                                <i class="bi bi-tag-fill me-1"></i>@Model.Role
                            </span>
                        </div>
                    </div>

                    <h6 class="fw-bold text-secondary mb-3 small text-uppercase tracking-wider">Security Layer</h6>

                    <div class="mb-3">
                        <label class="text-muted small d-block mb-1">User Identity ID</label>
                        <div class="fw-bold text-dark font-monospace p-2 bg-light rounded-3 border text-break small">@Model.UserId</div>
                    </div>

                    <div class="mb-3">
                        <label class="text-muted small d-block mb-1">Login Identifier (Email)</label>
                        <div class="fw-semibold text-dark p-2 bg-light rounded-3 border">
                            <i class="bi bi-envelope me-2 text-muted"></i>@Model.Email
                        </div>
                    </div>

                    @if (Model.AccountCreatedAt != DateTime.MinValue)
                    {
                        <div class="mb-4">
                            <label class="text-muted small d-block mb-1">Provisioned Date</label>
                            <div class="fw-semibold text-dark p-2 bg-light rounded-3 border">
                                <i class="bi bi-calendar-plus me-2 text-muted"></i>@Model.AccountCreatedAt.ToString("dd MMMM yyyy, hh:mm tt")
                            </div>
                        </div>
                    }

                    <div class="mb-4 p-3 bg-primary-subtle border border-primary-subtle rounded-3">
                        <label class="text-primary-emphasis small d-block mb-1 fw-bold text-uppercase">Account Operational Status</label>
                        @if (Model.IsLocked)
                        {
                            <div class="fw-bold text-danger d-flex align-items-center fs-6">
                                <i class="bi bi-lock-fill me-2"></i> Administrative Block is Active
                            </div>
                        }
                        else
                        {
                            <div class="fw-bold text-success d-flex align-items-center fs-6">
                                <i class="bi bi-shield-check me-2"></i> Access Clear / Operational
                            </div>
                        }
                    </div>

                    <div class="d-flex gap-2 mt-auto pt-3 border-top">
                        <a asp-action="EditRole" asp-route-id="@Model.UserId" class="btn btn-sm btn-primary rounded-pill px-4 fw-semibold shadow-sm">
                            <i class="bi bi-shield-shaded me-1"></i> Modify Access Privileges
                        </a>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-5">
                <div class="card border-0 shadow-sm rounded-4 bg-white p-4 h-100 d-flex flex-column">
                    <div class="d-flex align-items-center pb-3 border-bottom mb-4">
                        <i class="bi bi-building text-success fs-3 me-2"></i>
                        <div>
                            <h5 class="fw-bold text-dark mb-0">HR Synchronization</h5>
                            <small class="text-muted">Active financial database allocations.</small>
                        </div>
                    </div>

                    @if (Model.EmployeeId.HasValue)
                    {
                        <div class="text-center py-3 bg-light rounded-4 border mb-4">
                            <div class="text-success mb-2"><i class="bi bi-building-check fs-2"></i></div>
                            <h6 class="fw-bold text-dark mb-1">Active HR File Mapping</h6>
                            <small class="text-muted font-monospace d-block small">ID: #EMP-@Model.EmployeeId.Value.ToString("D4")</small>
                        </div>

                        <div class="mb-3">
                            <label class="text-muted small d-block mb-1">Organizational Unit</label>
                            <span class="badge bg-light text-primary border border-primary-subtle rounded-pill px-3 py-2 fw-semibold w-100 text-start">
                                <i class="bi bi-building-fill me-2"></i>@Model.DepartmentName
                            </span>
                        </div>

                        <div class="mb-4">
                            <label class="text-muted small d-block mb-1">Financial Allocation Rate</label>
                            <div class="p-2 bg-success-subtle border border-success-subtle rounded-3 text-success fw-bold">
                                <i class="bi bi-cash-stack me-2"></i>@Model.Salary?.ToString("C2", culture) / Mo
                            </div>
                        </div>

                        <div class="d-grid gap-2 mt-auto pt-3 border-top">
                            <a asp-area="Admin" asp-controller="Employees" asp-action="Details" asp-route-id="@Model.EmployeeId" class="btn btn-outline-success rounded-pill btn-sm fw-semibold">
                                <i class="bi bi-pencil-square me-1"></i> View HR Profile
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="text-center my-auto py-4">
                            <div class="text-secondary-subtle mb-3"><i class="bi bi-exclamation-diamond display-6"></i></div>
                            <h6 class="fw-bold text-dark">No Synchronized HR File</h6>
                            <p class="text-muted small px-3">This user account exists strictly within the security context and is not tied to a physical corporate employee file.</p>
                        </div>
                    }
                </div>
            </div>
        </div>

    </div>
</div>