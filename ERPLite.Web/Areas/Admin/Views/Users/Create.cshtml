@model CreateUserViewModel

@{
    ViewData["Title"] = "Provision User Identity";
}

<div class="row justify-content-center">
    <div class="col-12 col-lg-8">
        <div class="card border-0 shadow-sm rounded-4 bg-white p-4">
            <div class="d-flex align-items-center mb-4 pb-3 border-bottom">
                <i class="bi bi-person-plus text-primary fs-3 me-2"></i>
                <div>
                    <h5 class="fw-bold text-dark mb-0">Provision New Identity Account</h5>
                    <p class="text-muted small mb-0">Creates system login tokens and maps synchronization schemas with corporate HR metrics.</p>
                </div>
            </div>

            <form asp-action="Create" method="post" autocomplete="off">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <h6 class="fw-bold text-secondary mb-3"><i class="bi bi-shield-lock me-1"></i> Security & Authentication Profile</h6>
                <div class="row g-3 mb-4">
                    <div class="col-12">
                        <label asp-for="FullName" class="form-label fw-semibold text-muted small">User Full Name</label>
                        <input asp-for="FullName" class="form-control rounded-3" placeholder="e.g., Johnathan Doe" />
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label fw-semibold text-muted small">Login Email Identifier</label>
                        <input asp-for="Email" type="email" class="form-control rounded-3" placeholder="name@company.com" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Password" class="form-label fw-semibold text-muted small">Access Credential Password</label>
                        <input asp-for="Password" type="password" class="form-control rounded-3" placeholder="••••••••" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Role" class="form-label fw-semibold text-muted small">Assigned System Role</label>
                        <select asp-for="Role" class="form-select rounded-3 fw-semibold text-primary border-primary-subtle">
                            <option value="">-- Choose Access Permission --</option>
                            <option value="Admin">Admin (Full Administrative Access)</option>
                            <option value="Manager">Manager (Supervisory Controls)</option>
                            <option value="Employee">Employee (Standard Limited Portal)</option>
                        </select>
                        <span asp-validation-for="Role" class="text-danger small"></span>
                    </div>
                </div>

                <h6 class="fw-bold text-success mb-3"><i class="bi bi-building me-1"></i> Synchronized HR Configurations</h6>
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label asp-for="DepartmentId" class="form-label fw-semibold text-muted small">Department Assignment</label>
                        <select asp-for="DepartmentId" asp-items="Model.DepartmentList" class="form-select rounded-3">
                            <option value="">-- Select Organizational Unit --</option>
                        </select>
                        <span asp-validation-for="DepartmentId" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Salary" class="form-label fw-semibold text-muted small">Base Salary Rate</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0 text-muted small">$</span>
                            <input asp-for="Salary" type="number" step="0.01" class="form-control rounded-3 border-start-0" placeholder="0.00" />
                        </div>
                        <span asp-validation-for="Salary" class="text-danger small"></span>
                    </div>
                </div>

                <div class="p-3 bg-light rounded-3 mb-4 border border-primary-subtle">
                    <div class="form-check form-switch mb-0">
                        <input asp-for="IsEmployee" class="form-check-input" type="checkbox" role="switch" checked id="isEmployeeSwitch" onclick="return false;">
                        <label asp-for="IsEmployee" class="form-check-label fw-bold text-dark small">Is Internal Employee? (Enforced Sync)</label>
                    </div>
                    <small class="text-muted d-block mt-1">
                        <i class="bi bi-info-circle-fill text-primary me-1"></i>
                        Architecture Schema: Creating this user identity automatically deploys and maps a structured corporate HR record with the customized financial and unit metrics assigned above.
                    </small>
                </div>

                <div class="d-flex justify-content-end gap-2 border-top pt-3">
                    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Cancel</a>
                    <button type="submit" class="btn btn-primary rounded-pill px-4">
                        <i class="bi bi-cpu me-1"></i> Synchronize & Provision
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="~/Views/Shared/Infrastructure/_ValidationScriptsPartial.cshtml" />
}