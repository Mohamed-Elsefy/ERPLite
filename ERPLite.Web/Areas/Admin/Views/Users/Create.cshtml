@model CreateUserViewModel

@{
    ViewData["Title"] = "Create User Account";
}

<div class="row justify-content-center">
    <div class="col-12 col-lg-8">
        <div class="card border-0 shadow-sm rounded-3 bg-white p-4">

            <div class="d-flex align-items-center mb-4 pb-3 border-bottom" style="border-color: #f1f5f9 !important;">
                <div class="p-2.5 rounded-3 me-3" style="background-color: #f8fafc; color: #475569; border: 1px solid #e2e8f0;">
                    <i class="bi bi-person-plus fs-4"></i>
                </div>
                <div>
                    <h6 class="fw-bold text-dark mb-0">Create New User Account</h6>
                    <small class="text-muted" style="font-size: 0.8rem;">Setup system authentication and link workspace configurations.</small>
                </div>
            </div>

            <form asp-action="Create" method="post" autocomplete="off">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <span class="d-block text-muted small fw-semibold text-uppercase tracking-wider mb-3" style="font-size: 0.65rem;">Account Credentials</span>

                <div class="row g-3 mb-4">
                    <div class="col-12">
                        <label asp-for="FullName" class="form-label text-muted small fw-medium">Full Name</label>
                        <input asp-for="FullName" class="form-control bg-light border-0 small rounded-3" style="font-size: 0.85rem;" placeholder="e.g., John Doe" />
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label text-muted small fw-medium">Email Address</label>
                        <input asp-for="Email" type="email" class="form-control bg-light border-0 small rounded-3" style="font-size: 0.85rem;" placeholder="name@company.com" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Password" class="form-label text-muted small fw-medium">Password</label>
                        <input asp-for="Password" type="password" class="form-control bg-light border-0 small rounded-3" style="font-size: 0.85rem;" placeholder="••••••••" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Role" class="form-label text-muted small fw-medium">Access Role</label>
                        <select asp-for="Role" class="form-select bg-light border-0 small rounded-3" style="font-size: 0.85rem;">
                            <option value="">-- Select Access Role --</option>
                            <option value="Admin">Admin (Full Access)</option>
                            <option value="Manager">Manager (Supervisory Controls)</option>
                            <option value="Employee">Employee (Standard Access)</option>
                        </select>
                        <span asp-validation-for="Role" class="text-danger small"></span>
                    </div>
                </div>

                <span class="d-block text-muted small fw-semibold text-uppercase tracking-wider mb-3" style="font-size: 0.65rem;">HR File Integration</span>

                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label asp-for="DepartmentId" class="form-label text-muted small fw-medium">Assigned Department</label>
                        <select asp-for="DepartmentId" asp-items="Model.DepartmentList" class="form-select bg-light border-0 small rounded-3" style="font-size: 0.85rem;">
                            <option value="">-- Select Department --</option>
                        </select>
                        <span asp-validation-for="DepartmentId" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Salary" class="form-label text-muted small fw-medium">Monthly Salary</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-0 text-muted small" style="font-size: 0.85rem;">$</span>
                            <input asp-for="Salary" type="number" step="0.01" class="form-control bg-light border-0 small rounded-end-3" style="font-size: 0.85rem;" placeholder="0.00" />
                        </div>
                        <span asp-validation-for="Salary" class="text-danger small"></span>
                    </div>
                </div>

                <div class="p-3 rounded-3 mb-4 border" style="background-color: #fafafa; border-color: #e2e8f0 !important;">
                    <div class="form-check form-switch mb-0 d-flex align-items-center">
                        <input asp-for="IsEmployee" class="form-check-input me-2 shadow-none" type="checkbox" role="switch" checked id="isEmployeeSwitch" onclick="return false;">
                        <label asp-for="IsEmployee" class="form-check-label text-dark small fw-semibold">Link Internal Employee Profile</label>
                    </div>
                    <small class="text-muted d-block mt-2" style="font-size: 0.75rem;">
                        <i class="bi bi-info-circle me-1 text-secondary"></i>
                        Notice: Creating this account automatically instantiates an associated internal employee ledger file using the specified department and payroll criteria.
                    </small>
                </div>

                <div class="d-flex justify-content-end gap-2 border-top pt-3" style="border-color: #f1f5f9 !important;">
                    <a asp-action="Index" class="btn btn-sm btn-light border rounded-pill px-3 text-dark font-monospace" style="font-size: 0.8rem; border-color: #cbd5e1 !important;">Cancel</a>
                    <button type="submit" class="btn btn-sm text-white rounded-pill px-3 fw-medium shadow-none" style="background-color: #475569; font-size: 0.8rem;">
                        Save Account
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="~/Views/Shared/Infrastructure/_ValidationScriptsPartial.cshtml" />
}