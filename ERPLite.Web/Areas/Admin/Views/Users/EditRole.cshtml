@model EditUserRoleViewModel

@{
    ViewData["Title"] = "Modify Role";
}

<div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-5">
        <div class="card border-0 shadow-sm rounded-3 bg-white p-4">

            <div class="d-flex align-items-center mb-3 pb-3 border-bottom" style="border-color: #f1f5f9 !important;">
                <div class="p-2.5 rounded-3 me-3" style="background-color: #f8fafc; color: #475569; border: 1px solid #e2e8f0;">
                    <i class="bi bi-shield-lock fs-4"></i>
                </div>
                <div>
                    <h6 class="fw-bold text-dark mb-0">Modify Security Access Role</h6>
                    <small class="text-muted" style="font-size: 0.75rem;">Adjust the authorization privileges for this account.</small>
                </div>
            </div>

            <form asp-action="EditRole" method="post" autocomplete="off" onsubmit="return confirmAction(this);">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="UserId" />

                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <div class="mb-4 bg-light p-3 rounded-3 border-0">
                    <span class="d-block small text-muted fw-semibold text-uppercase tracking-wider mb-1" style="font-size: 0.6rem;">Target Identity</span>
                    <span class="fw-semibold text-dark small d-block">@Model.FullName</span>
                    <small class="text-muted font-monospace" style="font-size: 0.75rem;">@Model.Email</small>
                </div>

                <div class="mb-4">
                    <label asp-for="Role" class="form-label text-muted small fw-medium">System Permission Level</label>
                    <select asp-for="Role" class="form-select bg-light border-0 small rounded-3" style="font-size: 0.85rem;" id="roleSelect">
                        <option value="None">⚠️ Purge Login Account (Preserve Offline HR Records)</option>
                        <option value="Admin">Admin (Full Control Privilege)</option>
                        <option value="Manager">Manager (Department Supervisor)</option>
                        <option value="Employee">Employee (Standard Access Entry)</option>
                    </select>
                    <span asp-validation-for="Role" class="text-danger small"></span>
                </div>

                <div class="d-flex gap-2 justify-content-end border-top pt-3" style="border-color: #f1f5f9 !important;">
                    <a asp-action="Index" class="btn btn-sm btn-light border rounded-pill px-3 text-dark font-monospace" style="font-size: 0.8rem; border-color: #cbd5e1 !important;">Cancel</a>
                    <button type="submit" class="btn btn-sm text-white rounded-pill px-3 fw-medium shadow-none" style="background-color: #475569; font-size: 0.8rem;">
                        Update Access Role
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="~/Views/Shared/Infrastructure/_ValidationScriptsPartial.cshtml" />

    <script>
        function confirmAction(form) {
            var select = document.getElementById('roleSelect');
            if (select.value === "None") {
                return confirm("Are you sure you want to completely remove this user's login access credentials? The system profile will be dismantled while retaining basic corporate offline files.");
            }
            return true;
        }
    </script>
}