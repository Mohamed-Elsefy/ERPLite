@model PromoteEmployeeViewModel

@{
    ViewData["Title"] = "Link Employee Account";
}

<div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
        <div class="card border-0 shadow-sm rounded-3 bg-white p-4">

            <div class="d-flex align-items-center mb-4 pb-3 border-bottom" style="border-color: #f1f5f9 !important;">
                <div class="p-2.5 rounded-3 me-3" style="background-color: #f8fafc; color: #475569; border: 1px solid #e2e8f0;">
                    <i class="bi bi-arrow-up-right fs-4"></i>
                </div>
                <div>
                    <h6 class="fw-bold text-dark mb-0">Link Corporate Personnel Access</h6>
                    <small class="text-muted" style="font-size: 0.75rem;">Provisions digital login tokens to an existing unlinked HR employee file.</small>
                </div>
            </div>

            <form asp-action="Promote" method="post" autocomplete="off">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <div class="mb-3">
                    <label asp-for="EmployeeId" class="form-label text-muted small fw-medium">Unlinked Target Personnel</label>
                    <select asp-for="EmployeeId" asp-items="Model.UnlinkedEmployeesList" class="form-select bg-light border-0 small rounded-3" style="font-size: 0.85rem;">
                        <option value="">-- Choose Corporate Staff Record --</option>
                    </select>
                    <span asp-validation-for="EmployeeId" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label text-muted small fw-medium">New Portal Password</label>
                    <input asp-for="Password" type="password" class="form-control bg-light border-0 small rounded-3" style="font-size: 0.85rem;" placeholder="••••••••" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Role" class="form-label text-muted small fw-medium">Initial Authorization Level</label>
                    <select asp-for="Role" class="form-select bg-light border-0 small rounded-3" style="font-size: 0.85rem;">
                        <option value="">-- Select Security Assignment --</option>
                        <option value="Admin">Admin (Full System Privilege)</option>
                        <option value="Manager">Manager (Supervisory Controls)</option>
                        <option value="Employee">Employee (Standard Access Entry)</option>
                    </select>
                    <span asp-validation-for="Role" class="text-danger small"></span>
                </div>

                <div class="d-flex justify-content-end gap-2 border-top pt-3" style="border-color: #f1f5f9 !important;">
                    <a asp-action="Index" class="btn btn-sm btn-light border rounded-pill px-3 text-dark font-monospace" style="font-size: 0.8rem; border-color: #cbd5e1 !important;">Cancel</a>
                    <button type="submit" class="btn btn-sm text-white rounded-pill px-3 fw-medium shadow-none" style="background-color: #475569; font-size: 0.8rem;">
                        Authorize Access
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="~/Views/Shared/Infrastructure/_ValidationScriptsPartial.cshtml" />
}