@model PromoteEmployeeViewModel

@{
    ViewData["Title"] = "Promote Corporate Personnel";
}

<div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
        <div class="card border-0 shadow-sm rounded-4 bg-white p-4">
            <div class="d-flex align-items-center mb-4 pb-3 border-bottom">
                <i class="bi bi-arrow-up-circle text-primary fs-3 me-2"></i>
                <div>
                    <h5 class="fw-bold text-dark mb-0">Elevate Personnel Access Privileges</h5>
                    <p class="text-muted small mb-0">Grants system credential access layer tokens to an active HR corporate employee profile.</p>
                </div>
            </div>

            <form asp-action="Promote" method="post" autocomplete="off">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <div class="mb-3">
                    <label asp-for="EmployeeId" class="form-label fw-semibold text-muted small">Target Corporate Employee</label>
                    <select asp-for="EmployeeId" asp-items="Model.UnlinkedEmployeesList" class="form-select rounded-3">
                        <option value="">-- Choose Unlinked Corporate Staff --</option>
                    </select>
                    <span asp-validation-for="EmployeeId" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label fw-semibold text-muted small">New Access Password</label>
                    <input asp-for="Password" type="password" class="form-control rounded-3" placeholder="••••••••" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Role" class="form-label fw-semibold text-muted small">System Security Level</label>
                    <select asp-for="Role" class="form-select rounded-3">
                        <option value="">-- Select Security Assignment --</option>
                        <option value="Admin">Admin (Full Control Privilege)</option>
                        <option value="Manager">Manager (Supervisory Controls)</option>
                        <option value="Employee">Employee (Restricted Staff Portal)</option>
                    </select>
                    <span asp-validation-for="Role" class="text-danger small"></span>
                </div>

                <div class="d-flex justify-content-end gap-2 border-top pt-3">
                    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Cancel</a>
                    <button type="submit" class="btn btn-primary rounded-pill px-4 shadow-sm">
                        <i class="bi bi-shield-check me-1"></i> Authorize & Link Profile
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="~/Views/Shared/Infrastructure/_ValidationScriptsPartial.cshtml" />
}