@using ERPLite.Services.DTOs.Inventory
@model StockOperationDto

@{
    ViewData["Title"] = "Stock Out";
}

<!-- PAGE HEADER – Title & Breadcrumb  -->
<div class="mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-1">
            <li class="breadcrumb-item">
                <a asp-area="Employee" asp-controller="Dashboard" asp-action="Index" class="text-decoration-none">
                    <i class="bi bi-house-door-fill me-1"></i>Workspace
                </a>
            </li>
            <li class="breadcrumb-item">
                <a asp-area="Admin" asp-controller="Products" asp-action="Index" class="text-decoration-none">Products</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Stock Out</li>
        </ol>
    </nav>
    <h3 class="fw-bold text-dark mb-0">
        <i class="bi bi-box-arrow-up text-danger me-2"></i>Stock Out — Deduct Inventory
    </h3>
    <p class="text-muted small mb-0 mt-1">Remove stock from the product inventory.</p>
</div>

<!-- WARNING ALERT                                                 -->
<div class="row justify-content-center mb-3">
    <div class="col-lg-8 col-xl-6">
        <div class="alert alert-warning border-0 shadow-sm d-flex align-items-center" role="alert">
            <i class="bi bi-exclamation-triangle-fill fs-5 me-2"></i>
            <div>
                <strong>Caution:</strong> This operation will deduct stock from inventory.
                Ensure the quantity is correct before submitting.
            </div>
        </div>
    </div>
</div>

<!-- FORM CARD                                                     -->
<div class="row justify-content-center">
    <div class="col-lg-8 col-xl-6">
        <div class="card border-0 shadow-sm rounded-3 border-start border-warning border-3">
            <div class="card-header bg-warning text-dark py-3">
                <h5 class="mb-0 fw-semibold">
                    <i class="bi bi-box-arrow-up me-2"></i>Stock Out Operation
                </h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="StockOut" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="ProductId" type="hidden" />

                    <!-- Validation Summary -->
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>

                    <!-- Product Name Display -->
                    <div class="mb-4">
                        <label class="form-label fw-semibold text-muted small text-uppercase">
                            <i class="bi bi-box-seam me-1"></i>Product
                        </label>
                        <div class="bg-warning-subtle border border-warning-subtle rounded-3 p-3 d-flex align-items-center">
                            <div class="bg-warning text-dark p-2 rounded-3 me-3">
                                <i class="bi bi-box-seam-fill fs-4"></i>
                            </div>
                            <div>
                                <h5 class="fw-bold mb-0 text-dark">@Model.ProductName</h5>
                                <small class="text-muted">Deducting stock from this product</small>
                            </div>
                        </div>
                        <input asp-for="ProductName" type="hidden" />
                    </div>

                    <!-- Quantity Field -->
                    <div class="mb-4">
                        <label asp-for="Quantity" class="form-label fw-semibold">
                            <i class="bi bi-dash-circle me-1 text-danger"></i>Quantity to Deduct <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Quantity" class="form-control form-control-lg" type="number" min="1"
                               placeholder="Enter quantity to deduct..." />
                        <span asp-validation-for="Quantity" class="text-danger small"></span>
                        <div class="form-text text-muted">
                            <i class="bi bi-info-circle me-1"></i>Enter the number of units being removed from inventory.
                        </div>
                    </div>

                    <!-- Notes Field -->
                    <div class="mb-4">
                        <label asp-for="Notes" class="form-label fw-semibold">
                            <i class="bi bi-sticky me-1 text-warning"></i>Notes
                        </label>
                        <textarea asp-for="Notes" class="form-control" rows="3"
                                  placeholder="Optional: Add reason for stock removal (e.g., sold, damaged, returned to supplier)..."></textarea>
                        <span asp-validation-for="Notes" class="text-danger small"></span>
                    </div>

                    <!-- Action Buttons -->
                    <div class="d-flex justify-content-between align-items-center pt-3 border-top">
                        <a asp-area="Admin" asp-controller="Products" asp-action="Index"
                           class="btn btn-outline-secondary px-4 fw-semibold">
                            <i class="bi bi-arrow-left me-1"></i>Back to Products
                        </a>
                        <button type="submit" class="btn btn-warning px-5 fw-semibold shadow-sm">
                            <i class="bi bi-box-arrow-up me-1"></i>Confirm Stock Out
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- SCRIPTS – Validation & SweetAlert2                            -->
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        @if (TempData["Success"] != null)
        {
            <text>
            Swal.fire({ icon: 'success', title: 'Success', text: '@TempData["Success"]', confirmButtonColor: '#198754', timer: 3000, timerProgressBar: true });
            </text>
        }
        @if (TempData["Error"] != null)
        {
            <text>
            Swal.fire({ icon: 'error', title: 'Error', text: '@TempData["Error"]', confirmButtonColor: '#dc3545' });
            </text>
        }
    </script>
}
