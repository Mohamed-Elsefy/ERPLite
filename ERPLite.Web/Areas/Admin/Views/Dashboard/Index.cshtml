@using ERPLite.Web.Areas.Admin.Models.Dashboard
@model AdminDashboardViewModel

@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="row mt-3">
    <div class="col-12">
        <div class="card border-0 shadow-sm bg-light-subtle">
            <div class="card-body d-flex justify-content-between align-items-center p-3">
                <div class="d-flex align-items-center">
                    <div class="bg-primary text-white p-2 rounded-3 me-3">
                        <i class="bi bi-file-earmark-bar-graph fs-4"></i>
                    </div>
                    <div>
                        <h5 class="mb-0 fw-bold text-dark">Management Reports & Exports</h5>
                        <p class="text-muted mb-0 small">Generate, audit and export system financial, workforce, and inventory records.</p>
                    </div>
                </div>
                <a asp-area="Admin" asp-controller="Reports" asp-action="Index" class="btn btn-primary shadow-sm d-flex align-items-center gap-2">
                    <i class="bi bi-gear-fill"></i> Open Reports Center
                </a>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mt-2">
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100 bg-white">
            <div class="card-body d-flex align-items-center p-4">
                <div class="bg-success-subtle text-success p-3 rounded-3 me-3">
                    <i class="bi bi-currency-dollar fs-3"></i>
                </div>
                <div>
                    <h6 class="text-muted mb-1 fw-medium">Total Revenue</h6>
                    <h4 class="fw-bold mb-0 text-dark">@Model.Statistics.TotalRevenue.ToString("C")</h4>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100 bg-white">
            <div class="card-body d-flex align-items-center p-4">
                <div class="bg-primary-subtle text-primary p-3 rounded-3 me-3">
                    <i class="bi bi-people-fill fs-3"></i>
                </div>
                <div>
                    <h6 class="text-muted mb-1 fw-medium">Active Personnel</h6>
                    <h4 class="fw-bold mb-0 text-dark">@Model.Statistics.TotalEmployees Employees</h4>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 mt-4">
        <h4 class="fw-bold text-dark mb-3">Financial Analytics Framework</h4>
        <div class="row g-3">
            <div class="col-md-4">
                <div class="card bg-success border-0 text-white shadow-sm p-3">
                    <h6 class="text-white-50">Collected Cash Revenue</h6>
                    <h3 class="fw-bold">@Model.Analytics.TotalPaidRevenue.ToString("C")</h3>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card bg-danger border-0 text-white shadow-sm p-3">
                    <h6 class="text-white-50">Outstanding Receivables Balance</h6>
                    <h3 class="fw-bold">@Model.Analytics.OutstandingBalance.ToString("C")</h3>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card bg-dark border-0 text-white shadow-sm p-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <span>Paid Invoices: <strong>@Model.Analytics.PaidOrders</strong></span>
                        <span>Open Invoices: <strong>@Model.Analytics.UnpaidOrders</strong></span>
                    </div>
                    <hr class="my-2 border-white-50" />
                    <span class="small text-white-50">Total Document Pools: @Model.Analytics.TotalOrders</span>
                </div>
            </div>
        </div>
    </div>
</div>