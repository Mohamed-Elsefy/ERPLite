@using ERPLite.Web.Areas.Admin.Models.Dashboard
@model AdminDashboardViewModel

@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container-fluid py-4">
    <div class="row g-4 mb-4">
        <div class="col-12 col-sm-6 col-xl-4">
            @await Html.PartialAsync("~/Views/Shared/Components/StatisticCard/Default.cshtml", new { Title = "Total Revenue", Value = Model.Statistics?.TotalRevenue.ToString("C") ?? "$0", Icon = "fa-dollar-sign", ColorClass = "success", Trend = (decimal?)null })
        </div>
        <div class="col-12 col-sm-6 col-xl-4">
            @await Html.PartialAsync("~/Views/Shared/Components/StatisticCard/Default.cshtml", new { Title = "Total Employees", Value = Model.Statistics?.TotalEmployees.ToString("N0") ?? "0", Icon = "fa-user-tie", ColorClass = "primary", Trend = (decimal?)null })
        </div>
        <div class="col-12 col-sm-6 col-xl-4">
            @await Html.PartialAsync("~/Views/Shared/Components/StatisticCard/Default.cshtml", new { Title = "Paid Orders", Value = Model.Analytics?.PaidOrders.ToString("N0") ?? "0", Icon = "fa-file-invoice-dollar", ColorClass = "info", Trend = (decimal?)null })
        </div>
        <div class="col-12 col-sm-6 col-xl-4">
            @await Html.PartialAsync("~/Views/Shared/Components/StatisticCard/Default.cshtml", new { Title = "Unpaid Orders", Value = Model.Analytics?.UnpaidOrders.ToString("N0") ?? "0", Icon = "fa-file-invoice", ColorClass = "warning", Trend = (decimal?)null })
        </div>
        <div class="col-12 col-sm-6 col-xl-4">
            @await Html.PartialAsync("~/Views/Shared/Components/StatisticCard/Default.cshtml", new { Title = "Collected Cash", Value = Model.Analytics?.TotalPaidRevenue.ToString("C") ?? "$0", Icon = "fa-sack-dollar", ColorClass = "secondary", Trend = (decimal?)null })
        </div>
        <div class="col-12 col-sm-6 col-xl-4">
            @await Html.PartialAsync("~/Views/Shared/Components/StatisticCard/Default.cshtml", new { Title = "Outstanding Balance", Value = Model.Analytics?.OutstandingBalance.ToString("C") ?? "$0", Icon = "fa-triangle-exclamation", ColorClass = "danger", Trend = (decimal?)null })
        </div>
    </div>

    <div class="row g-4">
        <!-- Revenue Chart -->
        <div class="col-12 col-lg-8">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
                    <h6 class="fw-bold mb-0">Revenue Overview</h6>
                </div>
                <div class="card-body">
                    <div style="position: relative; height: 300px; width: 100%;">
                        <canvas id="revenueChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Notifications -->
        <div class="col-12 col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 d-flex justify-content-between align-items-center">
                    <h6 class="fw-bold mb-0">Recent Activity</h6>
                    <a href="#" class="text-decoration-none small">View All</a>
                </div>
                <div class="card-body">
                    @await Html.PartialAsync("~/Views/Shared/Components/NotificationCard/Default.cshtml", new { Title = "System Update", Priority = "Info", CreatedDate = DateTime.Now.AddHours(-2), Message = "Dashboard UI has been upgraded." })
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/dashboard/sales-chart.js"></script>
}