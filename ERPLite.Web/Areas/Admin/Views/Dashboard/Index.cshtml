@model AdminDashboardViewModel

@{
    ViewData["Title"] = "Admin Executive Hub";
    var culture = System.Globalization.CultureInfo.GetCultureInfo("en-US");
}

<div class="row g-4 mb-4">
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card shadow-sm h-100 bg-white border-0 rounded-3">
            <div class="card-body d-flex align-items-center p-4">
                <div class="p-3 rounded-3 me-3" style="background-color: #f1f5f9; color: #475569;">
                    <i class="bi bi-people fs-4"></i>
                </div>
                <div>
                    <h6 class="text-muted mb-1 fw-medium small tracking-wide text-uppercase" style="font-size: 0.7rem;">Total Employees</h6>
                    <h4 class="fw-bold mb-0 text-dark">@Model.Statistics.TotalEmployees</h4>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card shadow-sm h-100 bg-white border-0 rounded-3">
            <div class="card-body d-flex align-items-center p-4">
                <div class="p-3 rounded-3 me-3" style="background-color: #f1f5f9; color: #475569;">
                    <i class="bi bi-box-seam fs-4"></i>
                </div>
                <div>
                    <h6 class="text-muted mb-1 fw-medium small tracking-wide text-uppercase" style="font-size: 0.7rem;">Total Products</h6>
                    <h4 class="fw-bold mb-0 text-dark">@Model.Statistics.TotalProducts</h4>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card shadow-sm h-100 bg-white border-0 rounded-3">
            <div class="card-body d-flex align-items-center p-4">
                <div class="p-3 rounded-3 me-3" style="background-color: #f1f5f9; color: #475569;">
                    <i class="bi bi-cart fs-4"></i>
                </div>
                <div>
                    <h6 class="text-muted mb-1 fw-medium small tracking-wide text-uppercase" style="font-size: 0.7rem;">Total Orders</h6>
                    <h4 class="fw-bold mb-0 text-dark">@Model.Statistics.TotalOrders</h4>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card shadow-sm h-100 bg-white border-0 rounded-3">
            <div class="card-body d-flex align-items-center p-4">
                <div class="p-3 rounded-3 me-3" style="background-color: #f0fdf4; color: #16a34a;">
                    <i class="bi bi-currency-dollar fs-4"></i>
                </div>
                <div>
                    <h6 class="text-muted mb-1 fw-medium small tracking-wide text-uppercase" style="font-size: 0.7rem;">Total Gross Revenue</h6>
                    <h4 class="fw-bold mb-0 text-dark">@Model.Statistics.TotalRevenue.ToString("C2", culture)</h4>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-12 col-md-3">
        <div class="card shadow-sm border-0 bg-white p-3 rounded-3 border-start border-3" style="border-left-color: #3b82f6 !important;">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-muted small mb-1 fw-medium text-uppercase" style="font-size: 0.65rem;">Monthly Revenue</h6>
                    <h4 class="fw-bold mb-0" style="color: #1d4ed8; font-size: 1.4rem;">@Model.Statistics.MonthlyRevenue.ToString("C2", culture)</h4>
                </div>
                <i class="bi bi-graph-up text-muted opacity-30 fs-3"></i>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-3">
        <div class="card shadow-sm border-0 bg-white p-3 rounded-3 border-start border-3" style="border-left-color: #10b981 !important;">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-muted small mb-1 fw-medium text-uppercase" style="font-size: 0.65rem;">New Orders</h6>
                    <h4 class="fw-bold mb-0" style="color: #047857; font-size: 1.4rem;">@Model.Statistics.NewOrdersThisMonth</h4>
                </div>
                <i class="bi bi-bag-plus text-muted opacity-30 fs-3"></i>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-3">
        <div class="card shadow-sm border-0 bg-white p-3 rounded-3 border-start border-3" style="border-left-color: #06b6d4 !important;">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-muted small mb-1 fw-medium text-uppercase" style="font-size: 0.65rem;">New Customers</h6>
                    <h4 class="fw-bold mb-0" style="color: #0e7490; font-size: 1.4rem;">@Model.Statistics.NewCustomersThisMonth</h4>
                </div>
                <i class="bi bi-person-plus text-muted opacity-30 fs-3"></i>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-3">
        <div class="card shadow-sm border-0 bg-white p-3 rounded-3 border-start border-3" style="border-left-color: #6366f1 !important;">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-muted small mb-1 fw-medium text-uppercase" style="font-size: 0.65rem;">Inventory Value</h6>
                    <h4 class="fw-bold mb-0" style="color: #4338ca; font-size: 1.4rem;">@Model.Statistics.TotalInventoryValue.ToString("C2", culture)</h4>
                </div>
                <i class="bi bi-wallet2 text-muted opacity-30 fs-3"></i>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-12 col-lg-8">
        <div class="card border-0 shadow-sm rounded-3 bg-white h-100">
            <div class="card-header bg-transparent border-0 pt-4 px-4 pb-0">
                <h6 class="fw-bold text-dark mb-0"><i class="bi bi-bar-chart-line text-muted me-2"></i>Financial Overview Pool</h6>
            </div>
            <div class="card-body p-4">
                <div style="position: relative; height:280px;">
                    <canvas id="revenueChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-4">
        <div class="card border-0 shadow-sm rounded-3 bg-white h-100">
            <div class="card-header bg-transparent border-0 pt-4 px-4 pb-0">
                <h6 class="fw-bold text-dark mb-0"><i class="bi bi-shield-exclamation text-muted me-2"></i>Stock Security Logs</h6>
            </div>
            <div class="card-body p-4 d-flex flex-column justify-content-center align-items-center text-center">
                <div class="row w-100 mb-3 bg-light py-3 rounded-3 border border-light m-0">
                    <div class="col-6 border-end" style="border-color: #e2e8f0 !important;">
                        <h3 class="fw-bold text-dark mb-0" style="color: #b45309 !important;">@Model.Statistics.LowStockProducts</h3>
                        <span class="text-muted small fw-medium" style="font-size: 0.75rem;">Low Stock</span>
                    </div>
                    <div class="col-6">
                        <h3 class="fw-bold text-dark mb-0" style="color: #dc2626 !important;">@Model.Statistics.OutOfStockProducts</h3>
                        <span class="text-muted small fw-medium" style="font-size: 0.75rem;">Out Of Stock</span>
                    </div>
                </div>
                <p class="text-muted small px-2" style="font-size: 0.8rem; line-height: 1.5;">Critical inventory thresholds detected. Review structural security catalog levels to prevent cycle drops.</p>
                <a asp-area="" asp-controller="Products" asp-action="Index" class="btn btn-sm btn-light border rounded-pill px-4 mt-2 text-dark font-monospace" style="font-size: 0.75rem; border-color: #cbd5e1 !important;">
                    Review Ledger
                </a>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-12 col-md-4">
        <div class="card shadow-sm p-4 bg-white border-0 border-top border-3 h-100 rounded-3" style="border-top-color: #10b981 !important;">
            <h6 class="text-muted fw-medium text-uppercase small mb-2" style="font-size: 0.65rem;">Collected Liquid Capital</h6>
            <h3 class="fw-bold mb-1 font-monospace" style="color: #065f46;">@Model.Statistics.TotalPaidRevenue.ToString("C2", culture)</h3>
            <div class="text-muted small mt-2" style="font-size: 0.75rem;">
                <i class="bi bi-check-circle text-success me-1"></i> Confirmed in asset repository nodes
            </div>
        </div>
    </div>

    <div class="col-12 col-md-4">
        <div class="card shadow-sm p-4 bg-white border-0 border-top border-3 h-100 rounded-3" style="border-top-color: #ef4444 !important;">
            <h6 class="text-muted fw-medium text-uppercase small mb-2" style="font-size: 0.65rem;">Outstanding Receivables</h6>
            <h3 class="fw-bold mb-1 font-monospace" style="color: #991b1b;">@Model.Statistics.OutstandingBalance.ToString("C2", culture)</h3>
            <div class="text-muted small mt-2" style="font-size: 0.75rem;">
                <i class="bi bi-exclamation-circle text-danger me-1"></i> Total active market credit risk exposure
            </div>
        </div>
    </div>

    <div class="col-12 col-md-4">
        <div class="card shadow-sm p-4 bg-white border-0 border-top border-3 h-100 rounded-3 d-flex flex-column justify-content-between" style="border-top-color: #475569 !important;">
            <div>
                <h6 class="text-muted fw-medium text-uppercase small mb-3" style="font-size: 0.65rem;">Order Pipeline Metrics</h6>
                <div class="d-flex justify-content-between align-items-center mb-2 pb-2 border-bottom" style="border-color: #f1f5f9 !important;">
                    <span class="small" style="color: #059669;"><i class="bi bi-circle-fill me-2" style="font-size: 0.5rem;"></i>Fully Paid</span>
                    <span class="fw-semibold font-monospace text-dark small">@Model.Statistics.PaidOrders Units</span>
                </div>
                <div class="d-flex justify-content-between align-items-center mb-2 pb-2 border-bottom" style="border-color: #f1f5f9 !important;">
                    <span class="small" style="color: #d97706;"><i class="bi bi-circle-fill me-2" style="font-size: 0.5rem;"></i>Partially Paid</span>
                    <span class="fw-semibold font-monospace text-dark small">@Model.Statistics.PartialPaidOrders Units</span>
                </div>
                <div class="d-flex justify-content-between align-items-center mb-1">
                    <span class="small" style="color: #dc2626;"><i class="bi bi-circle-fill me-2" style="font-size: 0.5rem;"></i>Unpaid</span>
                    <span class="fw-semibold font-monospace text-dark small">@Model.Statistics.UnpaidOrders Units</span>
                </div>
            </div>
            <div class="pt-3 mt-3 border-top d-flex justify-content-between align-items-center text-muted font-monospace" style="font-size: 0.7rem; border-color: #f1f5f9 !important;">
                <span>Total Managed Pool:</span>
                <span class="text-dark fw-bold">@Model.Statistics.TotalOrders</span>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const ctx = document.getElementById('revenueChart').getContext('2d');
            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: ['Gross Revenue', 'Liquidity Collected', 'Market Debt Balance'],
                    datasets: [{
                        label: 'USD Currency Balance Pool',
                        data: [
                            @Model.Statistics.TotalRevenue,
                            @Model.Statistics.TotalPaidRevenue,
                            @Model.Statistics.OutstandingBalance
                        ],
                        backgroundColor: ['#475569', '#10b981', '#ef4444'], 
                        borderRadius: 6,
                        barThickness: 35
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        y: { beginAtZero: true, grid: { color: '#f8fafc' }, ticks: { font: { size: 10 } } },
                        x: { grid: { display: false }, ticks: { font: { size: 11 } } }
                    }
                }
            });
        });
    </script>
}