@using ERPLite.Services.DTOs.Inventory
@model IEnumerable<CategoryDto>

@{
    ViewData["Title"] = "Categories";

    /* ── Client-side helpers ── */
    var items = Model?.ToList() ?? new List<CategoryDto>();
    var searchTerm = ViewContext.HttpContext.Request.Query["search"].ToString();
    var sortBy = ViewContext.HttpContext.Request.Query["sortBy"].ToString();
    var sortDir = ViewContext.HttpContext.Request.Query["sortDir"].ToString();
}

<!-- PAGE HEADER – Title, Breadcrumb & Action Button               -->
<div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-1">
                <li class="breadcrumb-item">
                    <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="text-decoration-none">
                        <i class="bi bi-speedometer2 me-1"></i>Dashboard
                    </a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">Categories</li>
            </ol>
        </nav>
        <h3 class="fw-bold text-dark mb-0">
            <i class="bi bi-tags-fill text-primary me-2"></i>Category Management
        </h3>
        <p class="text-muted small mb-0 mt-1">Organize your products into meaningful categories.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary px-4 py-2 fw-semibold shadow-sm d-flex align-items-center gap-2 mt-3 mt-md-0">
        <i class="bi bi-plus-circle-fill"></i>
        <span>New Category</span>
    </a>
</div>

<!-- ============================================================ -->
<!-- MAIN CARD – Search + Table                                    -->
<!-- ============================================================ -->
<div class="card border-0 shadow-sm rounded-3">

    <!-- Search Bar -->
    <div class="card-header bg-white border-0 pt-4 pb-3">
        <form method="get" asp-action="Index">
            <div class="row g-2">
                <div class="col-md-5">
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0 text-muted">
                            <i class="bi bi-search"></i>
                        </span>
                        <input type="text" name="search" class="form-control border-start-0 bg-light"
                               placeholder="Search categories by name..." value="@searchTerm" />
                    </div>
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-dark px-4 fw-semibold shadow-sm">
                        <i class="bi bi-search me-1"></i>Search
                    </button>
                    @if (!string.IsNullOrWhiteSpace(searchTerm))
                    {
                        <a asp-action="Index" class="btn btn-outline-secondary px-3 d-flex align-items-center shadow-sm" title="Clear Search">
                            <i class="bi bi-x-lg"></i>
                        </a>
                    }
                </div>
            </div>
        </form>
    </div>

    <!-- Table Body -->
    <div class="card-body p-4 pt-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle border-0" id="categoriesTable">
                <thead class="table-light text-secondary border-bottom border-2">
                    <tr>
                        <th class="ps-3 py-3 fw-bold" style="cursor:pointer;"
                            onclick="sortTable('name')">
                            Name
                            <i class="bi bi-arrow-down-up ms-1 small text-muted"></i>
                        </th>
                        <th class="py-3 fw-bold" style="cursor:pointer;"
                            onclick="sortTable('description')">
                            Description
                            <i class="bi bi-arrow-down-up ms-1 small text-muted"></i>
                        </th>
                        <th class="text-end pe-3 py-3 fw-bold">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!items.Any())
                    {
                        <tr>
                            <td colspan="3" class="text-center py-5">
                                <div class="py-4">
                                    <i class="bi bi-inbox fs-1 text-muted d-block mb-3"></i>
                                    <h5 class="text-muted fw-semibold">No Categories Found</h5>
                                    <p class="text-muted small mb-3">Get started by creating your first product category.</p>
                                    <a asp-action="Create" class="btn btn-primary btn-sm px-4 fw-semibold">
                                        <i class="bi bi-plus-circle me-1"></i>Create Category
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var category in items)
                        {
                            <tr class="border-bottom">
                                <td class="ps-3 fw-semibold text-dark">
                                    <i class="bi bi-tag-fill text-primary me-2"></i>@category.Name
                                </td>
                                <td class="text-muted">
                                    @(string.IsNullOrWhiteSpace(category.Description) ? "—" : category.Description)
                                </td>
                                <td class="text-end pe-3">
                                    <div class="d-inline-flex gap-2">
                                        <!-- Details -->
                                        <a asp-action="Details" asp-route-id="@category.Id"
                                           class="btn btn-outline-primary btn-sm fw-semibold d-flex align-items-center gap-1 px-2"
                                           title="View Details">
                                            <i class="bi bi-eye"></i><span class="d-none d-lg-inline">Details</span>
                                        </a>
                                        <!-- Edit -->
                                        <a asp-action="Edit" asp-route-id="@category.Id"
                                           class="btn btn-warning btn-sm fw-semibold d-flex align-items-center gap-1 px-2"
                                           title="Edit Category">
                                            <i class="bi bi-pencil-square"></i><span class="d-none d-lg-inline">Edit</span>
                                        </a>
                                        <!-- Delete -->
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <form asp-action="Delete" asp-route-id="@category.Id" method="post" class="m-0 delete-form">
                                                @Html.AntiForgeryToken()
                                                <button type="button"
                                                        class="btn btn-outline-danger btn-sm fw-semibold d-flex align-items-center gap-1 px-2 btn-delete"
                                                        data-name="@category.Name"
                                                        title="Delete Category">
                                                    <i class="bi bi-trash3"></i><span class="d-none d-lg-inline">Delete</span>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination UI -->
        @if (items.Count > 0)
        {
            <div class="d-flex justify-content-between align-items-center mt-3 flex-wrap gap-2">
                <span class="text-muted small">
                    Showing <strong>@items.Count</strong> categor@(items.Count == 1 ? "y" : "ies")
                </span>
                <nav aria-label="Category pagination">
                    <ul class="pagination pagination-sm mb-0" id="paginationContainer">
                        <!-- Pagination rendered via JS -->
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>

<!-- ============================================================ -->
<!-- SCRIPTS – SweetAlert2, Delete Confirmation, Sorting, Paging  -->
<!-- ============================================================ -->
@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // ── SweetAlert2: TempData Messages ──
        @if (TempData["Success"] != null)
        {
            <text>
            Swal.fire({
                icon: 'success',
                title: 'Success',
                text: '@TempData["Success"]',
                confirmButtonColor: '#0d6efd',
                timer: 3000,
                timerProgressBar: true
            });
            </text>
        }
        @if (TempData["Error"] != null)
        {
            <text>
            Swal.fire({
                icon: 'error',
                title: 'Error',
                text: '@TempData["Error"]',
                confirmButtonColor: '#dc3545'
            });
            </text>
        }

        // ── SweetAlert2: Delete Confirmation ──
        document.querySelectorAll('.btn-delete').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var name = this.getAttribute('data-name');
                var form = this.closest('.delete-form');
                Swal.fire({
                    title: 'Delete Category?',
                    html: 'Are you sure you want to delete <strong>' + name + '</strong>?<br/>This action cannot be undone.',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#dc3545',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: '<i class="bi bi-trash3 me-1"></i>Yes, Delete',
                    cancelButtonText: 'Cancel'
                }).then(function (result) {
                    if (result.isConfirmed) {
                        form.submit();
                    }
                });
            });
        });

        // ── Client-Side Table Sorting ──
        function sortTable(column) {
            var table = document.getElementById('categoriesTable');
            var tbody = table.querySelector('tbody');
            var rows = Array.from(tbody.querySelectorAll('tr'));
            var colIndex = column === 'name' ? 0 : 1;
            var ascending = table.getAttribute('data-sort-dir') !== 'asc';

            rows.sort(function (a, b) {
                var cellA = a.cells[colIndex]?.textContent.trim().toLowerCase() || '';
                var cellB = b.cells[colIndex]?.textContent.trim().toLowerCase() || '';
                if (ascending) return cellA.localeCompare(cellB);
                return cellB.localeCompare(cellA);
            });

            table.setAttribute('data-sort-dir', ascending ? 'asc' : 'desc');
            rows.forEach(function (row) { tbody.appendChild(row); });
        }

        // ── Client-Side Pagination ──
        (function () {
            var pageSize = 10;
            var table = document.getElementById('categoriesTable');
            if (!table) return;
            var tbody = table.querySelector('tbody');
            var rows = Array.from(tbody.querySelectorAll('tr'));
            if (rows.length <= pageSize) return;

            var totalPages = Math.ceil(rows.length / pageSize);
            var currentPage = 1;

            function showPage(page) {
                currentPage = page;
                rows.forEach(function (row, i) {
                    row.style.display = (i >= (page - 1) * pageSize && i < page * pageSize) ? '' : 'none';
                });
                renderPagination();
            }

            function renderPagination() {
                var container = document.getElementById('paginationContainer');
                container.innerHTML = '';
                // Previous
                var prevLi = document.createElement('li');
                prevLi.className = 'page-item' + (currentPage === 1 ? ' disabled' : '');
                prevLi.innerHTML = '<a class="page-link" href="#">&laquo;</a>';
                prevLi.addEventListener('click', function (e) { e.preventDefault(); if (currentPage > 1) showPage(currentPage - 1); });
                container.appendChild(prevLi);
                // Page numbers
                for (var i = 1; i <= totalPages; i++) {
                    (function (p) {
                        var li = document.createElement('li');
                        li.className = 'page-item' + (p === currentPage ? ' active' : '');
                        li.innerHTML = '<a class="page-link" href="#">' + p + '</a>';
                        li.addEventListener('click', function (e) { e.preventDefault(); showPage(p); });
                        container.appendChild(li);
                    })(i);
                }
                // Next
                var nextLi = document.createElement('li');
                nextLi.className = 'page-item' + (currentPage === totalPages ? ' disabled' : '');
                nextLi.innerHTML = '<a class="page-link" href="#">&raquo;</a>';
                nextLi.addEventListener('click', function (e) { e.preventDefault(); if (currentPage < totalPages) showPage(currentPage + 1); });
                container.appendChild(nextLi);
            }

            showPage(1);
        })();
    </script>
}
