@using ERPLite.Services.DTOs.Inventory
@model ProductDto

@{
    ViewData["Title"] = "Product Details";
    var isLowStock = Model.QuantityInStock <= Model.MinStockLevel;
    var margin = Model.SellingPrice - Model.CostPrice;
    var marginPercent = Model.CostPrice > 0 ? (margin / Model.CostPrice * 100) : 0;
}

<!-- PAGE HEADER – Title & Breadcrumb                              -->
<div class="mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-1">
            <li class="breadcrumb-item">
                <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="text-decoration-none">
                    <i class="bi bi-speedometer2 me-1"></i>Dashboard
                </a>
            </li>
            <li class="breadcrumb-item">
                <a asp-action="Index" class="text-decoration-none">Products</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Details</li>
        </ol>
    </nav>
    <h3 class="fw-bold text-dark mb-0">
        <i class="bi bi-eye-fill text-info me-2"></i>Product Details
    </h3>
    <p class="text-muted small mb-0 mt-1">Viewing detailed information for <strong>@Model.Name</strong>.</p>
</div>

<!-- SUMMARY CARDS ROW                                             -->
<div class="row g-3 mb-4">
    <!-- Selling Price Card -->
    <div class="col-sm-6 col-lg-3">
        <div class="card border-0 shadow-sm h-100 bg-white">
            <div class="card-body d-flex align-items-center p-3">
                <div class="bg-success-subtle text-success p-3 rounded-3 me-3">
                    <i class="bi bi-cash-stack fs-4"></i>
                </div>
                <div>
                    <h6 class="text-muted mb-1 small fw-medium">Selling Price</h6>
                    <h5 class="fw-bold mb-0 text-dark">@Model.SellingPrice.ToString("C")</h5>
                </div>
            </div>
        </div>
    </div>
    <!-- Cost Price Card -->
    <div class="col-sm-6 col-lg-3">
        <div class="card border-0 shadow-sm h-100 bg-white">
            <div class="card-body d-flex align-items-center p-3">
                <div class="bg-primary-subtle text-primary p-3 rounded-3 me-3">
                    <i class="bi bi-currency-dollar fs-4"></i>
                </div>
                <div>
                    <h6 class="text-muted mb-1 small fw-medium">Cost Price</h6>
                    <h5 class="fw-bold mb-0 text-dark">@Model.CostPrice.ToString("C")</h5>
                </div>
            </div>
        </div>
    </div>
    <!-- Stock Card -->
    <div class="col-sm-6 col-lg-3">
        <div class="card border-0 shadow-sm h-100 @(isLowStock ? "border-start border-danger border-3" : "bg-white")">
            <div class="card-body d-flex align-items-center p-3">
                <div class="@(isLowStock ? "bg-danger-subtle text-danger" : "bg-info-subtle text-info") p-3 rounded-3 me-3">
                    <i class="bi bi-boxes fs-4"></i>
                </div>
                <div>
                    <h6 class="text-muted mb-1 small fw-medium">Current Stock</h6>
                    <h5 class="fw-bold mb-0 @(isLowStock ? "text-danger" : "text-dark")">
                        @Model.QuantityInStock
                        @if (isLowStock)
                        {
                            <span class="badge bg-danger ms-1 small">LOW</span>
                        }
                    </h5>
                </div>
            </div>
        </div>
    </div>
    <!-- Margin Card -->
    <div class="col-sm-6 col-lg-3">
        <div class="card border-0 shadow-sm h-100 bg-white">
            <div class="card-body d-flex align-items-center p-3">
                <div class="bg-warning-subtle text-warning p-3 rounded-3 me-3">
                    <i class="bi bi-graph-up-arrow fs-4"></i>
                </div>
                <div>
                    <h6 class="text-muted mb-1 small fw-medium">Profit Margin</h6>
                    <h5 class="fw-bold mb-0 text-dark">@marginPercent.ToString("F1")%</h5>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- DETAILS CARD                                                  -->
<div class="row justify-content-center">
    <div class="col-lg-10 col-xl-8">
        <div class="card border-0 shadow-sm rounded-3">
            <div class="card-header bg-info text-white py-3 d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-semibold">
                    <i class="bi bi-box-seam-fill me-2"></i>@Model.Name
                </h5>
                <span class="badge bg-light text-dark font-monospace px-3 py-2">@Model.SKU</span>
            </div>
            <div class="card-body p-4">

                <!-- SKU -->
                <div class="row mb-3 pb-3 border-bottom">
                    <div class="col-sm-4">
                        <span class="fw-semibold text-muted">
                            <i class="bi bi-upc-scan me-1"></i>SKU
                        </span>
                    </div>
                    <div class="col-sm-8">
                        <span class="badge bg-dark-subtle text-dark px-3 py-2 font-monospace fs-6">@Model.SKU</span>
                    </div>
                </div>

                <!-- Product Name -->
                <div class="row mb-3 pb-3 border-bottom">
                    <div class="col-sm-4">
                        <span class="fw-semibold text-muted">
                            <i class="bi bi-type me-1"></i>Product Name
                        </span>
                    </div>
                    <div class="col-sm-8">
                        <span class="fw-bold text-dark fs-5">@Model.Name</span>
                    </div>
                </div>

                <!-- Category -->
                <div class="row mb-3 pb-3 border-bottom">
                    <div class="col-sm-4">
                        <span class="fw-semibold text-muted">
                            <i class="bi bi-tag-fill me-1"></i>Category
                        </span>
                    </div>
                    <div class="col-sm-8">
                        <span class="badge bg-primary-subtle text-primary px-3 py-2 rounded-pill">
                            <i class="bi bi-tag me-1"></i>@Model.CategoryName
                        </span>
                    </div>
                </div>

                <!-- Supplier -->
                <div class="row mb-3 pb-3 border-bottom">
                    <div class="col-sm-4">
                        <span class="fw-semibold text-muted">
                            <i class="bi bi-truck me-1"></i>Supplier
                        </span>
                    </div>
                    <div class="col-sm-8">
                        <span class="text-dark fw-semibold">@Model.SupplierName</span>
                    </div>
                </div>

                <!-- Cost Price -->
                <div class="row mb-3 pb-3 border-bottom">
                    <div class="col-sm-4">
                        <span class="fw-semibold text-muted">
                            <i class="bi bi-currency-dollar me-1"></i>Cost Price
                        </span>
                    </div>
                    <div class="col-sm-8">
                        <span class="font-monospace fs-5 text-dark">@Model.CostPrice.ToString("C")</span>
                    </div>
                </div>

                <!-- Selling Price -->
                <div class="row mb-3 pb-3 border-bottom">
                    <div class="col-sm-4">
                        <span class="fw-semibold text-muted">
                            <i class="bi bi-cash-stack me-1"></i>Selling Price
                        </span>
                    </div>
                    <div class="col-sm-8">
                        <span class="font-monospace fs-5 fw-bold text-success">@Model.SellingPrice.ToString("C")</span>
                    </div>
                </div>

                <!-- Current Stock -->
                <div class="row mb-3 pb-3 border-bottom">
                    <div class="col-sm-4">
                        <span class="fw-semibold text-muted">
                            <i class="bi bi-boxes me-1"></i>Current Stock
                        </span>
                    </div>
                    <div class="col-sm-8">
                        @if (isLowStock)
                        {
                            <span class="badge bg-danger px-3 py-2 fs-6">
                                <i class="bi bi-exclamation-triangle-fill me-1"></i>@Model.QuantityInStock units — LOW STOCK
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-success-subtle text-success px-3 py-2 fs-6">
                                <i class="bi bi-check-circle-fill me-1"></i>@Model.QuantityInStock units
                            </span>
                        }
                    </div>
                </div>

                <!-- Minimum Stock Level -->
                <div class="row mb-3">
                    <div class="col-sm-4">
                        <span class="fw-semibold text-muted">
                            <i class="bi bi-exclamation-triangle me-1"></i>Minimum Stock
                        </span>
                    </div>
                    <div class="col-sm-8">
                        <span class="text-dark fw-semibold">@Model.MinStockLevel units</span>
                    </div>
                </div>

            </div>

            <!-- Action Buttons -->
            <div class="card-footer bg-light d-flex justify-content-between align-items-center py-3 flex-wrap gap-2">
                <a asp-action="Index" class="btn btn-outline-secondary px-4 fw-semibold">
                    <i class="bi bi-arrow-left me-1"></i>Back to List
                </a>
                <div class="d-flex gap-2 flex-wrap">
                    <a asp-area="Employee" asp-controller="Inventory" asp-action="StockIn" asp-route-productId="@Model.Id"
                       class="btn btn-success btn-sm px-3 fw-semibold shadow-sm">
                        <i class="bi bi-box-arrow-in-down me-1"></i>Stock In
                    </a>
                    <a asp-area="Employee" asp-controller="Inventory" asp-action="StockOut" asp-route-productId="@Model.Id"
                       class="btn btn-danger btn-sm px-3 fw-semibold shadow-sm">
                        <i class="bi bi-box-arrow-up me-1"></i>Stock Out
                    </a>
                    <a asp-area="Employee" asp-controller="Inventory" asp-action="History" asp-route-productId="@Model.Id"
                       class="btn btn-outline-dark btn-sm px-3 fw-semibold shadow-sm">
                        <i class="bi bi-clock-history me-1"></i>History
                    </a>
                    <a asp-action="Edit" asp-route-id="@Model.Id"
                       class="btn btn-warning btn-sm px-3 fw-semibold shadow-sm">
                        <i class="bi bi-pencil-square me-1"></i>Edit
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- SCRIPTS – SweetAlert2                                         -->
@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        @if (TempData["Success"] != null)
        {
            <text>
            Swal.fire({ icon: 'success', title: 'Success', text: '@TempData["Success"]', confirmButtonColor: '#0d6efd', timer: 3000, timerProgressBar: true });
            </text>
        }
        @if (TempData["Error"] != null)
        {
            <text>
            Swal.fire({ icon: 'error', title: 'Error', text: '@TempData["Error"]', confirmButtonColor: '#dc3545' });
            </text>
        }
    </script>
}
