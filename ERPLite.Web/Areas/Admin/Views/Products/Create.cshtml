@using ERPLite.Web.Areas.Admin.Models.Products
@model ProductFormViewModel

@{
    ViewData["Title"] = "Create Product";
}

<!-- PAGE HEADER – Title & Breadcrumb                              -->
<div class="mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-1">
            <li class="breadcrumb-item">
                <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="text-decoration-none">
                    <i class="bi bi-speedometer2 me-1"></i>Dashboard
                </a>
            </li>
            <li class="breadcrumb-item">
                <a asp-action="Index" class="text-decoration-none">Products</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Create</li>
        </ol>
    </nav>
    <h3 class="fw-bold text-dark mb-0">
        <i class="bi bi-plus-circle-fill text-primary me-2"></i>Add New Product
    </h3>
    <p class="text-muted small mb-0 mt-1">Fill in the product details below. SKU will be generated automatically.</p>
</div>

<!-- FORM CARD                                                     -->
<div class="row justify-content-center">
    <div class="col-lg-10 col-xl-8">
        <div class="card border-0 shadow-sm rounded-3">
            <div class="card-header bg-primary text-white py-3">
                <h5 class="mb-0 fw-semibold">
                    <i class="bi bi-box-seam-fill me-2"></i>Product Information
                </h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <!-- Validation Summary -->
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>

                    <!-- Info Alert: SKU Auto-generated -->
                    <div class="alert alert-info border-0 shadow-sm d-flex align-items-center mb-4" role="alert">
                        <i class="bi bi-info-circle-fill fs-5 me-2"></i>
                        <div>
                            <strong>SKU Auto-Generation:</strong> The product SKU will be assigned automatically upon creation.
                        </div>
                    </div>

                    <!-- Row 1: Name -->
                    <div class="mb-4">
                        <label asp-for="Product.Name" class="form-label fw-semibold">
                            <i class="bi bi-type me-1 text-primary"></i>Product Name <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Product.Name" class="form-control form-control-lg" placeholder="Enter product name..." />
                        <span asp-validation-for="Product.Name" class="text-danger small"></span>
                    </div>

                    <!-- Row 2: Category & Supplier Dropdowns -->
                    <div class="row mb-4">
                        <div class="col-md-6 mb-3 mb-md-0">
                            <label asp-for="Product.CategoryId" class="form-label fw-semibold">
                                <i class="bi bi-tag-fill me-1 text-primary"></i>Category <span class="text-danger">*</span>
                            </label>
                            <select asp-for="Product.CategoryId" asp-items="Model.Categories" class="form-select">
                                <option value="">-- Select Category --</option>
                            </select>
                            <span asp-validation-for="Product.CategoryId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Product.SupplierId" class="form-label fw-semibold">
                                <i class="bi bi-truck me-1 text-primary"></i>Supplier <span class="text-danger">*</span>
                            </label>
                            <select asp-for="Product.SupplierId" asp-items="Model.Suppliers" class="form-select">
                                <option value="">-- Select Supplier --</option>
                            </select>
                            <span asp-validation-for="Product.SupplierId" class="text-danger small"></span>
                        </div>
                    </div>

                    <!-- Row 3: Cost Price & Selling Price -->
                    <div class="row mb-4">
                        <div class="col-md-6 mb-3 mb-md-0">
                            <label asp-for="Product.CostPrice" class="form-label fw-semibold">
                                <i class="bi bi-currency-dollar me-1 text-primary"></i>Cost Price <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <span class="input-group-text bg-light">$</span>
                                <input asp-for="Product.CostPrice" class="form-control" type="number" step="0.01" min="0"
                                       placeholder="0.00" />
                            </div>
                            <span asp-validation-for="Product.CostPrice" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Product.SellingPrice" class="form-label fw-semibold">
                                <i class="bi bi-cash-stack me-1 text-primary"></i>Selling Price <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <span class="input-group-text bg-light">$</span>
                                <input asp-for="Product.SellingPrice" class="form-control" type="number" step="0.01" min="0"
                                       placeholder="0.00" />
                            </div>
                            <span asp-validation-for="Product.SellingPrice" class="text-danger small"></span>
                        </div>
                    </div>

                    <!-- Row 4: Quantity In Stock & Min Stock Level -->
                    <div class="row mb-4">
                        <div class="col-md-6 mb-3 mb-md-0">
                            <label asp-for="Product.QuantityInStock" class="form-label fw-semibold">
                                <i class="bi bi-boxes me-1 text-primary"></i>Initial Quantity <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Product.QuantityInStock" class="form-control" type="number" min="0"
                                   placeholder="Enter initial stock quantity..." />
                            <span asp-validation-for="Product.QuantityInStock" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Product.MinStockLevel" class="form-label fw-semibold">
                                <i class="bi bi-exclamation-triangle me-1 text-primary"></i>Minimum Stock Level <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Product.MinStockLevel" class="form-control" type="number" min="0"
                                   placeholder="Low stock alert threshold..." />
                            <span asp-validation-for="Product.MinStockLevel" class="text-danger small"></span>
                        </div>
                    </div>

                    <!-- Action Buttons -->
                    <div class="d-flex justify-content-between align-items-center pt-3 border-top">
                        <a asp-action="Index" class="btn btn-outline-secondary px-4 fw-semibold">
                            <i class="bi bi-arrow-left me-1"></i>Back to List
                        </a>
                        <button type="submit" class="btn btn-primary px-5 fw-semibold shadow-sm">
                            <i class="bi bi-check-circle me-1"></i>Create Product
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- SCRIPTS – Validation                                          -->
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        @if (TempData["Success"] != null)
        {
            <text>
            Swal.fire({ icon: 'success', title: 'Success', text: '@TempData["Success"]', confirmButtonColor: '#0d6efd', timer: 3000, timerProgressBar: true });
            </text>
        }
        @if (TempData["Error"] != null)
        {
            <text>
            Swal.fire({ icon: 'error', title: 'Error', text: '@TempData["Error"]', confirmButtonColor: '#dc3545' });
            </text>
        }
    </script>
}
