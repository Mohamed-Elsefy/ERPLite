@model ActivityLogDetailsViewModel

@{
    ViewData["Title"] = "Audit Entry Inspection";
}

<div class="row justify-content-center">
    <div class="col-12 col-md-9">
        <div class="card border-0 shadow-sm rounded-3 bg-white p-4">

            <div class="d-flex align-items-center border-bottom pb-3 mb-4" style="border-color: #f1f5f9 !important;">
                <div class="p-2.5 rounded-3 me-3" style="background-color: #f8fafc; color: #475569; border: 1px solid #e2e8f0;">
                    <i class="bi bi-terminal fs-4"></i>
                </div>
                <div>
                    <h6 class="fw-bold text-dark mb-0">Audit Ledger Entry Context</h6>
                    <small class="text-muted" style="font-size: 0.8rem;">Immutable operation transaction fingerprint captured inside admin security domain.</small>
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-12 col-sm-6">
                    <label class="text-uppercase text-muted small fw-medium tracking-wider d-block mb-1" style="font-size: 0.65rem;">Transaction Key</label>
                    <div class="p-2.5 bg-light rounded-3 font-monospace fw-semibold text-secondary small border border-light">
                        TRACE-RECORD-#@Model.Log.Id.ToString("D6")
                    </div>
                </div>
                <div class="col-12 col-sm-6">
                    <label class="text-uppercase text-muted small fw-medium tracking-wider d-block mb-1" style="font-size: 0.65rem;">Chronology Timeline</label>
                    <div class="p-2.5 bg-light rounded-3 font-monospace fw-semibold text-secondary small border border-light">
                        @Model.Log.Timestamp.ToString("yyyy-MM-dd HH:mm:ss") UTC
                    </div>
                </div>

                <div class="col-12 col-sm-6">
                    <label class="text-uppercase text-muted small fw-medium tracking-wider d-block mb-1" style="font-size: 0.65rem;">Operator Identity</label>
                    <div class="p-2.5 bg-light rounded-3 fw-medium text-dark small border border-light">
                        <i class="bi bi-person me-1.5 text-muted"></i>@Model.Log.UserFullName
                    </div>
                </div>
                <div class="col-12 col-sm-6">
                    <label class="text-uppercase text-muted small fw-medium tracking-wider d-block mb-1" style="font-size: 0.65rem;">Internal Account ID</label>
                    <div class="p-2.5 bg-light rounded-3 font-monospace text-muted small border border-light">
                        @Model.Log.UserId
                    </div>
                </div>

                <div class="col-12 col-sm-6">
                    <label class="text-uppercase text-muted small fw-medium tracking-wider d-block mb-1" style="font-size: 0.65rem;">Target Component</label>
                    <div class="p-2.5 bg-light text-secondary fw-semibold rounded-3 text-uppercase font-monospace small border border-light">
                        @Model.Log.EntityName <span class="text-muted fw-normal">(ID: @Model.Log.EntityId)</span>
                    </div>
                </div>
                <div class="col-12 col-sm-6">
                    <label class="text-uppercase text-muted small fw-medium tracking-wider d-block mb-1" style="font-size: 0.65rem;">Mutation Action</label>
                    <div class="p-2.5 bg-light text-dark fw-semibold rounded-3 text-uppercase font-monospace small border border-light">
                        @Model.Log.Action
                    </div>
                </div>

                <div class="col-12">
                    <label class="text-uppercase text-muted small fw-medium tracking-wider d-block mb-1" style="font-size: 0.65rem;">Log Operational Description</label>
                    <div class="p-3 rounded-3 shadow-none border font-monospace text-dark" style="white-space: pre-wrap; font-size: 0.85rem; line-height: 1.6; background-color: #fafafa; border-color: #e2e8f0 !important;">@Model.Log.Description</div>
                </div>
            </div>

            <div class="d-grid">
                <a asp-area="Admin" asp-action="Index" class="btn btn-light border rounded-pill py-2 fw-medium text-dark font-monospace shadow-none" style="font-size: 0.8rem; border-color: #cbd5e1 !important;">
                    <i class="bi bi-arrow-left me-1"></i> Close Audit Node View
                </a>
            </div>
        </div>
    </div>
</div>