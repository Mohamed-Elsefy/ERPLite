@model ActivityLogDetailsViewModel

@{
    ViewData["Title"] = "Audit Record Log Context";
}

<div class="row justify-content-center">
    <div class="col-12 col-md-8">
        <div class="card border-0 shadow-sm rounded-4 bg-white p-4">
            <div class="d-flex align-items-center border-bottom pb-3 mb-4">
                <div class="p-3 bg-danger text-white rounded-3 me-3">
                    <i class="bi bi-terminal-split fs-3"></i>
                </div>
                <div>
                    <h4 class="fw-bold text-dark mb-1">Audit Ledger Entry Context</h4>
                    <p class="text-muted small mb-0">Immutable tracking transaction vector captured within Secure Admin Domain.</p>
                </div>
            </div>

            <div class="row g-4 mb-4">
                <div class="col-12 col-sm-6">
                    <label class="text-uppercase text-muted small fw-bold tracking-wider d-block mb-1">Transaction Log Key</label>
                    <div class="p-3 bg-light rounded-3 font-monospace fw-bold text-secondary">
                        TRACE-RECORD-#@Model.Log.Id.ToString("D6")
                    </div>
                </div>
                <div class="col-12 col-sm-6">
                    <label class="text-uppercase text-muted small fw-bold tracking-wider d-block mb-1">Execution Chronology</label>
                    <div class="p-3 bg-light rounded-3 font-monospace fw-bold text-secondary">
                        @Model.Log.Timestamp.ToString("yyyy-MM-dd HH:mm:ss") UTC
                    </div>
                </div>

                <div class="col-12 col-sm-6">
                    <label class="text-uppercase text-muted small fw-bold tracking-wider d-block mb-1">Operator Persona</label>
                    <div class="p-3 bg-light rounded-3 fw-semibold text-dark">
                        <i class="bi bi-person-badge-fill me-2 text-primary"></i>@Model.Log.UserFullName
                    </div>
                </div>
                <div class="col-12 col-sm-6">
                    <label class="text-uppercase text-muted small fw-bold tracking-wider d-block mb-1">System Internal Identity ID</label>
                    <div class="p-3 bg-light rounded-3 font-monospace text-muted small">
                        @Model.Log.UserId
                    </div>
                </div>

                <div class="col-12 col-sm-6">
                    <label class="text-uppercase text-muted small fw-bold tracking-wider d-block mb-1">Target Engine Component</label>
                    <div class="p-3 bg-primary-subtle text-primary fw-bold rounded-3 text-uppercase font-monospace">
                        @Model.Log.EntityName (Entity ID: @Model.Log.EntityId)
                    </div>
                </div>
                <div class="col-12 col-sm-6">
                    <label class="text-uppercase text-muted small fw-bold tracking-wider d-block mb-1">Operation Mutator Action</label>
                    <div class="p-3 bg-warning-subtle text-warning fw-bold rounded-3 text-uppercase font-monospace">
                        @Model.Log.Action
                    </div>
                </div>

                <div class="col-12">
                    <label class="text-uppercase text-muted small fw-bold tracking-wider d-block mb-1">Corporate Impact Description Narrative</label>
                    <div class="p-4 bg-dark text-light font-monospace rounded-4 shadow-inner border border-secondary border-opacity-30" style="white-space: pre-wrap; font-size: 0.9rem; line-height: 1.6;">@Model.Log.Description</div>
                </div>
            </div>

            <div class="d-grid">
                <a asp-area="Admin" asp-action="Index" class="btn btn-outline-dark rounded-pill py-2.5 fw-semibold">
                    <i class="bi bi-arrow-left-circle me-1"></i> Terminate Audit View & Return to Admin Ledger
                </a>
            </div>
        </div>
    </div>
</div>