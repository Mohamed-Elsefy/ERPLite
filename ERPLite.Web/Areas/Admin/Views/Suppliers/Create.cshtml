@using ERPLite.Services.DTOs.Inventory
@model CreateSupplierDto

@{
    ViewData["Title"] = "Create Supplier";
}

<!-- PAGE HEADER – Title & Breadcrumb                              -->
<div class="mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-1">
            <li class="breadcrumb-item">
                <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="text-decoration-none">
                    <i class="bi bi-speedometer2 me-1"></i>Dashboard
                </a>
            </li>
            <li class="breadcrumb-item">
                <a asp-action="Index" class="text-decoration-none">Suppliers</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Create</li>
        </ol>
    </nav>
    <h3 class="fw-bold text-dark mb-0">
        <i class="bi bi-plus-circle-fill text-primary me-2"></i>Add New Supplier
    </h3>
    <p class="text-muted small mb-0 mt-1">Fill in the supplier details below to register a new supplier.</p>
</div>

<!-- FORM CARD                                                     -->
<div class="row justify-content-center">
    <div class="col-lg-8 col-xl-6">
        <div class="card border-0 shadow-sm rounded-3">
            <div class="card-header bg-primary text-white py-3">
                <h5 class="mb-0 fw-semibold">
                    <i class="bi bi-building me-2"></i>Supplier Information
                </h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <!-- Validation Summary -->
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>

                    <!-- Name Field -->
                    <div class="mb-4">
                        <label asp-for="Name" class="form-label fw-semibold">
                            <i class="bi bi-building me-1 text-primary"></i>Supplier Name <span class="text-danger">*</span>
                        </label>
                        <div class="form-floating">
                            <input asp-for="Name" class="form-control" id="floatingName" placeholder="Supplier Name" />
                            <label for="floatingName">Enter supplier name...</label>
                        </div>
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <!-- Phone Field -->
                    <div class="mb-4">
                        <label asp-for="Phone" class="form-label fw-semibold">
                            <i class="bi bi-telephone me-1 text-primary"></i>Phone Number <span class="text-danger">*</span>
                        </label>
                        <div class="form-floating">
                            <input asp-for="Phone" class="form-control" id="floatingPhone" placeholder="Phone Number" type="tel" />
                            <label for="floatingPhone">Enter phone number...</label>
                        </div>
                        <span asp-validation-for="Phone" class="text-danger small"></span>
                    </div>

                    <!-- Email Field -->
                    <div class="mb-4">
                        <label asp-for="Email" class="form-label fw-semibold">
                            <i class="bi bi-envelope me-1 text-primary"></i>Email Address
                        </label>
                        <div class="form-floating">
                            <input asp-for="Email" class="form-control" id="floatingEmail" placeholder="Email Address" type="email" />
                            <label for="floatingEmail">Enter email address (optional)...</label>
                        </div>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <!-- Address Field -->
                    <div class="mb-4">
                        <label asp-for="Address" class="form-label fw-semibold">
                            <i class="bi bi-geo-alt me-1 text-primary"></i>Address
                        </label>
                        <div class="form-floating">
                            <textarea asp-for="Address" class="form-control" id="floatingAddress" placeholder="Address"
                                      style="height: 100px"></textarea>
                            <label for="floatingAddress">Enter supplier address (optional)...</label>
                        </div>
                        <span asp-validation-for="Address" class="text-danger small"></span>
                    </div>

                    <!-- Action Buttons -->
                    <div class="d-flex justify-content-between align-items-center pt-3 border-top">
                        <a asp-action="Index" class="btn btn-outline-secondary px-4 fw-semibold">
                            <i class="bi bi-arrow-left me-1"></i>Back to List
                        </a>
                        <button type="submit" class="btn btn-primary px-5 fw-semibold shadow-sm">
                            <i class="bi bi-check-circle me-1"></i>Save Supplier
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- SCRIPTS – Validation & SweetAlert2                            -->
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        @if (TempData["Success"] != null)
        {
            <text>
            Swal.fire({ icon: 'success', title: 'Success', text: '@TempData["Success"]', confirmButtonColor: '#0d6efd', timer: 3000, timerProgressBar: true });
            </text>
        }
        @if (TempData["Error"] != null)
        {
            <text>
            Swal.fire({ icon: 'error', title: 'Error', text: '@TempData["Error"]', confirmButtonColor: '#dc3545' });
            </text>
        }
    </script>
}
