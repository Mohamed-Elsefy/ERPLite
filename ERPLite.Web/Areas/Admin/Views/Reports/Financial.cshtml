@model ERPLite.Services.DTOs.Reports.FinancialReportDto
@{
    ViewData["Title"] = "Financial Report";
}
<div class="container-fluid pt-4">
    <h3>Financial Report</h3>
    <div class="row mb-3">
        <div class="col-sm-3 card p-3">Revenue<br /><strong>@Model.TotalRevenue</strong></div>
        <div class="col-sm-3 card p-3">Payments<br /><strong>@Model.TotalPaid</strong></div>
        <div class="col-sm-3 card p-3">Outstanding<br /><strong>@(Model.TotalRevenue - Model.TotalPaid)</strong></div>
        <div class="col-sm-3 card p-3">Paid Orders<br /><strong>@Model.PaidOrders</strong></div>
    </div>
    <a asp-area="Admin" asp-controller="Reports" asp-action="FinancialPdf" class="btn btn-warning btn-sm">Export PDF</a>
    <div class="mt-4">
        <canvas id="financialChart" width="600" height="200"></canvas>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="/js/reports/financial-chart.js"></script>
</div>
