@model ERPLite.Services.DTOs.Reports.AttendanceReportDto
@{
    ViewData["Title"] = "Attendance Report";
}
<div class="container-fluid pt-4">
    <h3>Attendance Report</h3>
    <a asp-area="Admin" asp-controller="Reports" asp-action="EmployeesPdf" class="btn btn-primary btn-sm">Export PDF</a>
    <div class="mt-3">
        <div>Total Records: @Model.TotalRecords</div>
        <div>Present: @Model.PresentCount</div>
        <div>Late: @Model.LateCount</div>
    </div>

    <div class="table-responsive mt-3">
        <table class="table">
            <thead><tr><th>Employee</th><th>Date</th><th>CheckIn</th><th>CheckOut</th><th>Status</th></tr></thead>
            <tbody>
                @foreach (var r in Model.Records ?? new List<ERPLite.Services.DTOs.HR.AttendanceDto>())
                {
                    <tr>
                        <td>@r.EmployeeName</td>
                        <td>@r.Date.ToString("yyyy-MM-dd")</td>
                        <td>@r.CheckInTime.ToString("HH:mm")</td>
                        <td>@(r.CheckOutTime.HasValue ? r.CheckOutTime.Value.ToString("HH:mm") : "")</td>
                        <td>@r.Status</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
