@model ERPLite.Services.DTOs.Reports.EmployeesReportDto
@{
    ViewData["Title"] = "Employees Report";
}

<div class="container-fluid pt-4">
    <h3>Employees Report</h3>

    <div class="row mb-3">
        <div class="col-sm-4">
            <div class="card p-3">
                <div>Total Employees</div>
                <div class="h4">@Model.TotalEmployees</div>
            </div>
        </div>
        <div class="col-sm-4">
            <div class="card p-3">
                <div>Active Employees</div>
                <div class="h4">@Model.ActiveEmployees</div>
            </div>
        </div>
        <div class="col-sm-4">
            <div class="card p-3">
                <div>Total Salaries</div>
                <div class="h4">@Model.TotalSalaries</div>
            </div>
        </div>
    </div>

    <a asp-area="Admin" asp-controller="Reports" asp-action="EmployeesPdf" class="btn btn-primary btn-sm">Export PDF</a>

    <div class="table-responsive mt-3">
        <table class="table table-striped">
            <thead>
                <tr><th>Name</th><th>Department</th><th>Salary</th><th>Hire Date</th></tr>
            </thead>
            <tbody>
                @foreach (var e in Model.Employees ?? new List<ERPLite.Services.DTOs.HR.EmployeeDto>())
                {
                    <tr>
                        <td>@e.FullName</td>
                        <td>@e.DepartmentName</td>
                        <td>@e.Salary</td>
                        <td>@e.HireDate.ToString("yyyy-MM-dd")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
