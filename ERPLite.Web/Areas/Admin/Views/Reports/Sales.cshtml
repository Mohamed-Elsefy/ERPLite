@model ERPLite.Services.DTOs.Reports.SalesReportDto
@{
    ViewData["Title"] = "Sales Report";
}
<div class="container-fluid pt-4">
    <h3>Sales Report</h3>
    <div class="row mb-3">
        <div class="col-sm-4 card p-3">Orders Count<br /><strong>@Model.TotalOrders</strong></div>
        <div class="col-sm-4 card p-3">Revenue<br /><strong>@Model.TotalSales</strong></div>
        <div class="col-sm-4 card p-3">Average Order Value<br /><strong>@Model.AverageOrderValue</strong></div>
    </div>
    <form asp-area="Admin" asp-controller="Reports" asp-action="SalesPdf" method="get" target="_blank">
        <input type="hidden" name="from" value="@Model.From.ToString("yyyy-MM-dd")" />
        <input type="hidden" name="to" value="@Model.To.ToString("yyyy-MM-dd")" />
        <button class="btn btn-info btn-sm">Export PDF</button>
    </form>

    <div class="table-responsive mt-3">
        <table class="table">
            <thead><tr><th>Order #</th><th>Customer</th><th>Date</th><th>Total</th></tr></thead>
            <tbody>
                @foreach (var o in Model.Orders ?? new List<ERPLite.Services.DTOs.Sales.OrderDto>())
                {
                    <tr>
                        <td>@o.Id</td>
                        <td>@o.CustomerName</td>
                        <td>@o.OrderDate.ToString("yyyy-MM-dd")</td>
                        <td>@o.TotalPrice</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="mt-4">
        <canvas id="salesChart" width="600" height="200"></canvas>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="/js/reports/sales-report-chart.js"></script>
</div>
