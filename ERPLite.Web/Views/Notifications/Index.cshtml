@model IEnumerable<SystemNotificationDto>

@{
    ViewData["Title"] = "System Notifications Hub";
}

<div class="card border-0 shadow-sm rounded-4 bg-white p-4">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
        <div>
            <h4 class="fw-bold text-dark mb-1"><i class="bi bi-bell-fill text-info me-2"></i>Inbox Alerts Hub</h4>
            <p class="text-muted small mb-0">Personalized core communication vectors dispatched by system processes and automation relays.</p>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light text-secondary small fw-bold">
                <tr>
                    <th scope="col" class="ps-3">Priority Vector</th>
                    <th scope="col">Notification Context</th>
                    <th scope="col">Domain Context</th>
                    <th scope="col">Dispatched Temporal</th>
                    <th scope="col" class="text-end pe-3">Action Route</th>
                </tr>
            </thead>
            <tbody>
                @if (Model == null || !Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-5">
                            <i class="bi bi-bell-slash fs-1 d-block mb-2 text-secondary"></i>Your inbound communication stream is currently empty.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var alert in Model)
                    {
                        <tr class="@(!alert.IsRead ? "table-info table-opacity-10 fw-bold border-start border-info border-3" : "")">
                            <td class="ps-3">
                                <span class="badge @(alert.Priority.ToLower() == "urgent" || alert.Priority.ToLower() == "high" ? "bg-danger" : "bg-secondary") rounded-pill px-2.5 py-1 text-uppercase font-monospace small">
                                    @alert.Priority
                                </span>
                            </td>
                            <td>
                                <div class="text-dark">@alert.Title</div>
                                <div class="text-muted small text-truncate" style="max-width: 400px;">@alert.Message</div>
                            </td>
                            <td>
                                <span class="badge bg-light text-dark font-monospace border">@alert.Type</span>
                            </td>
                            <td class="text-muted font-monospace small">
                                @alert.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss") UTC
                            </td>
                            <td class="text-end pe-3">
                                <a asp-action="Details" asp-route-id="@alert.Id" class="btn btn-sm @(!alert.IsRead ? "btn-info text-white" : "btn-outline-dark") rounded-pill px-3 fw-semibold">
                                    <i class="bi bi-envelope-open me-1"></i> Inspect Stream
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>