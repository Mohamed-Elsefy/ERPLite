@model IEnumerable<PaymentsIndexViewModel>

@{
    ViewData["Title"] = "Global Inward Receipts Ledger";
}

<div class="card border-0 shadow-sm rounded-4 bg-white p-4">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
        <div>
            <h4 class="fw-bold text-dark mb-1">
                <i class="bi bi-cash-coin text-success me-2"></i>Global Receipts Ledger
            </h4>
            <p class="text-muted small mb-0">Audit, trace, and monitor real-time liquid capital inflow and revenue transactions across the enterprise.</p>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light text-secondary small fw-bold">
                <tr>
                    <th scope="col" class="ps-3">Voucher Ref</th>
                    <th scope="col">Amount Collected</th>
                    <th scope="col">Payment Gateway Node</th>
                    <th scope="col">Settlement Date</th>
                    <th scope="col" class="text-end pe-3">Voucher Status</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-5">
                            <i class="bi bi-journal-x fs-2 text-secondary mb-2 d-block"></i>
                            No official financial payment receipts have been captured in the system yet.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-3 font-monospace fw-bold text-secondary">
                                VCH-#@item.Id.ToString("D6")
                            </td>
                            <td class="fw-bold text-success font-monospace">
                                @item.Amount.ToString("C2")
                            </td>
                            <td>
                                <span class="badge bg-light text-dark border rounded-pill px-3 py-1">
                                    <i class="bi bi-credit-card-2-front me-1 text-primary"></i>@item.PaymentMethod
                                </span>
                            </td>
                            <td class="text-muted small">
                                @item.PaymentDate.ToString("yyyy-MM-dd HH:mm")
                            </td>
                            <td class="text-end pe-3">
                                <span class="badge bg-success-subtle text-success border border-success rounded-pill px-2.5 py-1 small">
                                    @item.Status
                                </span>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>