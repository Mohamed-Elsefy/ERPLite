@model ERPLite.Services.DTOs.Sales.OrderDto
@{
    ViewData["Title"] = $"Invoice Audit - #INV-{Model.Id.ToString("D6")}";
}

<div class="d-flex justify-content-between align-items-center mb-4 pb-2">
    <div>
        <h5 class="fw-bold text-dark mb-1"><i class="bi bi-shield-check text-secondary me-2"></i>Invoice Vault Blueprint</h5>
        <p class="text-muted small mb-0" style="font-size: 0.75rem;">Auditing immutable transaction snapshots, client parameters, and catalogued item lines.</p>
    </div>
    <div>
        <a asp-action="Index" class="btn btn-sm btn-light border font-monospace text-dark px-3 py-2" style="font-size: 0.75rem; border-color: #cbd5e1 !important;">
            <i class="bi bi-arrow-left me-1"></i> Back to Logs
        </a>
    </div>
</div>

<div class="row g-4">
    <div class="col-12 col-lg-4">
        <div class="card border-0 shadow-sm bg-white p-4 rounded-4 h-100 d-flex flex-column">
            <div class="pb-3 border-bottom mb-4" style="border-color: #f1f5f9 !important;">
                <span class="text-uppercase text-secondary fw-bold font-monospace d-block mb-1" style="font-size: 0.65rem;">System Reference Tokens</span>
                <h4 class="fw-bold text-dark font-monospace mb-0">#INV-@Model.Id.ToString("D6")</h4>
            </div>

            <div class="mb-3">
                <label class="text-muted small d-block mb-1 text-uppercase fw-bold" style="font-size: 0.6rem;">Associated Customer Node</label>
                <div class="p-2.5 border rounded-3 bg-light small text-dark fw-bold" style="border-color: #e2e8f0 !important;">
                    <i class="bi bi-person me-2 text-muted"></i>@Model.CustomerName
                </div>
            </div>

            <div class="row g-2 mb-3">
                <div class="col-6">
                    <label class="text-muted small d-block mb-1 text-uppercase fw-bold" style="font-size: 0.6rem;">Order Workflow</label>
                    <span class="badge w-100 py-2 border font-monospace text-uppercase
                        @(Model.Status.ToString() == "Completed" ? "bg-success-subtle text-success border-success-subtle" :
                            Model.Status.ToString() == "Pending" ? "bg-warning-subtle text-warning border-warning-subtle" :
                            "bg-light text-secondary border-secondary-subtle")" style="font-size: 0.65rem;">
                        <i class="bi bi-circle-fill me-1 small"></i> @Model.Status
                    </span>
                </div>
                <div class="col-6">
                    <label class="text-muted small d-block mb-1 text-uppercase fw-bold" style="font-size: 0.6rem;">Ledger Payment</label>
                    <span class="badge w-100 py-2 border font-monospace text-uppercase
                        @(Model.PaymentStatus.ToString() == "Paid" ? "bg-success-subtle text-success border-success-subtle" :
                            Model.PaymentStatus.ToString() == "Unpaid" ? "bg-danger-subtle text-danger border-danger-subtle" :
                            "bg-warning-subtle text-warning border-warning-subtle")" style="font-size: 0.65rem;">
                        <i class="bi bi-shield-shaded me-1 small"></i> @Model.PaymentStatus
                    </span>
                </div>
            </div>

            <div class="mb-3">
                <label class="text-muted small d-block mb-1 text-uppercase fw-bold" style="font-size: 0.6rem;">Operational Branch Pipeline</label>
                <div class="fw-medium text-secondary small font-monospace"><i class="bi bi-diagram-2 me-2"></i>Department Node #@Model.DepartmentId.ToString("D2")</div>
            </div>

            <div class="mb-4">
                <label class="text-muted small d-block mb-1 text-uppercase fw-bold" style="font-size: 0.6rem;">Legal Record Timestamp</label>
                <div class="fw-medium text-secondary small font-monospace"><i class="bi bi-clock me-2"></i>@Model.OrderDate.ToString("yyyy-MM-dd HH:mm:ss")</div>
            </div>

            <div class="mt-auto p-3 rounded-3 border border-success-subtle" style="background-color: #f0fdf4;">
                <label class="text-success small d-block mb-1 text-uppercase fw-bold" style="font-size: 0.65rem;">Sovereign Grand Total</label>
                <div class="font-monospace fw-bold fs-3 text-success">$@Model.TotalPrice.ToString("N2")</div>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-8">
        <div class="card border-0 shadow-sm bg-white p-4 rounded-4 h-100">
            <div class="d-flex align-items-center pb-3 border-bottom mb-4" style="border-color: #f1f5f9 !important;">
                <div class="p-2 rounded-3 me-3 text-secondary border bg-light">
                    <i class="bi bi-tags fs-5"></i>
                </div>
                <div>
                    <h6 class="fw-bold text-dark mb-0" style="font-size: 0.95rem;">Catalogued Line Items</h6>
                    <small class="text-muted" style="font-size: 0.75rem;">Exact inventory allocations bound to this ledger document snapshot.</small>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-light text-muted small fw-medium" style="font-size: 0.75rem;">
                        <tr>
                            <th scope="col" class="ps-2 border-0 py-2.5">Asset Component Spec</th>
                            <th scope="col" class="border-0 py-2.5">Unit Price</th>
                            <th scope="col" class="border-0 py-2.5">Quantity Bound</th>
                            <th scope="col" class="text-end pe-2 border-0 py-2.5">Line Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Items != null && Model.Items.Any())
                        {
                            foreach (var item in Model.Items)
                            {
                                <tr style="border-color: #f8fafc;">
                                    <td class="ps-2 py-3">
                                        <div class="fw-bold text-dark small" style="font-size: 0.8rem;">
                                            <i class="bi bi-box me-1.5 opacity-50 text-secondary"></i>@item.ProductName
                                        </div>
                                        <small class="text-muted font-monospace d-block ps-4" style="font-size: 0.65rem;">Product Node Link: #@item.ProductId</small>
                                    </td>
                                    <td class="font-monospace small text-secondary" style="font-size: 0.75rem;">
                                        $@item.UnitPrice.ToString("N2")
                                    </td>
                                    <td class="py-3">
                                        <span class="badge rounded-pill bg-light text-secondary border px-2.5 py-1 font-monospace" style="font-size: 0.7rem; border-color: #e2e8f0 !important;">
                                            x @item.Quantity Units
                                        </span>
                                    </td>
                                    <td class="text-end pe-2 font-monospace fw-bold text-dark small" style="font-size: 0.75rem;">
                                        $@((item.UnitPrice * item.Quantity).ToString("N2"))
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-5">
                                    <i class="bi bi-slash-circle d-block fs-3 mb-2 opacity-40"></i>No active line items mapped to this invoice payload structure.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>