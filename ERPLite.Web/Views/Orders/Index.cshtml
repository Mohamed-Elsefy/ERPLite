@model IEnumerable<ERPLite.Services.DTOs.Sales.OrderDto>
@{
    ViewData["Title"] = "Sales Order Logs";
}

<div class="card border-0 shadow-sm rounded-4 bg-white p-4">
    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center mb-4 pb-3 border-bottom border-light gap-3">
        <div>
            <h5 class="fw-bold text-dark mb-1">
                <i class="bi bi-receipt-cutoff text-secondary me-2"></i>Commercial Sales Ledger
            </h5>
            <p class="text-muted small mb-0" style="font-size: 0.75rem;">
                Review transactional workflows, historical invoice parameters, and structural pipeline liquidation speeds.
            </p>
        </div>
        <a asp-action="Create" class="btn btn-sm btn-dark rounded-pill px-4 fw-medium font-monospace" style="background-color: #475569; font-size: 0.8rem;">
            <i class="bi bi-plus-circle-fill me-1"></i> Generate New Invoice
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 rounded-3 small mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 small mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light text-secondary small fw-medium" style="font-size: 0.75rem;">
                <tr>
                    <th scope="col" class="ps-3 py-3 text-uppercase tracking-wider">Invoice Ref</th>
                    <th scope="col" class="py-3 text-uppercase tracking-wider">Customer</th>
                    <th scope="col" class="py-3 text-uppercase tracking-wider">Dept</th>
                    <th scope="col" class="py-3 text-uppercase tracking-wider">Date Finalized</th>
                    <th scope="col" class="py-3 text-uppercase tracking-wider">Workflow Status</th>
                    <th scope="col" class="py-3 text-uppercase tracking-wider">Payment Status</th>
                    <th scope="col" class="py-3 text-uppercase tracking-wider">Total Valuation</th>
                    <th scope="col" class="text-end pe-3 py-3 text-uppercase tracking-wider">Audit Trace</th>
                </tr>
            </thead>
            <tbody>
                @if (Model == null || !Model.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-5">
                            <i class="bi bi-receipt fs-2 d-block mb-2 opacity-30"></i>No transactional nodes recorded in the current session pipeline.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr style="border-color: #f1f5f9 !important;">
                            <td class="ps-3 py-3">
                                <span class="font-monospace fw-bold text-dark small" style="font-size: 0.8rem;">
                                    #INV-@item.Id.ToString("D6")
                                </span>
                            </td>
                            <td class="py-3 small text-dark fw-medium" style="font-size: 0.8rem;">
                                @item.CustomerName
                            </td>
                            <td class="py-3 small text-secondary">
                                <span class="badge bg-light text-dark border px-2 py-1 font-monospace" style="font-size: 0.65rem; border-color: #e2e8f0 !important;">
                                    #@item.DepartmentId.ToString("D2")
                                </span>
                            </td>
                            <td class="py-3 font-monospace text-muted small" style="font-size: 0.75rem;">
                                @item.OrderDate.ToString("yyyy-MM-dd HH:mm")
                            </td>
                            <td class="py-3">
                                <span class="badge py-1 px-2.5 border font-monospace text-uppercase" style="font-size: 0.65rem; rounded-pill: 50px;
                                    @(item.Status.ToString() == "Completed" ? "background-color: #f0fdf4; color: #16a34a; border-color: #bbf7d0;" :
                                        item.Status.ToString() == "Pending" ? "background-color: #fffbeb; color: #d97706; border-color: #fde68a;" :
                                        "background-color: #f8fafc; color: #64748b; border-color: #e2e8f0;")">
                                    @item.Status
                                </span>
                            </td>
                            <td class="py-3">
                                <span class="badge py-1 px-2.5 border font-monospace text-uppercase" style="font-size: 0.65rem; rounded-pill: 50px;
                                    @(item.PaymentStatus.ToString() == "Paid" ? "background-color: #eff6ff; color: #2563eb; border-color: #bfdbfe;" :
                                        item.PaymentStatus.ToString() == "Unpaid" ? "background-color: #fef2f2; color: #dc2626; border-color: #fecaca;" :
                                        "background-color: #fff7ed; color: #ea580c; border-color: #ffedd5;")">
                                    @item.PaymentStatus
                                </span>
                            </td>
                            <td class="py-3 font-monospace fw-bold text-success small" style="font-size: 0.8rem;">
                                $@item.TotalPrice.ToString("N2")
                            </td>
                            <td class="text-end pe-3 py-3">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-light border rounded-circle d-flex align-items-center justify-content-center ms-auto" style="width:32px; height:32px; padding:0; border-color: #cbd5e1 !important;" title="Audit Financial Blueprint">
                                    <i class="bi bi-eye text-secondary" style="font-size: 0.85rem;"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>