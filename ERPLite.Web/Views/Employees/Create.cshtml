@model CreateEmployeeViewModel

@{
    ViewData["Title"] = "Register Employee";
}

<div class="row justify-content-center">
    <div class="col-12 col-lg-8">
        <div class="card border-0 shadow-sm rounded-4 bg-white p-4">
            <div class="d-flex align-items-center mb-4 pb-3 border-bottom">
                <i class="bi bi-person-vcard text-success fs-3 me-2"></i>
                <h5 class="fw-bold text-dark mb-0">New Personnel Profile Registration</h5>
            </div>

            <form asp-action="Create" method="post" autocomplete="off">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <h6 class="fw-bold text-secondary mb-3"><i class="bi bi-file-earmark-person me-1"></i> Core HR Credentials</h6>
                <div class="row g-3 mb-4">
                    <div class="col-12">
                        <label asp-for="Employee.FullName" class="form-label fw-semibold text-muted small">Full Legal Name</label>
                        <input asp-for="Employee.FullName" class="form-control rounded-3" placeholder="e.g., Alexander Wright" />
                        <span asp-validation-for="Employee.FullName" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Employee.Email" class="form-label fw-semibold text-muted small">Corporate Email Address</label>
                        <input asp-for="Employee.Email" type="email" class="form-control rounded-3" placeholder="username@company.com" />
                        <span asp-validation-for="Employee.Email" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Employee.Salary" class="form-label fw-semibold text-muted small">Base Salary Rate</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0 text-muted small">$</span>
                            <input asp-for="Employee.Salary" type="number" step="0.01" class="form-control rounded-3 border-start-0" placeholder="0.00" />
                        </div>
                        <span asp-validation-for="Employee.Salary" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Employee.HireDate" class="form-label fw-semibold text-muted small">Hire Effective Date</label>
                        <input asp-for="Employee.HireDate" type="date" class="form-control rounded-3" />
                        <span asp-validation-for="Employee.HireDate" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Employee.DepartmentId" class="form-label fw-semibold text-muted small">Department Assignment</label>
                        <select asp-for="Employee.DepartmentId" asp-items="Model.DepartmentList" class="form-select rounded-3">
                            <option value="">-- Select Organizational Unit --</option>
                        </select>
                        <span asp-validation-for="Employee.DepartmentId" class="text-danger small"></span>
                    </div>
                </div>

                <div class="p-3 bg-light rounded-3 mb-4 border">
                    <div class="form-check form-switch mb-0">
                        <input asp-for="CreateUserAccount" class="form-check-input" type="checkbox" role="switch" id="toggleUserAccount">
                        <label asp-for="CreateUserAccount" class="form-check-label fw-bold text-dark small">Create Associated Security Account</label>
                    </div>
                    <small class="text-muted d-block mt-1">Enabling this generates a corresponding application user identity profile immediately.</small>
                </div>

                <div id="securityFieldsSection" style="display: none;">
                    <h6 class="fw-bold text-primary mb-3"><i class="bi bi-shield-lock me-1"></i> Identity Configurations</h6>
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label asp-for="Password" class="form-label fw-semibold text-muted small">System Access Password</label>
                            <input asp-for="Password" type="password" class="form-control rounded-3" placeholder="••••••••" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Role" class="form-label fw-semibold text-muted small">Access Authorization Role</label>
                            <select asp-for="Role" class="form-select rounded-3">
                                <option value="">-- Select Security Role --</option>
                                <option value="Admin">Admin (Full Overlord Control)</option>
                                <option value="Manager">Manager (Department Supervisor)</option>
                                <option value="Employee">Employee (Limited Standard Access)</option>
                            </select>
                            <span asp-validation-for="Role" class="text-danger small"></span>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-2 border-top pt-3">
                    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Cancel</a>
                    <button type="submit" class="btn btn-success rounded-pill px-4">
                        <i class="bi bi-check-lg me-1"></i> Integrate Employee
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="~/Views/Shared/Infrastructure/_ValidationScriptsPartial.cshtml" />
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const toggleSwitch = document.getElementById("toggleUserAccount");
            const securitySection = document.getElementById("securityFieldsSection");
            function handleToggle() {
                securitySection.style.display = toggleSwitch.checked ? "block" : "none";
            }
            toggleSwitch.addEventListener("change", handleToggle);
            handleToggle();
        });
    </script>
}