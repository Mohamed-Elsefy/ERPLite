@model ERPLite.Web.Models.Employees.EmployeeDetailsViewModel
@{
    ViewData["Title"] = "Employee Strategic Profile";
}

<div class="container-fluid p-0">
    <div class="mb-3">
        <a asp-action="Index" class="btn btn-sm btn-link text-secondary text-decoration-none p-0">
            <i class="bi bi-arrow-left me-1"></i> Return to Master Ledger
        </a>
    </div>

    <div class="row g-4">
        <div class="col-12 col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 bg-white text-center p-4">
                <div class="mx-auto bg-light border rounded-circle d-flex align-items-center justify-content-center mb-3" style="width: 90px; height: 90px; border-color: #cbd5e1 !important;">
                    <i class="bi bi-person-badge text-secondary display-6"></i>
                </div>
                <h5 class="fw-bold text-dark mb-1">@Model.FullName</h5>
                <p class="text-muted small font-monospace mb-3">ID: #@Model.EmployeeId.ToString("D4")</p>

                <div class="py-2 border-top border-bottom border-light mb-3">
                    <span class="badge rounded-pill bg-light text-dark border px-3 py-1.5 small" style="border-color: #cbd5e1 !important;">
                        <i class="bi bi-building text-muted me-1"></i>@Model.DepartmentName
                    </span>
                </div>

                <div class="mb-4 bg-light bg-opacity-50 p-2.5 rounded-3 border" style="border-color: #f1f5f9 !important;">
                    <span class="text-uppercase text-muted fw-bold d-block mb-1 font-monospace" style="font-size: 0.6rem; letter-spacing: 0.05em;">Base Salary Structure</span>
                    <h5 class="fw-bold text-success font-monospace mb-0">@Model.Salary.ToString("C2")</h5>
                </div>

                <div class="text-start small">
                    <span class="text-uppercase text-muted fw-bold d-block mb-1 font-monospace" style="font-size: 0.6rem;">System Account Token</span>
                    @if (Model.HasSystemAccount)
                    {
                        <div class="p-3 rounded-3 bg-success-subtle text-success border border-success-subtle font-monospace">
                            <div class="d-flex align-items-center mb-2">
                                <i class="bi bi-shield-check-fill me-2 fs-5"></i>
                                <div>
                                    <strong class="d-block" style="font-size: 0.75rem;">Identity Linked</strong>
                                    <span class="opacity-75 d-block" style="font-size: 0.65rem;">Role: @Model.SystemRole</span>
                                </div>
                            </div>
                            <div class="pt-2 border-top border-success border-opacity-20 d-flex justify-content-between align-items-center">
                                <span style="font-size: 0.65rem;">Security Status:</span>
                                @if (Model.IsAccountLocked)
                                {
                                    <span class="badge bg-danger text-white rounded-pill px-2 py-0.5" style="font-size: 0.6rem;"><i class="bi bi-lock-fill me-1"></i>Locked</span>
                                }
                                else
                                {
                                    <span class="badge bg-success text-white rounded-pill px-2 py-0.5" style="font-size: 0.6rem;"><i class="bi bi-unlock-fill me-1"></i>Active</span>
                                }
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="p-2.5 rounded-3 bg-warning-subtle text-warning border border-warning-subtle font-monospace d-flex align-items-center">
                            <i class="bi bi-shield-exclamation-fill me-2 fs-5"></i>
                            <div>
                                <strong class="d-block" style="font-size: 0.75rem;">Isolated Profile</strong>
                                <span class="opacity-75" style="font-size: 0.65rem;">No system access keys binded.</span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-8">
            <div class="d-flex flex-column gap-4 h-100">

                <div class="card border-0 shadow-sm rounded-4 bg-white p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3 pb-2 border-bottom border-light">
                        <div>
                            <h6 class="fw-bold text-dark mb-0">Corporate Specification Fields</h6>
                            <p class="text-muted small mb-0" style="font-size: 0.7rem;">Audited operational record configurations.</p>
                        </div>
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="Edit" asp-route-id="@Model.EmployeeId" class="btn btn-sm btn-outline-secondary rounded-pill px-3 py-1 font-monospace" style="font-size: 0.75rem;">
                                <i class="bi bi-pencil me-1"></i> Pivot Parameters
                            </a>
                        }
                    </div>

                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            <span class="text-uppercase text-muted fw-bold d-block mb-1 font-monospace" style="font-size: 0.65rem; letter-spacing: 0.05em;">Primary Communication Identifier</span>
                            <div class="p-2 border rounded-3 bg-light bg-opacity-30 small text-dark font-monospace">
                                @Model.Email
                            </div>
                        </div>

                        <div class="col-12 col-md-6">
                            <span class="text-uppercase text-muted fw-bold d-block mb-1 font-monospace" style="font-size: 0.65rem; letter-spacing: 0.05em;">Hire Date & Lifecycle</span>
                            <div class="p-2 border rounded-3 bg-light bg-opacity-30 small text-dark font-monospace">
                                @Model.HireDate.ToString("MMMM dd, yyyy")
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card border-0 shadow-sm rounded-4 bg-white p-4 flex-grow-1">
                    <h6 class="fw-bold text-dark mb-3 small" style="font-size: 0.85rem;">
                        <i class="bi bi-calendar-check me-2 text-muted"></i>Operational Attendance Ledger Logs
                    </h6>

                    <div class="table-responsive" style="max-height: 280px; overflow-y: auto;">
                        <table class="table align-middle table-sm mb-0">
                            <thead class="table-light text-muted small fw-medium sticky-top" style="font-size: 0.7rem; z-index: 1;">
                                <tr>
                                    <th scope="col" class="ps-2 py-2">Log Date</th>
                                    <th scope="col" class="py-2">Check In</th>
                                    <th scope="col" class="py-2">Check Out</th>
                                    <th scope="col" class="text-end pe-2 py-2">Status Flag</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.AttendanceLogs == null || !Model.AttendanceLogs.Any())
                                {
                                    <tr>
                                        <td colspan="4" class="text-center text-muted py-4 small">
                                            <i class="bi bi-calendar-x me-1 opacity-50"></i>No telemetry log metrics recorded within this zone.
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    foreach (var log in Model.AttendanceLogs)
                                    {
                                        <tr style="border-color: #f8fafc !important; font-size: 0.75rem;">
                                            <td class="ps-2 py-2 font-monospace fw-medium text-dark">
                                                @log.Date.ToString("yyyy-MM-dd")
                                            </td>
                                            <td class="py-2 font-monospace text-secondary">
                                                @log.CheckInTime.ToString("hh:mm tt")
                                            </td>
                                            <td class="py-2 font-monospace text-secondary">
                                                @(log.CheckOutTime.HasValue ? log.CheckOutTime.Value.ToString("hh:mm tt") : "--:--")
                                            </td>
                                            <td class="text-end pe-2 py-2">
                                                @if (log.Status == "Present" || log.Status == "OnTime")
                                                {
                                                    <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill px-2 font-monospace" style="font-size: 0.6rem;">@log.Status</span>
                                                }
                                                else if (log.Status == "Absent")
                                                {
                                                    <span class="badge bg-danger-subtle text-danger border border-danger-subtle rounded-pill px-2 font-monospace" style="font-size: 0.6rem;">@log.Status</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-warning-subtle text-warning border border-warning-subtle rounded-pill px-2 font-monospace" style="font-size: 0.6rem;">@log.Status</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>