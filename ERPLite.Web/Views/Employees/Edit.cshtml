@model EditEmployeeViewModel

@{
    ViewData["Title"] = "Update Employee Records";
}

<div class="row justify-content-center">
    <div class="col-12 col-lg-8">
        <div class="card border-0 shadow-sm rounded-4 bg-white p-4">
            <div class="d-flex align-items-center mb-4 pb-3 border-bottom">
                <i class="bi bi-pencil-square text-primary fs-3 me-2"></i>
                <div>
                    <h5 class="fw-bold text-dark mb-0">Modify Employee Administrative File</h5>
                    <small class="text-muted">Updating financial profile and unit assignment information.</small>
                </div>
            </div>

            <form asp-action="Edit" method="post" autocomplete="off">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Employee.Id" />
                <input type="hidden" asp-for="Employee.UserId" />

                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <div class="row g-3 mb-4">
                    <div class="col-12">
                        <label asp-for="Employee.FullName" class="form-label fw-semibold text-muted small">Full Name</label>
                        <input asp-for="Employee.FullName" class="form-control rounded-3" />
                        <span asp-validation-for="Employee.FullName" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Employee.Email" class="form-label fw-semibold text-muted small">Corporate Email</label>
                        <input asp-for="Employee.Email" type="email" class="form-control rounded-3" />
                        <span asp-validation-for="Employee.Email" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Employee.Salary" class="form-label fw-semibold text-muted small">Base Monthly Salary Rate</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0 text-muted small">$</span>
                            <input asp-for="Employee.Salary" type="number" step="0.01" class="form-control rounded-3 border-start-0" />
                        </div>
                        <span asp-validation-for="Employee.Salary" class="text-danger small"></span>
                    </div>

                    <div class="col-md-12">
                        <label asp-for="Employee.DepartmentId" class="form-label fw-semibold text-muted small">Department Allocation</label>
                        <select asp-for="Employee.DepartmentId" asp-items="Model.DepartmentList" class="form-select rounded-3"></select>
                        <span asp-validation-for="Employee.DepartmentId" class="text-danger small"></span>
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-2 border-top pt-3">
                    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Cancel</a>
                    <button type="submit" class="btn btn-primary rounded-pill px-4">
                        <i class="bi bi-save me-1"></i> Save Employee Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="~/Views/Shared/Infrastructure/_ValidationScriptsPartial.cshtml" />
}