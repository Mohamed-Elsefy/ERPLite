@model ERPLite.Web.Models.Employees.EditEmployeeViewModel
@{
    ViewData["Title"] = "Modify System Parameters";
}

<div class="card border-0 shadow-sm rounded-4 bg-white p-4 p-sm-5">
    <div class="d-flex align-items-center mb-4 pb-3 border-bottom border-light">
        <div class="bg-light border rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 45px; height: 45px; border-color: #e2e8f0 !important;">
            <i class="bi bi-pencil-square text-secondary fs-5"></i>
        </div>
        <div>
            <h5 class="fw-bold text-dark mb-0">Modify Employee Parameter Node</h5>
            <p class="text-muted small mb-0" style="font-size: 0.75rem;">Adjust demographic data structures and corporate zone re-allocations.</p>
        </div>
    </div>

    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="text-danger small mb-4 font-monospace"></div>

        <input type="hidden" asp-for="Employee.Id" />
        <input type="hidden" asp-for="Employee.UserId" />

        <div class="row g-3 mb-4">
            <div class="col-12 col-md-6">
                <label asp-for="Employee.FullName" class="form-label text-muted small text-uppercase mb-1 font-monospace" style="font-size: 0.65rem; letter-spacing: 0.05em;">Full Name</label>
                <input asp-for="Employee.FullName" class="form-control border rounded-3 bg-white py-2 shadow-none small" style="font-size: 0.85rem;" />
                <span asp-validation-for="Employee.FullName" class="text-danger small mt-1 d-block font-monospace" style="font-size: 0.7rem;"></span>
            </div>

            <div class="col-12 col-md-6">
                <label asp-for="Employee.Email" class="form-label text-muted small text-uppercase mb-1 font-monospace" style="font-size: 0.65rem; letter-spacing: 0.05em;">Email Address</label>
                <input asp-for="Employee.Email" type="email" class="form-control border rounded-3 bg-white py-2 shadow-none small" style="font-size: 0.85rem;" />
                <span asp-validation-for="Employee.Email" class="text-danger small mt-1 d-block font-monospace" style="font-size: 0.7rem;"></span>
            </div>

            <div class="col-12 col-md-6">
                <label asp-for="Employee.Salary" class="form-label text-muted small text-uppercase mb-1 font-monospace" style="font-size: 0.65rem; letter-spacing: 0.05em;">Base Salary Structure ($)</label>
                <input asp-for="Employee.Salary" type="number" step="0.01" class="form-control border rounded-3 bg-white py-2 shadow-none small font-monospace" style="font-size: 0.85rem;" />
                <span asp-validation-for="Employee.Salary" class="text-danger small mt-1 d-block font-monospace" style="font-size: 0.7rem;"></span>
            </div>

            <div class="col-12 col-md-6">
                <label asp-for="Employee.DepartmentId" class="form-label text-muted small text-uppercase mb-1 font-monospace" style="font-size: 0.65rem; letter-spacing: 0.05em;">Corporate Department Node</label>
                <select asp-for="Employee.DepartmentId" asp-items="Model.DepartmentList" class="form-select border rounded-3 bg-white py-2 shadow-none small" style="font-size: 0.85rem;">
                    <option value="">-- Reallocate Department Boundary --</option>
                </select>
                <span asp-validation-for="Employee.DepartmentId" class="text-danger small mt-1 d-block font-monospace" style="font-size: 0.7rem;"></span>
            </div>
        </div>

        <div class="d-flex justify-content-end align-items-center border-top pt-4 border-light gap-2">
            <a asp-action="Index" class="btn btn-light border rounded-pill px-4 fw-medium small text-secondary" style="font-size: 0.8rem;">Dismiss Changes</a>
            <button type="submit" class="btn btn-dark rounded-pill px-4 fw-medium shadow-sm" style="background-color: #475569; font-size: 0.8rem;">
                <i class="bi bi-save-fill me-1"></i> Update Parameter Records
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="~/Views/Shared/Infrastructure/_ValidationScriptsPartial.cshtml" />
}