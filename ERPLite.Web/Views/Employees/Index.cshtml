@model IEnumerable<EmployeeDto>

@{
    ViewData["Title"] = User.IsInRole(Roles.Admin) ? "HR Personnel Directory" : "Departmental Workforce Directory";
}

<div class="card border-0 shadow-sm rounded-4 bg-white p-4 mb-4">
    <div class="d-flex justify-content-between align-items-center @(User.IsInRole(Roles.Admin) ? "mb-4 pb-3 border-bottom" : "")">
        <div>
            <h4 class="fw-bold text-dark mb-1">
                <i class="bi bi-people-fill @(User.IsInRole(Roles.Admin) ? "text-success" : "text-primary") me-2"></i>
                @(User.IsInRole(Roles.Admin) ? "Personnel Management" : "My Team Directory")
            </h4>
            <p class="text-muted small mb-0">
                @(User.IsInRole(Roles.Admin)
                    ? "Manage corporate human resources, organizational departments, and staff structure metrics."
                    : "Monitor human capital allocation and baseline parameters for your assigned department.")
            </p>
        </div>
        @if (User.IsInRole(Roles.Admin))
        {
            <a asp-action="Create" class="btn btn-success rounded-pill px-4 fw-semibold shadow-sm">
                <i class="bi bi-person-plus me-1"></i> Register Employee
            </a>
        }
    </div>

    @if (User.IsInRole(Roles.Admin))
    {
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show border-0 rounded-3" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
    }

    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light text-secondary small fw-bold">
                <tr>
                    <th scope="col" class="ps-3">Employee Details</th>
                    @if (User.IsInRole(Roles.Admin))
                    {
                        <th scope="col">Department Unit</th>
                        <th scope="col">Financial Rate</th>
                        <th scope="col">System Access Status</th>
                    }
                    else
                    {
                        <th scope="col">Email Address</th>
                        <th scope="col">Department</th>
                    }
                    <th scope="col" class="text-end pe-3">@(User.IsInRole(Roles.Admin) ? "Actions Mapping" : "Actions")</th>
                </tr>
            </thead>
            <tbody>
                @if (Model == null || !Model.Any())
                {
                    <tr>
                        <td colspan="@(User.IsInRole(Roles.Admin) ? 5 : 4)" class="text-center text-muted py-5">
                            <i class="bi bi-folder-x fs-1 d-block mb-2 text-secondary"></i>
                            @(User.IsInRole(Roles.Admin) ? "No registered personnel found." : "No personnel currently assigned to your team domain.")
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var emp in Model)
                    {
                        <tr>
                            <td class="ps-3">
                                <div class="d-flex align-items-center">
                                    <div class="avatar-circle @(User.IsInRole(Roles.Admin) ? "bg-light text-success" : "bg-primary-subtle text-primary") fw-bold me-3 rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                        @emp.FullName.Substring(0, Math.Min(2, emp.FullName.Length)).ToUpper()
                                    </div>
                                    <div>
                                        <h6 class="fw-bold mb-0 text-dark">@emp.FullName</h6>
                                        @if (User.IsInRole(Roles.Admin))
                                        {
                                            <small class="text-muted">@emp.Email</small>
                                        }
                                    </div>
                                </div>
                            </td>

                            @if (User.IsInRole(Roles.Admin))
                            {
                                <td>
                                    <span class="badge bg-light text-primary border border-primary-subtle rounded-pill px-3 py-2 fw-semibold">
                                        <i class="bi bi-building me-1"></i>@emp.DepartmentName
                                    </span>
                                </td>
                                <td class="fw-bold text-dark">
                                    $@emp.Salary.ToString("N2")
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(emp.UserId))
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill px-3 py-2">
                                            <i class="bi bi-shield-check me-1"></i>Active System Account
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle rounded-pill px-3 py-2">
                                            <i class="bi bi-person me-1"></i>HR Record Only
                                        </span>
                                    }
                                </td>
                            }
                            else
                            {
                                <td class="text-muted small">@emp.Email</td>
                                <td>
                                    <span class="badge bg-primary-subtle text-primary border border-primary-subtle rounded-pill px-2.5 py-1 small fw-semibold">
                                        @emp.DepartmentName
                                    </span>
                                </td>
                            }

                            <td class="text-end pe-3">
                                <div class="d-inline-flex gap-1 align-items-center">
                                    @if (User.IsInRole(Roles.Admin))
                                    {
                                        <a asp-action="Details" asp-route-id="@emp.Id" class="btn btn-sm btn-light border rounded-circle d-flex align-items-center justify-content-center" style="width:32px; height:32px; padding:0;" title="View Comprehensive File">
                                            <i class="bi bi-eye-fill text-muted"></i>
                                        </a>

                                        <a asp-action="Edit" asp-route-id="@emp.Id" class="btn btn-sm btn-light border rounded-circle d-flex align-items-center justify-content-center" style="width:32px; height:32px; padding:0;" title="Modify Details">
                                            <i class="bi bi-pencil-fill text-muted"></i>
                                        </a>

                                        <form asp-action="Delete" asp-route-id="@emp.Id" method="post" onsubmit="return confirm('Warning! Permanently deleting this employee will also destroy any matched security credentials. Continue?');" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-light border rounded-circle d-flex align-items-center justify-content-center" style="width:32px; height:32px; padding:0;" title="Purge Record">
                                                <i class="bi bi-trash3-fill text-danger"></i>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <a asp-action="Details" asp-route-id="@emp.Id" class="btn btn-sm btn-light border rounded-pill px-3 fw-semibold small shadow-sm">
                                            <i class="bi bi-eye-fill me-1 text-primary"></i> View Profile
                                        </a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>