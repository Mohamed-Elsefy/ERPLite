@model ERPLite.Web.Models.Products.ProductIndexViewModel
@{
    var isAdmin = User.IsInRole("Admin");
    ViewData["Title"] = "Master Inventory Ledger";
}

<div class="card border-0 shadow-sm rounded-4 bg-white p-4">
    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center mb-4 pb-3 border-bottom border-light gap-3">
        <div>
            <h5 class="fw-bold text-dark mb-1">
                <i class="bi bi-box-seam text-secondary me-2"></i>Master Inventory Ledger
            </h5>
            <p class="text-muted small mb-0" style="font-size: 0.75rem;">
                Track, audit, and evaluate Stock Keeping Units (SKUs) across categorical and vendor pipelines.
            </p>
        </div>
        @if (isAdmin)
        {
            <a asp-action="Create" class="btn btn-sm btn-dark rounded-pill px-4 fw-medium font-monospace" style="background-color: #475569; font-size: 0.8rem;">
                <i class="bi bi-plus-circle-fill me-1"></i> Catalog New Item
            </a>
        }
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 rounded-3 small mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 small mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form asp-action="Index" method="get" class="row g-2 mb-4">
        <div class="col-12 col-md-6 col-lg-4">
            <div class="input-group border rounded-3" style="border-color: #cbd5e1 !important;">
                <span class="input-group-text bg-light border-0 text-muted px-3"><i class="bi bi-search small"></i></span>
                <input type="text" name="search" value="@Model.SearchTerm" class="form-control border-0 bg-white py-2 small shadow-none" placeholder="Filter by SKU, Category, or Supplier..." />
            </div>
        </div>
        <div class="col-auto d-flex align-items-center gap-2">
            <button type="submit" class="btn btn-light border fw-medium rounded-3 px-3 py-2 small text-secondary" style="font-size: 0.8rem; border-color: #cbd5e1 !important;">Filter</button>
            @if (!string.IsNullOrWhiteSpace(Model.SearchTerm))
            {
                <a asp-action="Index" class="btn btn-link text-decoration-none text-muted small px-1">Clear</a>
            }
        </div>
    </form>

    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light text-secondary small fw-medium" style="font-size: 0.75rem;">
                <tr>
                    <th scope="col" class="ps-3 py-3 text-uppercase tracking-wider">SKU Core Information</th>
                    <th scope="col" class="py-3 text-uppercase tracking-wider">Classification Node</th>
                    <th scope="col" class="py-3 text-uppercase tracking-wider">Approved Supplier</th>
                    <th scope="col" class="py-3 text-uppercase tracking-wider">Procurement Rate</th>
                    <th scope="col" class="py-3 text-uppercase tracking-wider">Stock Volume</th>
                    <th scope="col" class="text-end pe-3 py-3 text-uppercase tracking-wider">Asset Routing</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Products == null || !Model.Products.Any())
                {
                    <tr>
                        <td colspan="@(isAdmin ? 6 : 5)" class="text-center text-muted py-5">
                            <i class="bi bi-box-arrow-in-down fs-2 d-block mb-2 opacity-30"></i>No stock keeping units indexed inside the repository.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model.Products)
                    {
                        var isLowStock = item.QuantityInStock <= item.MinStockLevel;
                        <tr style="border-color: #f1f5f9 !important;">
                            <td class="ps-3 py-3">
                                <div>
                                    <h6 class="fw-bold mb-0 text-dark small" style="font-size: 0.85rem;">@item.Name</h6>
                                    <small class="text-muted font-monospace" style="font-size: 0.7rem;">SKU-ID: #@item.Id.ToString("D5")</small>
                                </div>
                            </td>
                            <td class="py-3 small text-secondary">
                                <span class="badge rounded-pill bg-light text-secondary border px-2.5 py-1" style="font-size: 0.7rem; border-color: #e2e8f0 !important;">
                                    @item.CategoryName
                                </span>
                            </td>
                            <td class="py-3 small text-muted">
                                <i class="bi bi-truck me-1.5 opacity-50"></i>@item.SupplierName
                            </td>
                            <td class="py-3 font-monospace text-dark fw-medium small" style="font-size: 0.8rem;">
                                $@item.Price.ToString("N2")
                            </td>
                            <td class="py-3">
                                <div class="d-flex align-items-center gap-2">
                                    <span class="badge rounded-pill px-2.5 py-1 font-monospace fw-medium @(isLowStock ? "bg-danger-subtle text-danger border border-danger-subtle" : "bg-success-subtle text-success border border-success-subtle")" style="font-size: 0.7rem;">
                                        @item.QuantityInStock Units
                                    </span>
                                    @if (isLowStock)
                                    {
                                        <i class="bi bi-exclamation-triangle-fill text-danger small" title="Critical Buffer Limit Breach! Minimum safety level: @item.MinStockLevel"></i>
                                    }
                                </div>
                            </td>
                            <td class="text-end pe-3 py-3">
                                <div class="d-inline-flex gap-2 align-items-center">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-light border rounded-circle d-flex align-items-center justify-content-center" style="width:32px; height:32px; padding:0; border-color: #cbd5e1 !important;" title="Audit SKU Details">
                                        <i class="bi bi-eye text-secondary" style="font-size: 0.85rem;"></i>
                                    </a>

                                    @if (isAdmin)
                                    {
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-light border rounded-circle d-flex align-items-center justify-content-center" style="width:32px; height:32px; padding:0; border-color: #cbd5e1 !important;" title="Modify Parameters">
                                            <i class="bi bi-pencil text-secondary" style="font-size: 0.85rem;"></i>
                                        </a>

                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Ledger Balance Check: Confirm permanent deletion of this product stock keeping file?');" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-light border rounded-circle d-flex align-items-center justify-content-center" style="width:32px; height:32px; padding:0; border-color: #cbd5e1 !important;" title="Purge Record">
                                                <i class="bi bi-trash3 text-danger" style="font-size: 0.85rem;"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>