@model ERPLite.Web.Models.Departments.DepartmentDetailsViewModel
@{
    var isAdmin = User.IsInRole("Admin");
    ViewData["Title"] = $"Department Details - {Model.Name}";
}

<div class="d-flex justify-content-between align-items-center mb-4 pb-2">
    <div>
        <h5 class="fw-bold text-dark mb-1"><i class="bi bi-building text-secondary me-2"></i>Department Profiles</h5>
        <p class="text-muted small mb-0" style="font-size: 0.75rem;">Overview of operational metadata synchronized with active staff allocations.</p>
    </div>
    <div>
        <a asp-action="Index" class="btn btn-sm btn-light border font-monospace text-dark px-3 py-2" style="font-size: 0.75rem; border-color: #cbd5e1 !important;">
            <i class="bi bi-arrow-left me-1"></i> Back to Directory
        </a>
    </div>
</div>

<div class="row g-4">
    <div class="col-12 col-md-5 col-lg-4">
        <div class="card border-0 shadow-sm bg-white p-4 rounded-4 h-100 d-flex flex-column">
            <div class="d-flex align-items-center pb-3 border-bottom mb-4" style="border-color: #f1f5f9 !important;">
                <div class="d-flex align-items-center justify-content-center border rounded-circle fw-semibold text-secondary font-monospace me-3"
                     style="width: 48px; height: 48px; background-color: #f8fafc; border-color: #e2e8f0 !important; font-size: 0.85rem;">
                    @Model.Name.Substring(0, Math.Min(2, Model.Name.Length)).ToUpper()
                </div>
                <div>
                    <h6 class="fw-bold text-dark mb-0 small" style="font-size: 0.9rem;">@Model.Name</h6>
                    <span class="badge bg-light text-secondary border font-monospace mt-1" style="font-size: 0.65rem; border-color: #e2e8f0 !important;">
                        CODE: #@Model.DepartmentId.ToString("D3")
                    </span>
                </div>
            </div>

            <h6 class="text-muted mb-3 small text-uppercase fw-bold tracking-wider" style="font-size: 0.65rem;">Unit Blueprint</h6>

            <div class="mb-4">
                <label class="text-secondary small d-block mb-1" style="font-size: 0.7rem;">Functional Description</label>
                <div class="p-3 border rounded-3 text-secondary bg-light font-monospace" style="white-space: pre-line; font-size: 0.75rem; border-color: #e2e8f0 !important;">
                    @(string.IsNullOrWhiteSpace(Model.Description) ? "No operational description documented for this unit." : Model.Description)
                </div>
            </div>

            <div class="mb-4 p-3 rounded-3 border mt-auto" style="background-color: #f8fafc; border-color: #e2e8f0 !important;">
                <label class="text-secondary small d-block mb-1 fw-bold text-uppercase" style="font-size: 0.65rem;">Human Resource Allocations</label>
                <div class="d-flex align-items-baseline">
                    <span class="fs-3 fw-bold font-monospace text-dark">@Model.EmployeesCount</span>
                    <span class="text-muted small ms-2" style="font-size: 0.75rem;">/ Active Staff Profiles</span>
                </div>
            </div>

            @if (isAdmin)
            {
                <div class="pt-3 border-top" style="border-color: #f1f5f9 !important;">
                    <a asp-action="Edit" asp-route-id="@Model.DepartmentId" class="btn btn-sm btn-light border font-monospace text-dark w-100 py-2" style="font-size: 0.75rem; border-color: #cbd5e1 !important;">
                        <i class="bi bi-pencil small text-muted me-1"></i>Edit Parameters
                    </a>
                </div>
            }
        </div>
    </div>

    <div class="col-12 col-md-7 col-lg-8">
        <div class="card border-0 shadow-sm bg-white p-4 rounded-4 h-100">
            <div class="d-flex align-items-center pb-3 border-bottom mb-4" style="border-color: #f1f5f9 !important;">
                <div class="p-2 rounded-3 me-3 text-secondary border bg-light">
                    <i class="bi bi-people fs-5"></i>
                </div>
                <div>
                    <h6 class="fw-bold text-dark mb-0" style="font-size: 0.95rem;">Assigned Personnel Roster</h6>
                    <small class="text-muted" style="font-size: 0.75rem;">Real-time workforce deployment metrics for this branch.</small>
                </div>
            </div>

            <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-muted small fw-medium sticky-top" style="background-color: #f8fafc; font-size: 0.75rem;">
                        <tr>
                            <th scope="col" class="ps-2 border-0 py-2.5">Employee Details</th>
                            @if (isAdmin)
                            {
                                <th scope="col" class="border-0 py-2.5">Financial Base</th>
                            }
                            <th scope="col" class="text-end pe-2 border-0 py-2.5">File Log</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Employees != null && Model.Employees.Any())
                        {
                            foreach (var emp in Model.Employees)
                            {
                                <tr style="border-color: #f8fafc;">
                                    <td class="ps-2 py-2.5">
                                        <div class="d-flex align-items-center">
                                            <div class="d-flex align-items-center justify-content-center border rounded-circle font-monospace text-muted small me-2.5 bg-light"
                                                 style="width: 34px; height: 34px; font-size: 0.7rem;">
                                                @emp.FullName.Substring(0, Math.Min(2, emp.FullName.Length)).ToUpper()
                                            </div>
                                            <div>
                                                <h6 class="fw-medium mb-0 text-dark small" style="font-size: 0.8rem;">@emp.FullName</h6>
                                                <small class="text-muted font-monospace" style="font-size: 0.7rem;">@emp.Email</small>
                                            </div>
                                        </div>
                                    </td>
                                    @if (isAdmin)
                                    {
                                        <td>
                                            <span class="badge rounded-pill px-2 py-1 font-monospace fw-medium" style="font-size: 0.7rem; background-color: #f0fdf4; color: #16a34a; border: 1px solid #bbf7d0;">
                                                $@emp.Salary.ToString("N2")
                                            </span>
                                        </td>
                                    }
                                    <td class="text-end pe-2">
                                        <a asp-controller="Employees" asp-action="Details" asp-route-id="@emp.Id" class="btn btn-sm btn-light border d-flex align-items-center justify-content-center ms-auto" style="width:28px; height:28px; padding:0; border-color: #cbd5e1 !important;" title="View File">
                                            <i class="bi bi-chevron-right text-secondary" style="font-size: 0.75rem;"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="@(isAdmin ? 3 : 2)" class="text-center text-muted py-5" style="background-color: #ffffff;">
                                    <i class="bi bi-person-dash d-block fs-3 mb-2 text-muted opacity-40"></i>This structural unit is currently vacant.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>