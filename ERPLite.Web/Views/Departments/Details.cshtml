@model DepartmentDetailsViewModel

@{
    ViewData["Title"] = $"Department Details - {Model.Name}";
}

<div class="row justify-content-center">
    <div class="col-12 col-xl-11">

        <div class="d-flex justify-content-between align-items-center mb-4 pb-2">
            <div>
                <h4 class="fw-bold text-dark mb-1"><i class="bi bi-building text-primary me-2"></i>Department Hub Profiles</h4>
                <p class="text-muted small mb-0">Overview of operational department metadata synchronized with active staff allocations.</p>
            </div>
            @if (User.IsInRole(Roles.Admin))
            {
                <a asp-action="Index" class="btn btn-light border rounded-pill px-4 fw-semibold small shadow-sm">
                    <i class="bi bi-arrow-left me-1"></i> Back to Architecture
                </a>
            }
        </div>

        <div class="row g-4">
            <div class="col-12 col-md-5">
                <div class="card border-0 shadow-sm rounded-4 bg-white p-4 h-100 d-flex flex-column">
                    <div class="d-flex align-items-center pb-3 border-bottom mb-4">
                        <div class="avatar-circle bg-light text-primary fw-bold rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 55px; height: 55px;">
                            @Model.Name.Substring(0, Math.Min(2, Model.Name.Length)).ToUpper()
                        </div>
                        <div>
                            <h5 class="fw-bold text-dark mb-1">@Model.Name</h5>
                            <span class="badge bg-light text-secondary border rounded-pill px-3 font-monospace small">
                                DEPT-CODE: #@Model.DepartmentId.ToString("D3")
                            </span>
                        </div>
                    </div>

                    <h6 class="fw-bold text-secondary mb-3 small text-uppercase tracking-wider">Business Unit Metadata</h6>

                    <div class="mb-4">
                        <label class="text-muted small d-block mb-1">Functional Description</label>
                        <div class="p-3 bg-light rounded-3 border text-secondary small" style="white-space: pre-line;">
                            @(string.IsNullOrWhiteSpace(Model.Description) ? "No operational description documented for this unit." : Model.Description)
                        </div>
                    </div>

                    <div class="mb-4 p-3 bg-primary-subtle border border-primary-subtle rounded-3">
                        <label class="text-primary-emphasis small d-block mb-1 fw-bold text-uppercase">Human Resource Density</label>
                        <div class="d-flex align-items-baseline">
                            <span class="fs-2 fw-bold text-primary">@Model.EmployeesCount</span>
                            <span class="text-muted small ms-2">/ Assigned Active Staff Members</span>
                        </div>
                    </div>

                    @if (User.IsInRole(Roles.Admin))
                    {
                        <div class="d-flex gap-2 mt-auto pt-3 border-top">
                            <a asp-action="Edit" asp-route-id="@Model.DepartmentId" class="btn btn-sm btn-outline-secondary rounded-pill px-4 fw-semibold" title="Modify Unit Metadata">
                                <i class="bi bi-pencil-fill me-1" style="font-size: 0.75rem;"></i>Edit Unit
                            </a>
                        </div>
                    }
                </div>
            </div>

            <div class="col-12 col-md-7">
                <div class="card border-0 shadow-sm rounded-4 bg-white p-4 h-100 d-flex flex-column">
                    <div class="d-flex align-items-center pb-3 border-bottom mb-4">
                        <div class="avatar-circle bg-light text-success fw-bold me-3 rounded-circle d-flex align-items-center justify-content-center" style="width: 45px; height: 45px;">
                            <i class="bi bi-people-fill text-success fs-5"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold text-dark mb-0">Assigned Personnel Roster</h5>
                            <small class="text-muted">Real-time list of human resources allocated to this branch.</small>
                        </div>
                    </div>

                    <div class="table-responsive my-auto" style="max-height: 380px; overflow-y: auto;">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light text-secondary small fw-bold sticky-top">
                                <tr>
                                    <th scope="col" class="ps-2">Employee Details</th>
                                    @if (User.IsInRole(Roles.Admin))
                                    {
                                        <th scope="col">Financial Rate</th>
                                    }
                                    <th scope="col" class="text-end pe-2">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Employees != null && Model.Employees.Any())
                                {
                                    foreach (var emp in Model.Employees)
                                    {
                                        <tr>
                                            <td class="ps-2">
                                                <div class="d-flex align-items-center">
                                                    <div class="avatar-circle bg-light text-primary fw-bold me-3 rounded-circle d-flex align-items-center justify-content-center small" style="width: 40px; height: 40px;">
                                                        @emp.FullName.Substring(0, Math.Min(2, emp.FullName.Length)).ToUpper()
                                                    </div>
                                                    <div>
                                                        <h6 class="fw-bold mb-0 text-dark small">@emp.FullName</h6>
                                                        <small class="text-muted" style="font-size: 0.75rem;">@emp.Email</small>
                                                    </div>
                                                </div>
                                            </td>
                                            @if (User.IsInRole(Roles.Admin))
                                            {
                                                <td>
                                                    <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill px-3 py-2 fw-bold small">
                                                        $@emp.Salary.ToString("N2")
                                                    </span>
                                                </td>
                                            }
                                            <td class="text-end pe-2">
                                                <a asp-controller="Employees" asp-action="Details" asp-route-id="@emp.Id" class="btn btn-sm btn-light border rounded-pill px-3 fw-semibold small shadow-sm d-inline-flex align-items-center" title="View Integrated Profile">
                                                    <i class="bi bi-eye-fill text-muted me-1"></i> Profile
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="@(User.IsInRole(Roles.Admin) ? 3 : 2)" class="text-center text-muted py-5 small">
                                            <i class="bi bi-person-dash d-block fs-2 mb-2 text-secondary"></i>This organizational department is currently vacant.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>