@{
    ViewData["Title"] = "Executive Reports Hub";
    var isAdmin = User.IsInRole("Admin");
}

<div class="row mb-4">
    <div class="col-12">
        <div class="d-flex align-items-center justify-content-between bg-white p-3 rounded-3 shadow-sm border-start border-primary border-4">
            <div>
                <h4 class="mb-1 fw-bold text-dark">
                    <i class="bi bi-file-earmark-bar-graph text-primary me-2"></i>Executive Reports Hub
                </h4>
                <p class="text-muted small mb-0">
                    Compile institutional assets, commercial ledger streams, and workforce metrics into structured legal PDF manifests.
                </p>
            </div>
            <span class="badge bg-light text-dark font-monospace border py-2 px-3">System Framework v1.0</span>
        </div>
    </div>
</div>

<div class="row g-4">

    <div class="col-12 col-md-6 col-xl-4">
        <div class="card h-100 border-0 shadow-sm rounded-3">
            <div class="card-body d-flex flex-column p-4">
                <div class="d-flex align-items-center mb-3">
                    <div class="bg-warning-subtle text-warning p-2.5 rounded-3 me-3">
                        <i class="bi bi-graph-up-arrow fs-4"></i>
                    </div>
                    <div>
                        <h5 class="card-title mb-0 fw-bold text-dark">Commercial Sales Ledger</h5>
                        <small class="text-muted">Orders, velocity and volume</small>
                    </div>
                </div>

                <p class="card-text text-secondary small flex-grow-1">
                    Generates timeline-bound transactional ledgers, tracking exact operational revenue pipelines and localized asset liquidation speeds.
                </p>

                <form asp-action="SalesPdf" method="get" target="_blank" class="mt-3 pt-3 border-top border-light">
                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <label class="form-label font-monospace text-muted small mb-1">From Date</label>
                            <input type="date" name="from" value="@DateTime.Today.AddDays(-30).ToString("yyyy-MM-dd")" class="form-control form-control-sm border-light-subtle shadow-none text-dark small" required />
                        </div>
                        <div class="col-6">
                            <label class="form-label font-monospace text-muted small mb-1">To Date</label>
                            <input type="date" name="to" value="@DateTime.Today.ToString("yyyy-MM-dd")" class="form-control form-control-sm border-light-subtle shadow-none text-dark small" required />
                        </div>
                    </div>
                    <button type="submit" class="btn btn-sm btn-outline-warning w-100 fw-semibold d-flex align-items-center justify-content-center gap-2 rounded-pill">
                        <i class="bi bi-file-pdf"></i> Stream Sales Blueprint
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-6 col-xl-4">
        <div class="card h-100 border-0 shadow-sm rounded-3">
            <div class="card-body d-flex flex-column p-4">
                <div class="d-flex align-items-center mb-3">
                    <div class="bg-indigo-subtle text-indigo p-2.5 rounded-3 me-3">
                        <i class="bi bi-calendar2-check-fill fs-4 text-indigo"></i>
                    </div>
                    <div>
                        <h5 class="card-title mb-0 fw-bold text-dark">Workforce Attendance</h5>
                        <small class="text-muted">Punctuality and logging metrics</small>
                    </div>
                </div>

                <p class="card-text text-secondary small flex-grow-1">
                    Extracts cross-departmental operational shift telemetry logs, indexing late marks, legal absences, and node uptime ratios.
                </p>

                <form asp-action="AttendancePdf" method="get" target="_blank" class="mt-3 pt-3 border-top border-light">
                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <label class="form-label font-monospace text-muted small mb-1">From Date</label>
                            <input type="date" name="from" value="@DateTime.Today.AddDays(-7).ToString("yyyy-MM-dd")" class="form-control form-control-sm border-light-subtle shadow-none text-dark small" required />
                        </div>
                        <div class="col-6">
                            <label class="form-label font-monospace text-muted small mb-1">To Date</label>
                            <input type="date" name="to" value="@DateTime.Today.ToString("yyyy-MM-dd")" class="form-control form-control-sm border-light-subtle shadow-none text-dark small" required />
                        </div>
                    </div>
                    <button type="submit" class="btn btn-sm btn-outline-indigo w-100 fw-semibold d-flex align-items-center justify-content-center gap-2 rounded-pill">
                        <i class="bi bi-file-pdf"></i> Compile Shifts Vector
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-6 col-xl-4">
        <div class="card h-100 border-0 shadow-sm rounded-3">
            <div class="card-body d-flex flex-column p-4">
                <div class="d-flex align-items-center mb-3">
                    <div class="bg-success-subtle text-success p-2.5 rounded-3 me-3">
                        <i class="bi bi-box-seam-fill fs-4"></i>
                    </div>
                    <div>
                        <h5 class="card-title mb-0 fw-bold text-dark">Inventory Valuation</h5>
                        <small class="text-muted">Asset auditing & alert indices</small>
                    </div>
                </div>

                <p class="card-text text-secondary small flex-grow-1">
                    Triggers a global asset evaluation report, exposing current supply depletion warnings, critical low stock states, and monetary capital totals.
                </p>

                <div class="mt-auto pt-3 border-top border-light">
                    <a asp-action="InventoryPdf" target="_blank" class="btn btn-sm btn-outline-success w-100 fw-semibold d-flex align-items-center justify-content-center gap-2 rounded-pill">
                        <i class="bi bi-printer-fill"></i> Asset Status Statement
                    </a>
                </div>
            </div>
        </div>
    </div>

    @if (isAdmin)
    {
        <div class="col-12 col-md-6 col-xl-4">
            <div class="card h-100 border-0 shadow-sm rounded-3 bg-gradient border-start border-info border-3">
                <div class="card-body d-flex flex-column p-4">
                    <div class="d-flex align-items-center mb-3">
                        <div class="bg-info-subtle text-info p-2.5 rounded-3 me-3">
                            <i class="bi bi-person-lines-fill fs-4"></i>
                        </div>
                        <div>
                            <h5 class="card-title mb-0 fw-bold text-dark">Human Capital Index</h5>
                            <span class="badge bg-danger-subtle text-danger font-monospace text-uppercase custom-badge-size">Core Access Only</span>
                        </div>
                    </div>

                    <p class="card-text text-secondary small flex-grow-1">
                        Compiles institutional personnel infrastructure metrics, indexing total headcount, system structural nodes, and fiscal salary burn rates.
                    </p>

                    <div class="mt-auto pt-3 border-top border-light">
                        <a asp-action="EmployeesPdf" target="_blank" class="btn btn-sm btn-info text-dark w-100 fw-bold d-flex align-items-center justify-content-center gap-2 rounded-pill shadow-sm">
                            <i class="bi bi-lock-fill"></i> Export Internal Payroll PDF
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-4">
            <div class="card h-100 border-0 shadow-sm rounded-3 bg-gradient border-start border-danger border-3">
                <div class="card-body d-flex flex-column p-4">
                    <div class="d-flex align-items-center mb-3">
                        <div class="bg-danger-subtle text-danger p-2.5 rounded-3 me-3">
                            <i class="bi bi-cash-coin fs-4"></i>
                        </div>
                        <div>
                            <h5 class="card-title mb-0 fw-bold text-dark">Financial Statements</h5>
                            <span class="badge bg-danger-subtle text-danger font-monospace text-uppercase custom-badge-size">Core Access Only</span>
                        </div>
                    </div>

                    <p class="card-text text-secondary small flex-grow-1">
                        High-level financial overview capturing system revenue channels, real-time uncollected cash flows, and overall invoice status breakdown.
                    </p>

                    <div class="mt-auto pt-3 border-top border-light">
                        <a asp-action="FinancialPdf" target="_blank" class="btn btn-sm btn-danger w-100 fw-bold d-flex align-items-center justify-content-center gap-2 rounded-pill shadow-sm">
                            <i class="bi bi-shield-lock-fill"></i> Stream Revenue Statement
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }

</div>

<style>
    .custom-badge-size {
        font-size: 0.55rem;
        padding: 0.25em 0.5em;
    }

    .bg-indigo-subtle {
        background-color: rgba(102, 16, 242, 0.1) !important;
    }

    .text-indigo {
        color: #6610f2 !important;
    }

    .btn-outline-indigo {
        color: #6610f2;
        border-color: #6610f2;
    }

        .btn-outline-indigo:hover {
            background-color: #6610f2;
            color: #fff;
        }

    .card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .card:hover {
            transform: translateY(-3px);
            box-shadow: 0 .5rem 1.5rem rgba(0,0,0,.08) !important;
        }
</style>