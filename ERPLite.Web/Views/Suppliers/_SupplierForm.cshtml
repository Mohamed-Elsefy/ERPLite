@model SupplierFormViewModel

@if (Model.IsEditMode)
{
    <input type="hidden" asp-for="Id" />
}

<div class="mb-3">
    <label asp-for="Name" class="form-label fw-bold text-secondary small text-uppercase tracking-wider">Corporate Name</label>
    <div class="input-group">
        <span class="input-group-text bg-light border-end-0 text-muted rounded-start-3"><i class="bi bi-building"></i></span>
        <input asp-for="Name" class="form-control border-start-0 rounded-end-3" placeholder="e.g., Global Tech Logistics, Alpha Manufacturing" />
    </div>
    <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
</div>

<div class="mb-3">
    <label asp-for="Phone" class="form-label fw-bold text-secondary small text-uppercase tracking-wider">Contact Phone Hotline</label>
    <div class="input-group">
        <span class="input-group-text bg-light border-end-0 text-muted rounded-start-3"><i class="bi bi-telephone"></i></span>
        <input asp-for="Phone" class="form-control border-start-0 rounded-end-3" placeholder="e.g., +1 (555) 019-2834" />
    </div>
    <span asp-validation-for="Phone" class="text-danger small mt-1 d-block"></span>
</div>

<div class="mb-4">
    <label asp-for="Address" class="form-label fw-bold text-secondary small text-uppercase tracking-wider">Headquarters Address</label>
    <textarea asp-for="Address" class="form-control rounded-3" rows="3" placeholder="Document full regional logistics center or headquarter offices address..."></textarea>
    <span asp-validation-for="Address" class="text-danger small mt-1 d-block"></span>
</div>

<div class="d-flex justify-content-end gap-2 border-top pt-3">
    <a asp-action="Index" class="btn btn-light border rounded-pill px-4 fw-semibold small">Cancel</a>
    <button type="submit" class="btn @(Model.IsEditMode ? "btn-warning text-white" : "btn-primary") rounded-pill px-4 fw-semibold shadow-sm">
        <i class="bi bi-check-circle-fill me-1"></i> @(Model.IsEditMode ? "Commit Supplier" : "Register Vendor")
    </button>
</div>