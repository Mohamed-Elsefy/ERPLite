@model ERPLite.Web.ViewModels.Dashboard.DashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container-fluid py-4">
    <div class="row g-4 mb-4">
        <div class="col-12 col-sm-6 col-xl-4">
            @await Html.PartialAsync("~/Views/Shared/Components/StatisticCard/Default.cshtml", new { Title = "Total Revenue", Value = Model.TotalRevenue.ToString("C"), Icon = "fa-dollar-sign", ColorClass = "success", Trend = 5.2 })
        </div>
        <div class="col-12 col-sm-6 col-xl-4">
            @await Html.PartialAsync("~/Views/Shared/Components/StatisticCard/Default.cshtml", new { Title = "Total Orders", Value = Model.TotalOrders.ToString("N0"), Icon = "fa-shopping-cart", ColorClass = "primary", Trend = 12.5 })
        </div>
        <div class="col-12 col-sm-6 col-xl-4">
            @await Html.PartialAsync("~/Views/Shared/Components/StatisticCard/Default.cshtml", new { Title = "Total Customers", Value = Model.TotalCustomers.ToString("N0"), Icon = "fa-users", ColorClass = "info", Trend = 3.1 })
        </div>
        <div class="col-12 col-sm-6 col-xl-4">
            @await Html.PartialAsync("~/Views/Shared/Components/StatisticCard/Default.cshtml", new { Title = "Total Products", Value = Model.TotalProducts.ToString("N0"), Icon = "fa-boxes-stacked", ColorClass = "warning", Trend = -1.2 })
        </div>
        <div class="col-12 col-sm-6 col-xl-4">
            @await Html.PartialAsync("~/Views/Shared/Components/StatisticCard/Default.cshtml", new { Title = "Total Employees", Value = Model.TotalEmployees.ToString("N0"), Icon = "fa-user-tie", ColorClass = "secondary" })
        </div>
        <div class="col-12 col-sm-6 col-xl-4">
            @await Html.PartialAsync("~/Views/Shared/Components/StatisticCard/Default.cshtml", new { Title = "Low Stock Items", Value = Model.LowStockProducts.ToString("N0"), Icon = "fa-triangle-exclamation", ColorClass = "danger" })
        </div>
    </div>

    <div class="row g-4">
        <!-- Revenue Chart -->
        <div class="col-12 col-lg-8">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
                    <h6 class="fw-bold mb-0">Revenue Overview</h6>
                </div>
                <div class="card-body">
                    <canvas id="revenueChart" height="100"></canvas>
                </div>
            </div>
        </div>

        <!-- Recent Notifications -->
        <div class="col-12 col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 d-flex justify-content-between align-items-center">
                    <h6 class="fw-bold mb-0">Recent Activity</h6>
                    <a href="#" class="text-decoration-none small">View All</a>
                </div>
                <div class="card-body">
                    @await Html.PartialAsync("~/Views/Shared/Components/NotificationCard/Default.cshtml", new { Title = "New Order Placed", Priority = "High", CreatedDate = DateTime.Now.AddMinutes(-5), Message = "Order #1024 has been placed successfully." })
                    @await Html.PartialAsync("~/Views/Shared/Components/NotificationCard/Default.cshtml", new { Title = "Stock Alert", Priority = "Warning", CreatedDate = DateTime.Now.AddHours(-1), Message = "Product 'Laptop Pro' is running low on stock." })
                    @await Html.PartialAsync("~/Views/Shared/Components/NotificationCard/Default.cshtml", new { Title = "New Employee", Priority = "Info", CreatedDate = DateTime.Now.AddDays(-1), Message = "John Doe joined the IT department." })
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/dashboard/sales-chart.js"></script>
}
