@model CategoryDetailsViewModel

@{
    ViewData["Title"] = $"Category Profiles - {Model.Name}";
}

<div class="row justify-content-center">
    <div class="col-12 col-xl-12">

        <div class="d-flex justify-content-between align-items-center mb-4 pb-2">
            <div>
                <h4 class="fw-bold text-dark mb-1"><i class="bi bi-tags text-primary me-2"></i>Category Hub Profiles</h4>
                <p class="text-muted small mb-0">Structural overview of the category branch matched with live product inventory records.</p>
            </div>
            <a asp-action="Index" class="btn btn-light border rounded-pill px-4 fw-semibold small shadow-sm">
                <i class="bi bi-arrow-left me-1"></i> Back to Categories
            </a>
        </div>

        <div class="row g-4">
            <div class="col-12 col-lg-4">
                <div class="card border-0 shadow-sm rounded-4 bg-white p-4 h-100 d-flex flex-column">
                    <div class="d-flex align-items-center pb-3 border-bottom mb-4">
                        <div class="avatar-circle bg-primary-subtle text-primary fw-bold rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 55px; height: 55px;">
                            <i class="bi bi-tag-fill fs-4"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold text-dark mb-1">@Model.Name</h5>
                            <span class="badge bg-light text-secondary border rounded-pill px-3 font-monospace small">
                                CAT-CODE: #@Model.Id.ToString("D3")
                            </span>
                        </div>
                    </div>

                    <h6 class="fw-bold text-secondary mb-3 small text-uppercase tracking-wider">Catalogue Metadata</h6>

                    <div class="mb-4">
                        <label class="text-muted small d-block mb-1">Functional Description</label>
                        <div class="p-3 bg-light rounded-3 border text-secondary small" style="white-space: pre-line;">
                            @(string.IsNullOrWhiteSpace(Model.Description) ? "No operational description documented for this category branch." : Model.Description)
                        </div>
                    </div>

                    <div class="mb-3 p-3 bg-primary-subtle border border-primary-subtle rounded-3">
                        <label class="text-primary-emphasis small d-block mb-1 fw-bold text-uppercase">Tracked SKUs Density</label>
                        <div class="d-flex align-items-baseline">
                            <span class="fs-3 fw-bold text-primary">@Model.TotalProductsCount</span>
                            <span class="text-muted small ms-2">/ Associated Active Products</span>
                        </div>
                    </div>

                    <div class="mb-4 p-3 bg-success-subtle border border-success-subtle rounded-3">
                        <label class="text-success-emphasis small d-block mb-1 fw-bold text-uppercase">Total Inventory Value</label>
                        <div class="d-flex align-items-baseline">
                            <span class="fs-4 fw-bold text-success">$@Model.TotalValue.ToString("N2")</span>
                            <span class="text-muted small ms-2">/ Financial Asset Weight</span>
                        </div>
                    </div>

                    @if (User.IsInRole(Roles.Admin))
                    {
                        <div class="d-flex gap-2 mt-auto pt-3 border-top">
                            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-secondary rounded-pill px-4 fw-semibold w-100">
                                <i class="bi bi-pencil-square me-1"></i> Modify Properties
                            </a>
                        </div>
                    }
                </div>
            </div>

            <div class="col-12 col-lg-8">
                <div class="card border-0 shadow-sm rounded-4 bg-white p-4 h-100 d-flex flex-column">
                    <div class="d-flex align-items-center pb-3 border-bottom mb-4">
                        <i class="bi bi-box-seam text-success fs-4 me-2"></i>
                        <div>
                            <h5 class="fw-bold text-dark mb-0">Assigned Product Catalogue</h5>
                            <small class="text-muted">Real-time catalog monitoring of products tracking under this category group.</small>
                        </div>
                    </div>

                    <div class="table-responsive my-auto" style="max-height: 420px; overflow-y: auto;">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light text-secondary small fw-bold sticky-top">
                                <tr>
                                    <th scope="col" class="ps-2">Product Information</th>
                                    <th scope="col">Price</th>
                                    <th scope="col">Stock Integrity</th>
                                    <th scope="col" class="text-end pe-2">Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.AssociatedProducts != null && Model.AssociatedProducts.Any())
                                {
                                    foreach (var prod in Model.AssociatedProducts)
                                    {
                                        <tr>
                                            <td class="ps-2">
                                                <div>
                                                    <h6 class="fw-bold mb-0 text-dark small">@prod.Name</h6>
                                                    <small class="text-muted" style="font-size: 0.75rem;"><i class="bi bi-truck me-1"></i>@prod.SupplierName</small>
                                                </div>
                                            </td>
                                            <td class="fw-bold text-dark small">$@prod.Price.ToString("N2")</td>
                                            <td class="small">
                                                <span class="fw-semibold text-secondary">@prod.QuantityInStock units</span>
                                                <small class="text-muted d-block" style="font-size: 0.7rem;">Min Safety Level: @prod.MinStockLevel</small>
                                            </td>
                                            <td class="text-end pe-2">
                                                @if (prod.QuantityInStock <= 0)
                                                {
                                                    <span class="badge bg-danger-subtle text-danger border border-danger-subtle rounded-pill px-2.5 py-1 fw-bold" style="font-size: 0.7rem;">Out Of Stock</span>
                                                }
                                                else if (prod.QuantityInStock <= prod.MinStockLevel)
                                                {
                                                    <span class="badge bg-warning-subtle text-warning border border-warning-subtle rounded-pill px-2.5 py-1 fw-bold" style="font-size: 0.7rem;">Low Stock</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill px-2.5 py-1 fw-bold" style="font-size: 0.7rem;">Available</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="4" class="text-center text-muted py-5 small">
                                            <i class="bi bi-box-seam-fill d-block fs-2 mb-2 text-secondary"></i>No product assets are currently registered to this category segment.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>