@model CategoryFormViewModel

@if (Model.IsEditMode)
{
    <input type="hidden" asp-for="Id" />
}

<div class="mb-3">
    <label asp-for="Name" class="form-label fw-bold text-secondary text-uppercase" style="font-size: 0.65rem; letter-spacing: 0.05em;">Category Name</label>
    <div class="input-group border rounded-3" style="border-color: #cbd5e1 !important; overflow: hidden;">
        <span class="input-group-text bg-light border-0 text-muted px-3"><i class="bi bi-tag small"></i></span>
        <input asp-for="Name" class="form-control border-0 bg-white py-2 shadow-none" style="font-size: 0.85rem;" placeholder="e.g. Electronics, Raw Materials" />
    </div>
    <span asp-validation-for="Name" class="text-danger small mt-1 d-block font-monospace" style="font-size: 0.7rem;"></span>
</div>

<div class="mb-4">
    <label asp-for="Description" class="form-label fw-bold text-secondary text-uppercase" style="font-size: 0.65rem; letter-spacing: 0.05em;">Operational Purpose</label>
    <textarea asp-for="Description" class="form-control border rounded-3 bg-white shadow-none p-3" rows="4" style="font-size: 0.85rem; border-color: #cbd5e1 !important;" placeholder="Define category classification rules..."></textarea>
    <span asp-validation-for="Description" class="text-danger small mt-1 d-block font-monospace" style="font-size: 0.7rem;"></span>
</div>

<div class="d-flex justify-content-end gap-2 border-top pt-3 border-light">
    <a asp-action="Index" class="btn btn-light border rounded-pill px-4 fw-medium small text-secondary">Cancel</a>
    <button type="submit" class="btn @(Model.IsEditMode ? "btn-warning text-white" : "btn-dark") rounded-pill px-4 fw-medium shadow-sm" style="font-size: 0.8rem;">
        <i class="bi bi-check-circle-fill me-1"></i> @(Model.IsEditMode ? "Apply Corrections" : "Commit Provision")
    </button>
</div>