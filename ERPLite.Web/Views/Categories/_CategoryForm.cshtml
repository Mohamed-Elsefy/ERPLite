@model CategoryFormViewModel

@if (Model.IsEditMode)
{
    <input type="hidden" asp-for="Id" />
}

<div class="mb-3">
    <label asp-for="Name" class="form-label fw-bold text-secondary small text-uppercase tracking-wider">Category Name</label>
    <div class="input-group">
        <span class="input-group-text bg-light border-end-0 text-muted rounded-start-3"><i class="bi bi-tag"></i></span>
        <input asp-for="Name" class="form-control border-start-0 rounded-end-3" placeholder="e.g., Electronics, Heavy Machinery, Corporate Supplies" />
    </div>
    <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
</div>

<div class="mb-4">
    <label asp-for="Description" class="form-label fw-bold text-secondary small text-uppercase tracking-wider">Operational Purpose</label>
    <textarea asp-for="Description" class="form-control rounded-3" rows="4" placeholder="Document brief details regarding what product types settle within this category node..."></textarea>
    <span asp-validation-for="Description" class="text-danger small mt-1 d-block"></span>
</div>

<div class="d-flex justify-content-end gap-2 border-top pt-3">
    <a asp-action="Index" class="btn btn-light border rounded-pill px-4 fw-semibold small">Cancel</a>
    <button type="submit" class="btn @(Model.IsEditMode ? "btn-warning text-white" : "btn-primary") rounded-pill px-4 fw-semibold shadow-sm">
        <i class="bi bi-check-circle-fill me-1"></i> @(Model.IsEditMode ? "Commit Changes" : "Save Group")
    </button>
</div>