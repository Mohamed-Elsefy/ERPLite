@model CategoryIndexViewModel

@{
    ViewData["Title"] = "Stock Categories Control";
}

<div class="card border-0 shadow-sm rounded-4 bg-white p-4">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
        <div>
            <h4 class="fw-bold text-dark mb-1"><i class="bi bi-tags text-primary me-2"></i>Stock Categories Architecture</h4>
            <p class="text-muted small mb-0">Manage inventory stock groupings, catalogue classifications, and active product criteria.</p>
        </div>
        @if (User.IsInRole(Roles.Admin))
        {
            <a asp-action="Create" class="btn btn-primary rounded-pill px-4 fw-semibold shadow-sm">
                <i class="bi bi-plus-circle-fill me-1"></i> Provision Category
            </a>
        }
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 rounded-3" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form asp-action="Index" method="get" class="row g-2 mb-4">
        <div class="col-12 col-md-5 col-lg-4">
            <div class="input-group">
                <span class="input-group-text bg-white border-end-0 text-muted"><i class="bi bi-search"></i></span>
                <input type="text" name="search" value="@Model.SearchTerm" class="form-control border-start-0 rounded-end-3" placeholder="Filter by category name or description..." />
            </div>
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-light border fw-semibold rounded-3 px-3">Filter</button>
            @if (!string.IsNullOrWhiteSpace(Model.SearchTerm))
            {
                <a asp-action="Index" class="btn btn-link text-decoration-none text-muted small">Clear Criteria</a>
            }
        </div>
    </form>

    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light text-secondary small fw-bold">
                <tr>
                    <th scope="col" class="ps-3">Category Group</th>
                    <th scope="col">Functional Description</th>
                    <th scope="col" class="text-end pe-3">@(User.IsInRole(Roles.Admin) ? "Catalogue Control" : "Actions")</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Categories.Any())
                {
                    <tr>
                        <td colspan="3" class="text-center text-muted py-5">
                            <i class="bi bi-tags-fill fs-1 d-block mb-2 text-secondary"></i>No stock category groups match your system criteria.
                        </td>
                    </tr>
                }
                @foreach (var item in Model.Categories)
                {
                    <tr>
                        <td class="ps-3">
                            <div class="d-flex align-items-center">
                                <div class="avatar-circle bg-light text-primary fw-bold me-3 rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; min-width: 40px;">
                                    @item.Name.Trim().Substring(0, Math.Min(2, item.Name.Trim().Length)).ToUpper()
                                </div>
                                <div>
                                    <h6 class="fw-bold mb-0 text-dark">@item.Name</h6>
                                    <small class="text-muted font-monospace small">CAT-ID: #@item.Id.ToString("D3")</small>
                                </div>
                            </div>
                        </td>
                        <td>
                            <span class="text-muted small text-truncate d-inline-block" style="max-width: 350px;" title="@item.Description">
                                @(string.IsNullOrEmpty(item.Description) ? "No operational description documented for this catalogue group." : item.Description)
                            </span>
                        </td>
                        <td class="text-end pe-3">
                            <div class="d-inline-flex gap-2 align-items-center">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary rounded-pill px-3 fw-semibold" title="View Associated Products Inventory">
                                    <i class="bi bi-eye-fill me-1" style="font-size: 0.75rem;"></i>Details
                                </a>

                                @if (User.IsInRole(Roles.Admin))
                                {
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary rounded-pill px-3 fw-semibold" title="Modify Category Details">
                                        <i class="bi bi-pencil-fill me-1" style="font-size: 0.75rem;"></i>Edit
                                    </a>

                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Are you sure you want to purge this inventory category? This action requires zero active associated products.');" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3 fw-semibold">
                                            <i class="bi bi-trash3-fill me-1"></i>Purge
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>