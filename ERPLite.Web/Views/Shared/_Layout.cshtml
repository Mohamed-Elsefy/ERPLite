<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ERPLite System</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <!-- Sidebar -->
    <div class="sidebar">
        <div class="sidebar-logo">
            <div class="logo-text">ERPLite</div>
            <div class="logo-sub">AI-Powered ERP System</div>
        </div>

        <nav class="sidebar-menu">
            <div class="menu-label">Main</div>
            <div class="nav-item-custom">
                <a asp-controller="Home" asp-action="Index">
                    <i class="fa-solid fa-gauge-high"></i> Dashboard
                </a>
            </div>

            <div class="menu-label">Management</div>
            <div class="nav-item-custom">
                <a href="#">
                    <i class="fa-solid fa-users"></i> HR Module
                </a>
            </div>
            <div class="nav-item-custom">
                <a href="#">
                    <i class="fa-solid fa-boxes-stacked"></i> Inventory
                </a>
            </div>
            <div class="nav-item-custom">
                <a href="#">
                    <i class="fa-solid fa-cart-shopping"></i> Sales
                </a>
            </div>

            <div class="menu-label">Intelligence</div>
            <div class="nav-item-custom">
                <a href="#">
                    <i class="fa-solid fa-brain"></i> AI Insights
                </a>
            </div>
            <div class="nav-item-custom">
                <a href="#">
                    <i class="fa-solid fa-chart-line"></i> Reports
                </a>
            </div>

            <div class="menu-label">System</div>
            <div class="nav-item-custom">
                <a href="#">
                    <i class="fa-solid fa-bell"></i> Notifications
                    <span style="margin-left:auto; background:#ef4444; color:white; border-radius:20px; padding:1px 8px; font-size:0.72rem;">3</span>
                </a>
            </div>
            @if (User.IsInRole("Admin"))
            {
                <div class="nav-item-custom">
                    <a href="#">
                        <i class="fa-solid fa-gear"></i> Settings
                    </a>
                </div>
            }
        </nav>

        <div class="sidebar-footer">
            <div class="user-info">
                <div class="user-avatar">@(User.Identity?.Name?.Length > 0 ? User.Identity.Name.Substring(0, 1).ToUpper() : "U")</div>
                <div>
                    <div class="user-name">@User.Identity?.Name</div>
                    <div class="user-role">@(User.IsInRole("Admin") ? "System Admin" : User.IsInRole("Manager") ? "Manager" : "Employee")</div>
                </div>
            </div>
            <form asp-controller="Auth" asp-action="Logout" method="post">
                <button type="submit" class="btn-logout">
                    <i class="fa-solid fa-right-from-bracket me-1"></i> Sign Out
                </button>
            </form>
        </div>
    </div>

    <!-- Main Content -->
    <div class="main-wrapper">
        <div class="topbar">
            <div class="topbar-title">@ViewData["Title"]</div>
            <div class="topbar-right">
                <div class="notif-btn">
                    <i class="fa-solid fa-bell"></i>
                    <span class="notif-badge">3</span>
                </div>
                <div class="notif-btn">
                    <i class="fa-solid fa-magnifying-glass"></i>
                </div>
            </div>
        </div>

        <div class="page-content">
            @RenderBody()
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
