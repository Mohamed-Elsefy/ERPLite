@{
    var isAdmin = User.IsInRole(Roles.Admin);
    var isManager = User.IsInRole(Roles.Manager);
    var isEmployee = User.IsInRole(Roles.Employee);

    var currentDashboardArea = isAdmin ? Roles.Admin : isManager ? Roles.Manager : Roles.Employee;

    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
}

<div class="sidebar d-flex flex-column shadow-sm min-vh-100" style="width: 250px; min-width: 250px; z-index: 1030;">

    <div class="p-3 border-bottom border-secondary border-opacity-10 bg-black bg-opacity-20 d-flex align-items-center justify-content-center">
        <h5 class="mb-0 fw-bold d-flex align-items-center tracking-wide text-white">
            <i class="bi bi-cpu-fill me-2 fs-4" style="color: #38bdf8;"></i>ERPLite <span class="badge ms-2 font-monospace" style="font-size: 0.55rem; background-color: #1e293b; color: #94a3b8; border: 1px solid #334155;">V1.0</span>
        </h5>
    </div>

    <ul class="nav flex-column mt-3 px-2 flex-grow-1 gap-1">

        <li class="nav-item">
            <a asp-area="@currentDashboardArea" asp-controller="Dashboard" asp-action="Index"
               class="nav-link @(currentAction == "Index" && currentController == "Dashboard" ? "active" : "")">
                <i class="bi bi-grid-1x2-fill me-2 fs-6"></i> Dashboard
            </a>
        </li>

        <li class="nav-item">
            <a asp-area="" asp-controller="Notifications" asp-action="Index"
               class="nav-link @NavigationHelper.IsActive(currentController, "Notifications")">
                <i class="bi bi-bell-fill me-2 fs-6"></i> Notifications
            </a>
        </li>

        @if (isAdmin)
        {
            <li class="nav-item small text-uppercase tracking-wider text-muted px-3 mt-3 mb-1 fw-semibold" style="font-size: 0.65rem; color: #475569 !important;">System Security</li>

            <li class="nav-item">
                <a asp-area="Admin" asp-controller="Users" asp-action="Index"
                   class="nav-link @NavigationHelper.IsActive(currentController, "Users")">
                    <i class="bi bi-person-gear me-2 fs-6"></i> User Accounts
                </a>
            </li>

            <li class="nav-item">
                <a asp-area="Admin" asp-controller="ActivityLogs" asp-action="Index"
                   class="nav-link @NavigationHelper.IsActive(currentController, "ActivityLogs")">
                    <i class="bi bi-journal-text me-2 fs-6"></i> Security Audit Logs
                </a>
            </li>
        }

        @if (isAdmin || isManager)
        {
            <li class="nav-item small text-uppercase tracking-wider text-muted px-3 mt-3 mb-1 fw-semibold" style="font-size: 0.65rem; color: #475569 !important;">Operational Core</li>

            <li class="nav-item">
                <a asp-area="" asp-controller="Customers" asp-action="Index"
                   class="nav-link @NavigationHelper.IsActive(currentController, "Customers")">
                    <i class="bi bi-people me-2 fs-6"></i> Customers Relation
                </a>
            </li>

            <li class="nav-item">
                <a asp-area="" asp-controller="Products" asp-action="Index"
                   class="nav-link @NavigationHelper.IsActive(currentController, "Products")">
                    <i class="bi bi-box-seam me-2 fs-6"></i> Products Catalog
                </a>
            </li>

            <li class="nav-item">
                <a asp-area="" asp-controller="Orders" asp-action="Index"
                   class="nav-link @NavigationHelper.IsActive(currentController, "Orders")">
                    <i class="bi bi-cart me-2 fs-6"></i> Orders Ledger
                </a>
            </li>

            <li class="nav-item">
                <a asp-area="" asp-controller="Payments" asp-action="Index"
                   class="nav-link @NavigationHelper.IsActive(currentController, "Payments")">
                    <i class="bi bi-credit-card me-2 fs-6"></i> Payments Control
                </a>
            </li>

            <li class="nav-item">
                <a asp-area="" asp-controller="Reports" asp-action="Index"
                   class="nav-link @NavigationHelper.IsActive(currentController, "Reports")">
                    <i class="bi bi-pie-chart me-2 fs-6"></i> Intelligence Reports
                </a>
            </li>

            <li class="nav-item small text-uppercase tracking-wider text-muted px-3 mt-3 mb-1 fw-semibold" style="font-size: 0.65rem; color: #475569 !important;">Human Capital</li>

            <li class="nav-item">
                <a asp-area="@currentDashboardArea" asp-controller="Dashboard" asp-action="AttendanceHub"
                   class="nav-link @(currentAction == "AttendanceHub" && currentController == "Dashboard" ? "active" : "")">
                    <i class="bi bi-calendar2-check me-2 fs-6"></i> Attendance Hub
                </a>
            </li>

            <li class="nav-item">
                <a asp-area="" asp-controller="Departments" asp-action="Index"
                   class="nav-link @NavigationHelper.IsActive(currentController, "Departments")">
                    <i class="bi bi-building me-2 fs-6"></i> Departments
                </a>
            </li>

            <li class="nav-item">
                <a asp-area="" asp-controller="Employees" asp-action="Index"
                   class="nav-link @NavigationHelper.IsActive(currentController, "Employees")">
                    <i class="bi bi-person-badge me-2 fs-6"></i> Employees Directory
                </a>
            </li>

            <li class="nav-item small text-uppercase tracking-wider text-muted px-3 mt-3 mb-1 fw-semibold" style="font-size: 0.65rem; color: #475569 !important;">Supply Chain</li>

            <li class="nav-item">
                <a asp-area="" asp-controller="Categories" asp-action="Index"
                   class="nav-link @NavigationHelper.IsActive(currentController, "Categories")">
                    <i class="bi bi-tags me-2 fs-6"></i> Product Categories
                </a>
            </li>

            <li class="nav-item">
                <a asp-area="" asp-controller="Suppliers" asp-action="Index"
                   class="nav-link @NavigationHelper.IsActive(currentController, "Suppliers")">
                    <i class="bi bi-arrow-left-right me-2 fs-6"></i> Suppliers Node
                </a>
            </li>
        }

        @if (isEmployee)
        {
            <li class="nav-item small text-uppercase tracking-wider text-muted px-3 mt-3 mb-1 fw-semibold" style="font-size: 0.65rem; color: #475569 !important;">Personal Portal</li>

            <li class="nav-item">
                <a asp-area="Employee" asp-controller="Attendance" asp-action="Index"
                   class="nav-link @NavigationHelper.IsActive(currentController, "Attendance")">
                    <i class="bi bi-clock me-2 fs-6"></i> Check-In / History
                </a>
            </li>
        }
    </ul>

    <div class="p-2 border-top border-secondary border-opacity-10 text-center small text-muted font-monospace" style="font-size: 0.7rem; background-color: rgba(0,0,0,0.1);">
        2026 &copy; ERPLite Enterprise
    </div>
</div>