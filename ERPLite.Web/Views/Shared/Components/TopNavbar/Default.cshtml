<nav class="navbar navbar-expand-lg navbar-light bg-white px-4 py-2 shadow-sm border-bottom border-light">
    <div class="container-fluid px-0">
        <div class="d-flex align-items-center">
            <span class="navbar-brand mb-0 h6 fw-bold text-dark border-start border-primary border-3 ps-2">
                @(ViewData["Title"] ?? "Enterprise Hub")
            </span>
        </div>

        <div class="d-flex align-items-center ms-auto gap-3">

            <div class="d-flex align-items-center bg-light px-3 py-1.5 rounded-pill border">
                <i class="bi bi-person-circle fs-5 text-primary me-2"></i>
                <div class="d-flex flex-column align-items-start">
                    <span class="fw-bold text-dark small leading-none" style="font-size: 0.8rem; line-height: 1;">@User.Identity?.Name</span>
                    <small class="text-muted font-monospace" style="font-size: 0.65rem;">System Node</small>
                </div>
            </div>

            @await Component.InvokeAsync("NotificationBell")

            <form asp-area="" asp-controller="Auth" asp-action="Logout" method="post" class="m-0" id="logoutForm">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-sm btn-outline-danger d-flex align-items-center gap-1 rounded-pill px-3 fw-semibold shadow-sm transition-all">
                    <i class="bi bi-box-arrow-right"></i> Logout
                </button>
            </form>

        </div>
    </div>
</nav>