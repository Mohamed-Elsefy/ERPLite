<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ERPLite</title>

    <partial name="~/Views/Shared/Infrastructure/_CssLibraries.cshtml" />

    <style>
            body {
                font-family: 'Inter', system-ui, -apple-system, sans-serif;
                letter-spacing: -0.01em;
                color: #334155; 
                background-color: #f8fafc;
            }

            .sidebar {
                background-color: #0f172a !important;
                border-right: 1px solid #1e293b;
            }

                .sidebar .nav-link {
                    color: #94a3b8; 
                    transition: all 0.2s ease-in-out;
                    border-radius: 0.375rem;
                    display: flex;
                    align-items: center;
                    padding: 0.625rem 1rem;
                    font-size: 0.9rem;
                }

                    .sidebar .nav-link i {
                        color: #64748b !important; 
                        transition: color 0.2s ease-in-out;
                    }

                    .sidebar .nav-link:hover {
                        color: #f8fafc;
                        background-color: rgba(255, 255, 255, 0.05);
                    }

                        .sidebar .nav-link:hover i {
                            color: #38bdf8 !important; 
                        }

                    .sidebar .nav-link.active {
                        color: #38bdf8 !important; 
                        background-color: rgba(56, 189, 248, 0.1) !important;
                        font-weight: 500;
                    }

                        .sidebar .nav-link.active i {
                            color: #38bdf8 !important;
                        }

            ::-webkit-scrollbar {
                width: 5px;
                height: 5px;
            }

            ::-webkit-scrollbar-track {
                background: #f1f5f9;
            }

            ::-webkit-scrollbar-thumb {
                background: #cbd5e1;
                border-radius: 10px;
            }

                ::-webkit-scrollbar-thumb:hover {
                    background: #94a3b8;
                }
    </style>
</head>
<body class="bg-light min-vh-100 overflow-x-hidden">

    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <div class="d-flex align-items-stretch min-vh-100">

            <partial name="~/Views/Shared/Components/Sidebar/Default.cshtml" />

            <div class="flex-grow-1 d-flex flex-column bg-light" style="min-width: 0;">

                <partial name="~/Views/Shared/Components/TopNavbar/Default.cshtml" />

                <main class="container-fluid p-4 flex-grow-1">
                    @RenderBody()
                </main>
            </div>
        </div>
    }
    else
    {
        <div class="min-vh-100 d-flex align-items-center justify-content-center" style="background: #f8fafc;">
            <main class="w-100 py-4">
                @RenderBody()
            </main>
        </div>
    }

    <partial name="~/Views/Shared/Infrastructure/_JsLibraries.cshtml" />

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>