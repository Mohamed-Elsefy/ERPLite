@{
    ViewData["Title"] = "Dashboard";
}

@section Styles {
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
}

<!-- Stats Row -->
<div class="row g-3 mb-4">
    <div class="col-md-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon purple"><i class="fa-solid fa-cart-shopping"></i></div>
            <div>
                <div class="stat-label">Total Orders</div>
                <div class="stat-value">1,284</div>
                <div class="stat-change up"><i class="fa-solid fa-arrow-up me-1"></i>12.5% this month</div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon green"><i class="fa-solid fa-dollar-sign"></i></div>
            <div>
                <div class="stat-label">Total Revenue</div>
                <div class="stat-value">$84.2K</div>
                <div class="stat-change up"><i class="fa-solid fa-arrow-up me-1"></i>8.1% vs last month</div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon orange"><i class="fa-solid fa-users"></i></div>
            <div>
                <div class="stat-label">Total Employees</div>
                <div class="stat-value">142</div>
                <div class="stat-change up"><i class="fa-solid fa-arrow-up me-1"></i>3 new this week</div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon red"><i class="fa-solid fa-triangle-exclamation"></i></div>
            <div>
                <div class="stat-label">Low Stock Items</div>
                <div class="stat-value">7</div>
                <div class="stat-change down"><i class="fa-solid fa-arrow-down me-1"></i>Needs attention</div>
            </div>
        </div>
    </div>
</div>

<!-- Modules + Activity Row -->
<div class="row g-3 mb-4">
    <!-- Module Quick Access -->
    <div class="col-lg-8">
        <div class="section-title">System Modules</div>
        <div class="row g-3">
            <div class="col-sm-6 col-md-4">
                <a href="#" class="module-card">
                    <div class="module-icon" style="background:rgba(99,102,241,0.1);">
                        <i class="fa-solid fa-users" style="color:#6366f1;"></i>
                    </div>
                    <div class="module-title">HR Management</div>
                    <div class="module-desc">Employees, departments & attendance tracking</div>
                    <div class="module-arrow"><i class="fa-solid fa-arrow-right"></i> Open Module</div>
                </a>
            </div>
            <div class="col-sm-6 col-md-4">
                <a href="#" class="module-card">
                    <div class="module-icon" style="background:rgba(16,185,129,0.1);">
                        <i class="fa-solid fa-boxes-stacked" style="color:#10b981;"></i>
                    </div>
                    <div class="module-title">Inventory</div>
                    <div class="module-desc">Products, suppliers & stock monitoring</div>
                    <div class="module-arrow"><i class="fa-solid fa-arrow-right"></i> Open Module</div>
                </a>
            </div>
            <div class="col-sm-6 col-md-4">
                <a href="#" class="module-card">
                    <div class="module-icon" style="background:rgba(245,158,11,0.1);">
                        <i class="fa-solid fa-cart-shopping" style="color:#f59e0b;"></i>
                    </div>
                    <div class="module-title">Sales</div>
                    <div class="module-desc">Orders, customers & payment tracking</div>
                    <div class="module-arrow"><i class="fa-solid fa-arrow-right"></i> Open Module</div>
                </a>
            </div>
            <div class="col-sm-6 col-md-4">
                <a href="#" class="module-card">
                    <div class="module-icon" style="background:rgba(239,68,68,0.1);">
                        <i class="fa-solid fa-chart-line" style="color:#ef4444;"></i>
                    </div>
                    <div class="module-title">Reports</div>
                    <div class="module-desc">Generate Excel / PDF reports</div>
                    <div class="module-arrow"><i class="fa-solid fa-arrow-right"></i> Open Module</div>
                </a>
            </div>
            <div class="col-sm-6 col-md-4">
                <a href="#" class="module-card">
                    <div class="module-icon" style="background:rgba(139,92,246,0.1);">
                        <i class="fa-solid fa-brain" style="color:#8b5cf6;"></i>
                    </div>
                    <div class="module-title">AI Insights</div>
                    <div class="module-desc">AI-powered analysis & recommendations</div>
                    <div class="module-arrow"><i class="fa-solid fa-arrow-right"></i> Open Module</div>
                </a>
            </div>
            <div class="col-sm-6 col-md-4">
                <a href="#" class="module-card">
                    <div class="module-icon" style="background:rgba(20,184,166,0.1);">
                        <i class="fa-solid fa-bell" style="color:#14b8a6;"></i>
                    </div>
                    <div class="module-title">Notifications</div>
                    <div class="module-desc">System alerts and priority messages</div>
                    <div class="module-arrow"><i class="fa-solid fa-arrow-right"></i> Open Module</div>
                </a>
            </div>
        </div>
    </div>

    <!-- Recent Activity -->
    <div class="col-lg-4">
        <div class="section-title">Recent Activity</div>
        <div class="activity-card">
            <div class="activity-item">
                <div class="activity-dot" style="background:#10b981;"></div>
                <div>
                    <div class="activity-text">New order #1284 created by Sales Team</div>
                    <div class="activity-time"><i class="fa-regular fa-clock me-1"></i>2 minutes ago</div>
                </div>
            </div>
            <div class="activity-item">
                <div class="activity-dot" style="background:#ef4444;"></div>
                <div>
                    <div class="activity-text">Low stock alert: Keyboard (4 remaining)</div>
                    <div class="activity-time"><i class="fa-regular fa-clock me-1"></i>15 minutes ago</div>
                </div>
            </div>
            <div class="activity-item">
                <div class="activity-dot" style="background:#6366f1;"></div>
                <div>
                    <div class="activity-text">Employee Ahmed Hassan checked in</div>
                    <div class="activity-time"><i class="fa-regular fa-clock me-1"></i>1 hour ago</div>
                </div>
            </div>
            <div class="activity-item">
                <div class="activity-dot" style="background:#f59e0b;"></div>
                <div>
                    <div class="activity-text">AI Report for May 2026 is ready</div>
                    <div class="activity-time"><i class="fa-regular fa-clock me-1"></i>3 hours ago</div>
                </div>
            </div>
            <div class="activity-item">
                <div class="activity-dot" style="background:#10b981;"></div>
                <div>
                    <div class="activity-text">Payment received for Order #1278</div>
                    <div class="activity-time"><i class="fa-regular fa-clock me-1"></i>Yesterday</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- AI Banner -->
<div class="ai-banner">
    <div class="row align-items-center">
        <div class="col-md-8">
            <div class="ai-banner-title"><i class="fa-solid fa-brain me-2" style="color:#818cf8;"></i>AI Insights Engine is Ready</div>
            <div class="ai-banner-desc">Generate intelligent business analysis reports powered by GPT-4o. Get executive summaries, risk detection, and next-month forecasts automatically.</div>
            <button class="btn-ai"><i class="fa-solid fa-wand-magic-sparkles me-2"></i>Generate AI Report</button>
        </div>
        <div class="col-md-4 text-end d-none d-md-block">
            <i class="fa-solid fa-robot" style="font-size:5rem; opacity:0.15; color:white;"></i>
        </div>
    </div>
</div>
