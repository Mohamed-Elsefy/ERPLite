@model CreateCustomerViewModel

@{
    ViewData["Title"] = "Onboard Corporate Customer";
}

<div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
        <div class="card border-0 shadow-sm rounded-4 bg-white p-4">
            <div class="d-flex align-items-center mb-4 pb-3 border-bottom">
                <div class="avatar-circle bg-primary-subtle text-primary rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 45px; height: 45px;">
                    <i class="bi bi-person-plus-fill fs-4"></i>
                </div>
                <div>
                    <h5 class="fw-bold text-dark mb-0">Onboard New Customer</h5>
                    <small class="text-muted">Provision a new commercial relationship file into the unified ERP node.</small>
                </div>
            </div>

            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 small border-0 mb-3"></div>

                <div class="mb-3">
                    <label asp-for="FullName" class="form-label text-secondary small fw-bold">Full Identity Name</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light text-muted border-end-0"><i class="bi bi-person"></i></span>
                        <input asp-for="FullName" class="form-control bg-light border-start-0" placeholder="e.g. Acme Corporation / John Doe" />
                    </div>
                    <span asp-validation-for="FullName" class="text-danger small mt-1 d-block"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Phone" class="form-label text-secondary small fw-bold">Phone Telephony Footprint</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light text-muted border-end-0"><i class="bi bi-telephone"></i></span>
                        <input asp-for="Phone" class="form-control bg-light border-start-0" placeholder="e.g. +1 (555) 019-2834" />
                    </div>
                    <span asp-validation-for="Phone" class="text-danger small mt-1 d-block"></span>
                </div>

                <div class="d-flex gap-2 justify-content-end border-top pt-3">
                    <a asp-action="Index" class="btn btn-light border rounded-pill px-4 fw-semibold btn-sm">Cancel</a>
                    <button type="submit" class="btn btn-primary rounded-pill px-4 fw-semibold btn-sm shadow-sm">
                        <i class="bi bi-cloud-arrow-up-fill me-1"></i>Commit & Onboard
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="~/Views/Shared/Infrastructure/_ValidationScriptsPartial.cshtml" />
}