@model EditCustomerViewModel

@{
    ViewData["Title"] = "Modify Customer Entity";
}

<div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
        <div class="card border-0 shadow-sm rounded-4 bg-white p-4">
            <div class="d-flex align-items-center mb-4 pb-3 border-bottom">
                <div class="avatar-circle bg-warning-subtle text-warning rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 45px; height: 45px;">
                    <i class="bi bi-pencil-square fs-4"></i>
                </div>
                <div>
                    <h5 class="fw-bold text-dark mb-0">Modify Customer Parameters</h5>
                    <small class="text-muted">Update audited entity logs for record alignment and communication safety.</small>
                </div>
            </div>

            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="Id" />

                <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 small border-0 mb-3"></div>

                <div class="mb-3">
                    <label asp-for="FullName" class="form-label text-secondary small fw-bold">Updated Account Name</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light text-muted border-end-0"><i class="bi bi-person"></i></span>
                        <input asp-for="FullName" class="form-control bg-light border-start-0" />
                    </div>
                    <span asp-validation-for="FullName" class="text-danger small mt-1 d-block"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Phone" class="form-label text-secondary small fw-bold">Communication Phone Line</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light text-muted border-end-0"><i class="bi bi-telephone"></i></span>
                        <input asp-for="Phone" class="form-control bg-light border-start-0" />
                    </div>
                    <span asp-validation-for="Phone" class="text-danger small mt-1 d-block"></span>
                </div>

                <div class="d-flex gap-2 justify-content-end border-top pt-3">
                    <a asp-action="Index" class="btn btn-light border rounded-pill px-4 fw-semibold btn-sm">Cancel Alignment</a>
                    <button type="submit" class="btn btn-warning text-dark rounded-pill px-4 fw-semibold btn-sm shadow-sm">
                        <i class="bi bi-check-all me-1"></i>Apply Corrections
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="~/Views/Shared/Infrastructure/_ValidationScriptsPartial.cshtml" />
}