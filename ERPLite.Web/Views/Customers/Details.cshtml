@model ERPLite.Web.Models.Customers.CustomerDetailsViewModel
@{
    ViewData["Title"] = $"Client Audit - {Model.FullName}";
}

<div class="d-flex justify-content-between align-items-center mb-4 pb-2">
    <div>
        <h5 class="fw-bold text-dark mb-1"><i class="bi bi-person-badge text-secondary me-2"></i>Account Dossier</h5>
        <p class="text-muted small mb-0" style="font-size: 0.75rem;">Granular tracking of lifecycle values, onboarding timeline node, and sales pipelines.</p>
    </div>
    <div>
        <a asp-action="Index" class="btn btn-sm btn-light border font-monospace text-dark px-3 py-2" style="font-size: 0.75rem; border-color: #cbd5e1 !important;">
            <i class="bi bi-arrow-left me-1"></i> Back to Registry
        </a>
    </div>
</div>

<div class="row g-4">
    <div class="col-12 col-md-5 col-lg-4">
        <div class="card border-0 shadow-sm bg-white p-4 rounded-4 h-100 d-flex flex-column">
            <div class="text-center pb-4 border-bottom mb-4" style="border-color: #f1f5f9 !important;">
                <div class="bg-light text-secondary rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3 border font-monospace fw-bold fs-4" style="width: 64px; height: 64px; border-color: #e2e8f0 !important;">
                    @Model.FullName.Substring(0, Math.Min(2, Model.FullName.Length)).ToUpper()
                </div>
                <h5 class="fw-bold text-dark mb-1">@Model.FullName</h5>
                <span class="badge bg-light text-secondary border font-monospace small" style="font-size: 0.65rem; border-color: #cbd5e1 !important;">
                    CLIENT-ID: #@Model.CustomerId.ToString("D4")
                </span>
            </div>

            <div class="mb-3">
                <label class="text-muted small d-block mb-1 text-uppercase fw-bold tracking-wider" style="font-size: 0.6rem;">Telecommunication Routing</label>
                <div class="fw-medium text-dark font-monospace small"><i class="bi bi-telephone text-muted me-2"></i>@Model.Phone</div>
            </div>

            <div class="mb-4">
                <label class="text-muted small d-block mb-1 text-uppercase fw-bold tracking-wider" style="font-size: 0.6rem;">System Incorporation Date</label>
                <div class="fw-medium text-secondary small">
                    <i class="bi bi-calendar-event text-muted me-2"></i>@Model.OnboardedAt.ToString("MMMM dd, yyyy - HH:mm")
                </div>
            </div>

            <div class="mt-auto p-3 rounded-4 border border-success-subtle bg-success-subtle bg-opacity-20 text-success">
                <label class="text-success small d-block mb-1 text-uppercase fw-bold tracking-wider" style="font-size: 0.6rem;">Total Lifetime Capital Value (LTV)</label>
                <div class="font-monospace fw-bold fs-3">$@Model.TotalLifetimeValue.ToString("N2")</div>
            </div>

            <div class="pt-3 border-top mt-4" style="border-color: #f1f5f9 !important;">
                <a asp-action="Edit" asp-route-id="@Model.CustomerId" class="btn btn-sm btn-light border font-monospace text-dark w-100 py-2" style="font-size: 0.75rem; border-color: #cbd5e1 !important;">
                    <i class="bi bi-pencil small text-muted me-1"></i>Adjust Client Parameters
                </a>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-7 col-lg-8">
        <div class="card border-0 shadow-sm bg-white p-4 rounded-4 h-100">
            <div class="d-flex align-items-center pb-3 border-bottom mb-4" style="border-color: #f1f5f9 !important;">
                <div class="p-2 rounded-3 me-3 text-secondary border bg-light">
                    <i class="bi bi-receipt fs-5"></i>
                </div>
                <div>
                    <h6 class="fw-bold text-dark mb-0" style="font-size: 0.95rem;">Historical Invoice Orders</h6>
                    <small class="text-muted" style="font-size: 0.75rem;">Cross-department transactional tracking bound to this client account.</small>
                </div>
            </div>

            <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-muted small fw-medium sticky-top" style="background-color: #f8fafc; font-size: 0.75rem;">
                        <tr>
                            <th scope="col" class="ps-2 border-0 py-2.5">Invoice Token</th>
                            <th scope="col" class="border-0 py-2.5">Pipeline Branch</th>
                            <th scope="col" class="border-0 py-2.5">Date Processed</th>
                            <th scope="col" class="text-end pe-2 border-0 py-2.5">Gross Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.OrdersPipeline != null && Model.OrdersPipeline.Any())
                        {
                            foreach (var order in Model.OrdersPipeline)
                            {
                                <tr style="border-color: #f8fafc;">
                                    <td class="ps-2 py-2.5">
                                        <span class="font-monospace fw-medium text-dark small" style="font-size: 0.8rem;">
                                            #INV-@order.Id.ToString("D6")
                                        </span>
                                    </td>
                                    <td class="py-2.5 small text-secondary">
                                        <span class="badge bg-light text-dark border px-2 py-1" style="font-size: 0.65rem; border-color: #e2e8f0 !important;">
                                            Dept-Node: #@order.DepartmentId
                                        </span>
                                    </td>
                                    <td class="text-end pe-2 font-monospace fw-bold text-success small" style="font-size: 0.75rem;">
                                        $@order.TotalPrice.ToString("N2")
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-5" style="background-color: #ffffff;">
                                    <i class="bi bi-receipt-cutoff d-block fs-3 mb-2 text-muted opacity-40"></i>No transaction pipelines have been finalized for this profile.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>