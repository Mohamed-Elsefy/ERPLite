@model ProductIndexViewModel

@{
    ViewData["Title"] = "Warehouse Stock Inventory";
}

<div class="card border-0 shadow-sm rounded-4 bg-white p-4">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
        <div>
            <h4 class="fw-bold text-dark mb-1"><i class="bi bi-box-seam text-primary me-2"></i>Inventory Stock Items</h4>
            <p class="text-muted small mb-0">Track stock integrity, unit valuations, automated alerts thresholds and supplier sources.</p>
        </div>
        @if (User.IsInRole(Roles.Admin))
        {
            <a asp-action="Create" class="btn btn-primary rounded-pill px-4 fw-semibold shadow-sm">
                <i class="bi bi-plus-circle-fill me-1"></i> Provision Product
            </a>
        }
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 rounded-3" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form asp-action="Index" method="get" class="row g-2 mb-4">
        <div class="col-12 col-md-5 col-lg-4">
            <div class="input-group">
                <span class="input-group-text bg-white border-end-0 text-muted"><i class="bi bi-search"></i></span>
                <input type="text" name="search" value="@Model.SearchTerm" class="form-control border-start-0 rounded-end-3" placeholder="Search by item name, category or vendor..." />
            </div>
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-light border fw-semibold rounded-3 px-3">Filter</button>
            @if (!string.IsNullOrWhiteSpace(Model.SearchTerm))
            {
                <a asp-action="Index" class="btn btn-link text-decoration-none text-muted small">Clear Criteria</a>
            }
        </div>
    </form>

    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light text-secondary small fw-bold">
                <tr>
                    <th scope="col" class="ps-3">Product Specifications</th>
                    <th scope="col">Category</th>
                    <th scope="col">Supplier Node</th>
                    <th scope="col">Unit Price</th>
                    <th scope="col">Quantity In Stock</th>
                    <th scope="col">Status</th>
                    <th scope="col" class="text-end pe-3">@(User.IsInRole("Admin") ? "Control Node" : "Actions")</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Products.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-5">
                            <i class="bi bi-boxes fs-1 d-block mb-2 text-secondary"></i>No active warehouse product assets found matching system records.
                        </td>
                    </tr>
                }
                @foreach (var item in Model.Products)
                {
                    <tr>
                        <td class="ps-3">
                            <div>
                                <h6 class="fw-bold mb-0 text-dark">@item.Name</h6>
                                <small class="text-muted font-monospace" style="font-size: 0.7rem;">SKU: #@item.Id.ToString("D4")</small>
                            </div>
                        </td>
                        <td>
                            <span class="badge bg-light text-dark border rounded-pill px-2.5 py-1 small">@item.CategoryName</span>
                        </td>
                        <td><span class="text-secondary small"><i class="bi bi-truck me-1"></i>@item.SupplierName</span></td>
                        <td class="fw-bold text-dark small">$@item.Price.ToString("N2")</td>
                        <td>
                            <span class="fw-bold @(item.QuantityInStock <= item.MinStockLevel ? "text-danger" : "text-secondary")">@item.QuantityInStock units</span>
                            <small class="text-muted d-block font-monospace" style="font-size: 0.65rem;">Min Floor: @item.MinStockLevel</small>
                        </td>
                        <td>
                            @if (item.QuantityInStock <= 0)
                            {
                                <span class="badge bg-danger-subtle text-danger border border-danger-subtle rounded-pill px-2.5 py-1 fw-bold" style="font-size: 0.7rem;">Out Of Stock</span>
                            }
                            else if (item.QuantityInStock <= item.MinStockLevel)
                            {
                                <span class="badge bg-warning-subtle text-warning border border-warning-subtle rounded-pill px-2.5 py-1 fw-bold" style="font-size: 0.7rem;">Low Stock Alert</span>
                            }
                            else
                            {
                                <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill px-2.5 py-1 fw-bold" style="font-size: 0.7rem;">Stable (Available)</span>
                            }
                        </td>
                        <td class="text-end pe-3">
                            <div class="d-inline-flex gap-2 align-items-center">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary rounded-pill px-3 fw-semibold">Details</a>

                                @if (User.IsInRole(Roles.Admin))
                                {
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary rounded-pill px-3 fw-semibold">Edit</a>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Purge item tracking? System will block deletion if bound to historic orders.');" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3 fw-semibold">Purge</button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>