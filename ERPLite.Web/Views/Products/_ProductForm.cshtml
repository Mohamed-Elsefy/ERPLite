@model ProductFormViewModel

@if (Model.IsEditMode)
{
    <input type="hidden" asp-for="Id" />
}

<div class="row g-3">
    <div class="col-12">
        <label asp-for="Name" class="form-label fw-bold text-secondary small text-uppercase tracking-wider">Product Catalog Title</label>
        <div class="input-group">
            <span class="input-group-text bg-light border-end-0 text-muted rounded-start-3"><i class="bi bi-box-seam"></i></span>
            <input asp-for="Name" class="form-control border-start-0 rounded-end-3" placeholder="e.g., Industrial Hydraulic Valve X2, Laser Scanner Head" />
        </div>
        <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
    </div>

    <div class="col-12 col-md-6">
        <label asp-for="Price" class="form-label fw-bold text-secondary small text-uppercase tracking-wider">Unit Asset Price ($)</label>
        <div class="input-group">
            <span class="input-group-text bg-light border-end-0 text-muted rounded-start-3"><i class="bi bi-currency-dollar"></i></span>
            <input asp-for="Price" type="number" step="0.01" class="form-control border-start-0 rounded-end-3" placeholder="0.00" />
        </div>
        <span asp-validation-for="Price" class="text-danger small mt-1 d-block"></span>
    </div>

    <div class="col-12 col-md-6">
        <label asp-for="QuantityInStock" class="form-label fw-bold text-secondary small text-uppercase tracking-wider">Initial Quantity In Stock</label>
        <input asp-for="QuantityInStock" type="number" class="form-control rounded-3" placeholder="0" />
        <span asp-validation-for="QuantityInStock" class="text-danger small mt-1 d-block"></span>
    </div>

    <div class="col-12">
        <label asp-for="MinStockLevel" class="form-label fw-bold text-secondary small text-uppercase tracking-wider">Minimum Safety Stock Level Floor</label>
        <input asp-for="MinStockLevel" type="number" class="form-control rounded-3" placeholder="e.g., 10 (System auto-triggers Low-Stock alarms at this threshold)" />
        <span asp-validation-for="MinStockLevel" class="text-danger small mt-1 d-block"></span>
    </div>

    <div class="col-12 col-md-6">
        <label asp-for="CategoryId" class="form-label fw-bold text-secondary small text-uppercase tracking-wider">Structural Group Segment</label>
        <select asp-for="CategoryId" asp-items="Model.CategoriesList" class="form-select rounded-3">
            <option value="">-- Choose Category Classification --</option>
        </select>
        <span asp-validation-for="CategoryId" class="text-danger small mt-1 d-block"></span>
    </div>

    <div class="col-12 col-md-6">
        <label asp-for="SupplierId" class="form-label fw-bold text-secondary small text-uppercase tracking-wider">Assigned Procurement Vendor</label>
        <select asp-for="SupplierId" asp-items="Model.SuppliersList" class="form-select rounded-3">
            <option value="">-- Choose Logistics Supplier Channel --</option>
        </select>
        <span asp-validation-for="SupplierId" class="text-danger small mt-1 d-block"></span>
    </div>
</div>

<div class="d-flex justify-content-end gap-2 border-top pt-3 mt-4">
    <a asp-action="Index" class="btn btn-light border rounded-pill px-4 fw-semibold small">Cancel</a>
    <button type="submit" class="btn @(Model.IsEditMode ? "btn-warning text-white" : "btn-primary") rounded-pill px-4 fw-semibold shadow-sm">
        <i class="bi bi-check-circle-fill me-1"></i> @(Model.IsEditMode ? "Commit Specifications" : "Provision Item")
    </button>
</div>